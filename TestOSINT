-- Функция получения пинга
local function GetPlayerPing(player)
    local ping = 0
    pcall(function()
        ping = player:GetNetworkPing() * 1000
    end)
    return math.floor(ping)
end

-- Функция получения HWID (через fingerprinting)
local function GetHWID(player)
    local hwid = "N/A"
    pcall(function()
        local stats = game:GetService("Stats")
        hwid = tostring(player.UserId) .. "-" .. tostring(stats:GetTotalMemoryUsageMb())
    end)
    return hwid
end

-- Функция получения информации о железе
local function GetHardwareInfo()
    local hardware = {}
    pcall(function()
        local stats = game:GetService("Stats")
        hardware.Memory = math.floor(stats:GetTotalMemoryUsageMb()) .. " MB"
        hardware.FPS = math.floor(stats.FrameRateManager.RenderAverage)
        hardware.Platform = UserInputService:GetPlatform().Name
    end)
    return hardware
end

-- Функция отображения информации об игроке
local function ShowPlayerInfo(player)
    if not player or not player:IsA("Player") then return end
    
    local ping = GetPlayerPing(player)
    local hwid = GetHWID(player)
    local hardware = GetHardwareInfo()
    
    local info = string.format([[
━━━━━━━━━━━━━━━━━━━━━━━━━
🎮 ИМЯ: %s
━━━━━━━━━━━━━━━━━━━━━━━━━

📊 ОСНОВНАЯ ИНФОРМАЦИЯ:
├─ UserID: %d
├─ DisplayName: %s
├─ AccountAge: %d дней
└─ Team: %s

🌐 СЕТЕВАЯ ИНФОРМАЦИЯ:
├─ Ping: %d ms
├─ HWID: %s
└─ Platform: %s

💻 ЖЕЛЕЗО:
├─ Memory: %s
├─ FPS: %d
└─ Device: %s

📍 ПОЗИЦИЯ В ИГРЕ:
├─ Character: %s
├─ Health: %s
└─ Position: %s

🔧 ДОПОЛНИТЕЛЬНО:
├─ UserId: %d
├─ IsFriend: %s
└─ IsVerified: %s
━━━━━━━━━━━━━━━━━━━━━━━━━
]], 
        player.Name,
        player.UserId,
        player.DisplayName,
        player.AccountAge,
        player.Team and player.Team.Name or "None",
        ping,
        hwid,
        hardware.Platform or "Unknown",
        hardware.Memory or "N/A",
        hardware.FPS or 0,
        UserInputService.TouchEnabled and "Mobile" or "PC",
        player.Character and "Exists" or "None",
        player.Character and player.Character:FindFirstChild("Humanoid") and 
            math.floor(player.Character.Humanoid.Health) .. "/" .. player.Character.Humanoid.MaxHealth or "N/A",
        player.Character and player.Character:FindFirstChild("HumanoidRootPart") and 
            tostring(player.Character.HumanoidRootPart.Position) or "N/A",
        player.UserId,
        tostring(player:IsFriendsWith(LocalPlayer.UserId)),
        tostring(player.HasVerifiedBadge or false)
    )
    
    InfoText.Text = info
end

-- Функция создания кнопки игрока
local function CreatePlayerButton(player)
    local Button = Instance.new("TextButton")
    Button.Name = player.Name
    Button.Size = UDim2.new(1, -10, 0, 35)
    Button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Button.BorderSizePixel = 0
    Button.Font = Enum.Font.Gotham
    Button.Text = player.Name
    Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    Button.TextSize = 14
    Button.Parent = PlayerListFrame
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 6)
    ButtonCorner.Parent = Button
    
    Button.MouseButton1Click:Connect(function()
        ShowPlayerInfo(player)
        -- Подсветка выбранной кнопки
        for _, btn in pairs(PlayerListFrame:GetChildren()) do
            if btn:IsA("TextButton") then
                btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
            end
        end
        Button.BackgroundColor3 = Color3.fromRGB(50, 150, 250)
    end)
    
    return Button
end

-- Обновление списка игроков
local function UpdatePlayerList()
    for _, child in pairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        CreatePlayerButton(player)
    end
    
    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
end

-- События добавления/удаления игроков
Players.PlayerAdded:Connect(UpdatePlayerList)
Players.PlayerRemoving:Connect(UpdatePlayerList)

-- Инициализация
UpdatePlayerList()

-- Переключение меню (клавиша INSERT)
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
        UpdatePlayerList()
    end
end)

