-- Функция получения расстояния до игрока
local function GetDistance(player)
    if not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return "N/A"
    end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return "N/A"
    end
    
    local distance = (player.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
    return math.floor(distance)
end

-- Функция получения информации об устройстве
local function GetDeviceInfo()
    local device = "Unknown"
    if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
        device = "📱 Mobile"
    elseif UserInputService.KeyboardEnabled and UserInputService.MouseEnabled then
        device = "💻 PC"
    elseif UserInputService.GamepadEnabled then
        device = "🎮 Console"
    end
    return device
end

-- Функция получения оружия/инструмента
local function GetEquippedTool(player)
    if not player.Character then return "None" end
    local tool = player.Character:FindFirstChildOfClass("Tool")
    if tool then
        return tool.Name
    end
    return "None"
end

-- Функция получения всех аксессуаров
local function GetAccessories(player)
    if not player.Character then return {} end
    local accessories = {}
    for _, item in pairs(player.Character:GetChildren()) do
        if item:IsA("Accessory") then
            table.insert(accessories, item.Name)
        end
    end
    return accessories
end

-- Функция получения информации о персонаже
local function GetCharacterInfo(player)
    local charInfo = {}
    
    if not player.Character then
        charInfo.Exists = false
        return charInfo
    end
    
    charInfo.Exists = true
    local char = player.Character
    
    -- Humanoid
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        charInfo.Health = math.floor(humanoid.Health)
        charInfo.MaxHealth = math.floor(humanoid.MaxHealth)
        charInfo.HealthPercent = math.floor((charInfo.Health / charInfo.MaxHealth) * 100)
        charInfo.WalkSpeed = humanoid.WalkSpeed
        charInfo.JumpPower = humanoid.JumpPower or humanoid.JumpHeight
        charInfo.DisplayName = humanoid.DisplayName
        charInfo.RigType = humanoid.RigType.Name
        charInfo.AutoRotate = humanoid.AutoRotate
        charInfo.Sit = humanoid.Sit
        charInfo.Jump = humanoid.Jump
        
        -- Состояние
        local state = humanoid:GetState()
        charInfo.State = tostring(state):gsub("Enum.HumanoidStateType.", "")
        
        charInfo.HipHeight = humanoid.HipHeight
    end
    
    -- HumanoidRootPart
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local pos = hrp.Position
        charInfo.Position = string.format("X: %.1f, Y: %.1f, Z: %.1f", pos.X, pos.Y, pos.Z)
        charInfo.PosX = math.floor(pos.X)
        charInfo.PosY = math.floor(pos.Y)
        charInfo.PosZ = math.floor(pos.Z)
        
        local vel = hrp.AssemblyLinearVelocity
        charInfo.Velocity = string.format("%.2f studs/s", vel.Magnitude)
        charInfo.VelocityX = math.floor(vel.X)
        charInfo.VelocityY = math.floor(vel.Y)
        charInfo.VelocityZ = math.floor(vel.Z)
        charInfo.Speed = math.floor(vel.Magnitude)
        
        -- Rotation
        local rot = hrp.CFrame:ToEulerAnglesXYZ()
        charInfo.Rotation = string.format("X: %.1f°, Y: %.1f°, Z: %.1f°", 
            math.deg(rot), math.deg(rot), math.deg(rot))
        
        charInfo.Distance = GetDistance(player)
        charInfo.Mass = math.floor(hrp.AssemblyMass)
    end
    
    -- Части тела
    charInfo.BodyParts = {}
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            table.insert(charInfo.BodyParts, part.Name)
        end
    end
    charInfo.BodyPartsCount = #charInfo.BodyParts
    
    -- Одежда
    charInfo.Clothing = {}
    for _, item in pairs(char:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            table.insert(charInfo.Clothing, item.ClassName)
        end
    end
    
    -- Аксессуары
    charInfo.Accessories = GetAccessories(player)
    charInfo.AccessoryCount = #charInfo.Accessories
    
    -- Инструменты
    charInfo.EquippedTool = GetEquippedTool(player)
    
    -- Backpack
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        charInfo.BackpackTools = {}
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(charInfo.BackpackTools, tool.Name)
            end
        end
        charInfo.BackpackCount = #charInfo.BackpackTools
    else
        charInfo.BackpackCount = 0
        charInfo.BackpackTools = {}
    end
    
    return charInfo
end

-- Функция получения системной информации
local function GetSystemInfo()
    local sysInfo = {}
    
    -- Устройство
    sysInfo.Device = GetDeviceInfo()
    
    -- VR
    sysInfo.VREnabled = VRService.VREnabled
    
    -- Inputs
    sysInfo.TouchEnabled = UserInputService.TouchEnabled
    sysInfo.KeyboardEnabled = UserInputService.KeyboardEnabled
    sysInfo.MouseEnabled = UserInputService.MouseEnabled
    sysInfo.GamepadEnabled = UserInputService.GamepadEnabled
    sysInfo.AccelerometerEnabled = UserInputService.AccelerometerEnabled
    sysInfo.GyroscopeEnabled = UserInputService.GyroscopeEnabled
    
    -- Platform
    local platform = "Unknown"
    pcall(function()
        platform = tostring(UserInputService:GetPlatform())
    end)
    sysInfo.Platform = platform
    
    -- Screen
    local screenSize = workspace.CurrentCamera.ViewportSize
    sysInfo.ScreenResolution = string.format("%dx%d", screenSize.X, screenSize.Y)
    sysInfo.ScreenWidth = screenSize.X
    sysInfo.ScreenHeight = screenSize.Y
    sysInfo.AspectRatio = string.format("%.2f:1", screenSize.X / screenSize.Y)
    
    -- Camera
    local cam = workspace.CurrentCamera
    sysInfo.CameraType = tostring(cam.CameraType):gsub("Enum.CameraType.", "")
    sysInfo.CameraSubject = cam.CameraSubject and cam.CameraSubject.Name or "None"
    sysInfo.FieldOfView = cam.FieldOfView
    
    -- Memory
    sysInfo.MemoryUsage = math.floor(Stats:GetTotalMemoryUsageMb())
    sysInfo.MemoryUsageKB = math.floor(Stats:GetTotalMemoryUsageMb() * 1024)
    
    -- Graphics
    sysInfo.GraphicsQuality = settings().Rendering.QualityLevel
    
    -- Instances
    sysInfo.InstanceCount = Stats.InstanceCount
    sysInfo.PrimitivesCount = Stats.PrimitivesCount
    
    return sysInfo
end

-- Функция получения информации об игроке
local function GetPlayerInfo(player)
    local info = {}
    
    -- Базовая информация
    info.Name = player.Name
    info.DisplayName = player.DisplayName
    info.UserId = player.UserId
    info.AccountAge = player.AccountAge
    info.AccountAgeYears = string.format("%.2f", player.AccountAge / 365)
    info.AccountAgeMonths = math.floor(player.AccountAge / 30)
    
    -- Дата создания
    local creationDate = os.time() - (player.AccountAge * 86400)
    info.AccountCreated = os.date("%d.%m.%Y", creationDate)
    
    -- Premium
    local premium = false
    pcall(function()
        premium = player.MembershipType == Enum.MembershipType.Premium
    end)
    info.IsPremium = premium
    info.PremiumStatus = premium and "✅ Premium" or "❌ Free"
    info.MembershipType = tostring(player.MembershipType):gsub("Enum.MembershipType.", "")
    
    -- Verified Badge
    info.HasVerifiedBadge = player.HasVerifiedBadge
    info.VerifiedStatus = player.HasVerifiedBadge and "✅ Verified" or "❌ Not Verified"
    
    -- Friend
    local isFriend = false
    pcall(function()
        isFriend = player:IsFriendsWith(LocalPlayer.UserId)
    end)
    info.IsFriend = isFriend
    info.FriendStatus = isFriend and "✅ Друг" or "❌ Не друг"
    
    -- Team
    if player.Team then
        info.TeamName = player.Team.Name
        info.TeamColor = tostring(player.Team.TeamColor)
        info.TeamPlayers = #player.Team:GetPlayers()
    else
        info.TeamName = "No Team"
        info.TeamColor = "N/A"
        info.TeamPlayers = 0
    end
    
    -- Locale
    info.LocaleId = player.LocaleId or "Unknown"
    
    -- Following
    info.FollowUserId = player.FollowUserId
    info.IsFollowing = player.FollowUserId ~= 0
    
    -- Guest
    info.IsGuest = player.UserId < 0
    
    return info
end

-- Функция получения статистики
local function GetPlayerStats(player)
    local stats = {}
    
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        stats.Leaderstats = {}
        for _, stat in pairs(leaderstats:GetChildren()) do
            stats.Leaderstats[stat.Name] = tostring(stat.Value)
        end
    else
        stats.Leaderstats = {}
    end
    
    return stats
end

-- Функция получения информации о сервере
local function GetServerInfo()
    local serverInfo = {}
    
    serverInfo.PlaceId = game.PlaceId
    serverInfo.JobId = game.JobId ~= "" and string.sub(game.JobId, 1, 25) .. "..." or "Local Server"
    serverInfo.GameId = game.GameId
    serverInfo.CreatorId = game.CreatorId
    serverInfo.CreatorType = game.CreatorType.Name
    
    serverInfo.TotalPlayers = #Players:GetPlayers()
    serverInfo.MaxPlayers = Players.MaxPlayers
    serverInfo.PlayerSlots = string.format("%d/%d", serverInfo.TotalPlayers, serverInfo.MaxPlayers)
    
    serverInfo.ServerTime = os.date("%H:%M:%S")
    serverInfo.ServerDate = os.date("%d.%m.%Y")
    serverInfo.Uptime = math.floor(time())
    serverInfo.UptimeFormatted = string.format("%02d:%02d:%02d", 
        math.floor(time() / 3600),
        math.floor(time() % 3600 / 60),
        math.floor(time() % 60))
    
    serverInfo.TimeOfDay = Lighting.TimeOfDay
    serverInfo.ClockTime = Lighting.ClockTime
    serverInfo.Brightness = Lighting.Brightness
    serverInfo.FogEnd = Lighting.FogEnd
    serverInfo.FogStart = Lighting.FogStart
    serverInfo.GlobalShadows = Lighting.GlobalShadows
    
    serverInfo.Gravity = Workspace.Gravity
    serverInfo.StreamingEnabled = Workspace.StreamingEnabled
    
    return serverInfo
end

