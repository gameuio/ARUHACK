-- Создание кнопки игрока
local function CreatePlayerButton(player)
    local Button = Instance.new("TextButton")
    Button.Name = player.Name
    Button.Size = UDim2.new(1, -10, 0, 45)
    Button.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
    Button.BorderSizePixel = 0
    Button.Font = Enum.Font.GothamSemibold
    Button.Text = ""
    Button.Parent = PlayerListFrame
    
    local ButtonCorner = Instance.new("UICorner")
    ButtonCorner.CornerRadius = UDim.new(0, 10)
    ButtonCorner.Parent = Button
    
    -- Имя
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size = UDim2.new(1, -20, 1, -25)
    NameLabel.Position = UDim2.new(0, 10, 0, 0)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Font = Enum.Font.GothamBold
    NameLabel.Text = player.Name
    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    NameLabel.TextSize = 13
    NameLabel.TextXAlignment = Enum.TextXAlignment.Left
    NameLabel.TextTruncate = Enum.TextTruncate.AtEnd
    NameLabel.Parent = Button
    
    -- DisplayName
    local DisplayLabel = Instance.new("TextLabel")
    DisplayLabel.Size = UDim2.new(1, -20, 0, 15)
    DisplayLabel.Position = UDim2.new(0, 10, 1, -18)
    DisplayLabel.BackgroundTransparency = 1
    DisplayLabel.Font = Enum.Font.Gotham
    DisplayLabel.Text = "@" .. player.DisplayName
    DisplayLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
    DisplayLabel.TextSize = 10
    DisplayLabel.TextXAlignment = Enum.TextXAlignment.Left
    DisplayLabel.TextTruncate = Enum.TextTruncate.AtEnd
    DisplayLabel.Parent = Button
    
    -- Индикатор состояния
    local StatusIndicator = Instance.new("Frame")
    StatusIndicator.Size = UDim2.new(0, 8, 0, 8)
    StatusIndicator.Position = UDim2.new(0, 5, 0, 5)
    StatusIndicator.BorderSizePixel = 0
    StatusIndicator.Parent = Button
    
    local StatusCorner = Instance.new("UICorner")
    StatusCorner.CornerRadius = UDim.new(1, 0)
    StatusCorner.Parent = StatusIndicator
    
    -- Обновление статуса
    RunService.Heartbeat:Connect(function()
        if player and player.Parent then
            if player.Character and player.Character:FindFirstChild("Humanoid") then
                local health = player.Character.Humanoid.Health
                if health > 75 then
                    StatusIndicator.BackgroundColor3 = Color3.fromRGB(40, 255, 40)
                elseif health > 25 then
                    StatusIndicator.BackgroundColor3 = Color3.fromRGB(255, 255, 40)
                else
                    StatusIndicator.BackgroundColor3 = Color3.fromRGB(255, 40, 40)
                end
            else
                StatusIndicator.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
            end
        end
    end)
    
    Button.MouseButton1Click:Connect(function()
        selectedPlayer = player
        ShowPlayerInfo(player)
        
        -- Подсветка
        for _, btn in pairs(PlayerListFrame:GetChildren()) do
            if btn:IsA("TextButton") then
                btn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
            end
        end
        Button.BackgroundColor3 = Color3.fromRGB(60, 140, 255)
    end)
    
    Button.MouseEnter:Connect(function()
        if selectedPlayer ~= player then
            Button.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
        end
    end)
    
    Button.MouseLeave:Connect(function()
        if selectedPlayer ~= player then
            Button.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        end
    end)
end

-- Обновление списка игроков
local function UpdatePlayerList(searchQuery)
    for _, child in pairs(PlayerListFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end
    
    searchQuery = searchQuery or ""
    searchQuery = searchQuery:lower()
    
    for _, player in pairs(Players:GetPlayers()) do
        if searchQuery == "" or 
           player.Name:lower():find(searchQuery) or 
           player.DisplayName:lower():find(searchQuery) then
            CreatePlayerButton(player)
        end
    end
    
    PlayerListFrame.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 10)
end

-- События
Players.PlayerAdded:Connect(function()
    wait(0.1)
    UpdatePlayerList(SearchBox.Text)
end)

Players.PlayerRemoving:Connect(function(player)
    if selectedPlayer == player then
        selectedPlayer = nil
        ContentText.Text = "❌ Игрок покинул сервер"
    end
    UpdatePlayerList(SearchBox.Text)
end)

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    UpdatePlayerList(SearchBox.Text)
end)

RefreshButton.MouseButton1Click:Connect(function()
    UpdatePlayerList(SearchBox.Text)
    if selectedPlayer and selectedPlayer.Parent then
        ShowPlayerInfo(selectedPlayer)
    end
    RefreshButton.BackgroundColor3 = Color3.fromRGB(60, 255, 100)
    wait(0.2)
    RefreshButton.BackgroundColor3 = Color3.fromRGB(40, 200, 80)
end)

CopyButton.MouseButton1Click:Connect(function()
    if selectedPlayer then
        setclipboard(ContentText.Text)
        CopyButton.Text = "✅"
        wait(1)
        CopyButton.Text = "📋"
    end
end)

-- Автообновление
spawn(function()
    while wait(1) do
        if selectedPlayer and selectedPlayer.Parent and MainFrame.Visible then
            ShowPlayerInfo(selectedPlayer)
        end
    end
end)

-- Инициализация
UpdatePlayerList()

-- Переключение меню
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.Insert then
        MainFrame.Visible = not MainFrame.Visible
        if MainFrame.Visible then
            UpdatePlayerList()
        end
    end
end)

