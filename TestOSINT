        lastFrameTime = currentTime
    end
end)

-- Функция получения РЕАЛЬНОГО пинга
local function GetRealPing(player)
    local success, ping = pcall(function()
        return player:GetNetworkPing()
    end)
    if success and ping then
        return math.floor(ping * 1000)
    end
    return 0
end

-- Функция получения расширенной сетевой информации
local function GetNetworkInfo(player)
    local netInfo = {}
    
    -- Ping
    local ping = GetRealPing(player)
    netInfo.CurrentPing = ping
    
    -- История пинга
    if not pingHistory[player.UserId] then
        pingHistory[player.UserId] = {}
    end
    table.insert(pingHistory[player.UserId], ping)
    if #pingHistory[player.UserId] > 60 then
        table.remove(pingHistory[player.UserId], 1)
    end
    
    -- Статистика пинга
    local total = 0
    local min = 9999
    local max = 0
    for _, p in pairs(pingHistory[player.UserId]) do
        total = total + p
        if p < min then min = p end
        if p > max then max = p end
    end
    netInfo.AvgPing = math.floor(total / #pingHistory[player.UserId])
    netInfo.MinPing = min
    netInfo.MaxPing = max
    netInfo.PingStability = max - min
    netInfo.PingJitter = math.abs(ping - netInfo.AvgPing)
    
    -- Качество соединения
    if ping < 50 then
        netInfo.Quality = "🟢 Отлично"
        netInfo.QualityScore = 100
    elseif ping < 100 then
        netInfo.Quality = "🟡 Хорошо"
        netInfo.QualityScore = 75
    elseif ping < 200 then
        netInfo.Quality = "🟠 Средне"
        netInfo.QualityScore = 50
    else
        netInfo.Quality = "🔴 Плохо"
        netInfo.QualityScore = 25
    end
    
    -- Packet loss (приблизительно)
    netInfo.PacketLoss = netInfo.PingJitter > 50 and "Возможен" or "Нет"
    
    -- Тип соединения
    if ping < 30 then
        netInfo.ConnectionType = "Кабель/Fiber"
    elseif ping < 80 then
        netInfo.ConnectionType = "WiFi (хороший)"
    else
        netInfo.ConnectionType = "WiFi/Mobile"
    end
    
    return netInfo
end

-- Функция получения информации о персонаже (расширенная)
local function GetCharacterInfo(player)
    local charInfo = {}
    
    if not player.Character then
        charInfo.Exists = false
        return charInfo
    end
    
    charInfo.Exists = true
    local char = player.Character
    
    -- Humanoid
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        charInfo.Health = math.floor(humanoid.Health)
        charInfo.MaxHealth = math.floor(humanoid.MaxHealth)
        charInfo.HealthPercent = math.floor((charInfo.Health / charInfo.MaxHealth) * 100)
        charInfo.WalkSpeed = humanoid.WalkSpeed
        charInfo.JumpPower = humanoid.JumpPower or humanoid.JumpHeight
        charInfo.DisplayName = humanoid.DisplayName
        charInfo.RigType = humanoid.RigType.Name
        charInfo.AutoRotate = humanoid.AutoRotate
        charInfo.PlatformStand = humanoid.PlatformStand
        charInfo.Sit = humanoid.Sit
        charInfo.Jump = humanoid.Jump
        charInfo.WalkToPoint = tostring(humanoid.WalkToPoint)
        charInfo.TargetPoint = tostring(humanoid.TargetPoint)
        
        -- Состояние
        local state = humanoid:GetState()
        charInfo.State = tostring(state):gsub("Enum.HumanoidStateType.", "")
        
        -- Hip Height
        charInfo.HipHeight = humanoid.HipHeight
    end
    
    -- HumanoidRootPart
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if hrp then
        local pos = hrp.Position
        charInfo.Position = string.format("X: %.1f, Y: %.1f, Z: %.1f", pos.X, pos.Y, pos.Z)
        charInfo.PosX = math.floor(pos.X)
        charInfo.PosY = math.floor(pos.Y)
        charInfo.PosZ = math.floor(pos.Z)
        
        local vel = hrp.AssemblyLinearVelocity
        charInfo.Velocity = string.format("%.2f studs/s", vel.Magnitude)
        charInfo.VelocityX = math.floor(vel.X)
        charInfo.VelocityY = math.floor(vel.Y)
        charInfo.VelocityZ = math.floor(vel.Z)
        charInfo.Speed = math.floor(vel.Magnitude)
        
        -- Rotation
        local rot = hrp.CFrame:ToEulerAnglesXYZ()
        charInfo.Rotation = string.format("X: %.1f°, Y: %.1f°, Z: %.1f°", 
            math.deg(rot), math.deg(rot), math.deg(rot))
        
        -- Расстояние до локального игрока
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            charInfo.Distance = math.floor(distance)
        else
            charInfo.Distance = "N/A"
        end
        
        -- Mass
        charInfo.Mass = math.floor(hrp.AssemblyMass)
    end
    
    -- Head
    local head = char:FindFirstChild("Head")
    if head then
        charInfo.HeadSize = tostring(head.Size)
        charInfo.HeadColor = tostring(head.Color)
    end
    
    -- Части тела
    charInfo.BodyParts = {}
    for _, part in pairs(char:GetChildren()) do
        if part:IsA("BasePart") then
            table.insert(charInfo.BodyParts, part.Name)
        end
    end
    charInfo.BodyPartsCount = #charInfo.BodyParts
    
    -- Одежда
    charInfo.Clothing = {}
    for _, item in pairs(char:GetChildren()) do
        if item:IsA("Shirt") or item:IsA("Pants") or item:IsA("ShirtGraphic") then
            table.insert(charInfo.Clothing, item.ClassName)
        end
    end
    
    -- Аксессуары
    charInfo.Accessories = {}
    for _, item in pairs(char:GetChildren()) do
        if item:IsA("Accessory") then
            table.insert(charInfo.Accessories, item.Name)
        end
    end
    charInfo.AccessoryCount = #charInfo.Accessories
    
    -- Инструменты
    charInfo.Tools = {}
    for _, item in pairs(char:GetChildren()) do
        if item:IsA("Tool") then
            table.insert(charInfo.Tools, item.Name)
        end
    end
    charInfo.EquippedTool = charInfo.Tools[1] or "None"
    
    -- Backpack
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        charInfo.BackpackTools = {}
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(charInfo.BackpackTools, tool.Name)
            end
        end
        charInfo.BackpackCount = #charInfo.BackpackTools
    end
    
    return charInfo
end

-- Функция получения системной информации
local function GetSystemInfo(player)
    local sysInfo = {}
    
    -- Устройство
    if UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled then
        sysInfo.Device = "📱 Mobile"
        sysInfo.DeviceType = "Mobile"
    elseif UserInputService.KeyboardEnabled and UserInputService.MouseEnabled then
        sysInfo.Device = "💻 PC"
        sysInfo.DeviceType = "PC"
    elseif UserInputService.GamepadEnabled then
        sysInfo.Device = "🎮 Console"
        sysInfo.DeviceType = "Console"
    else
        sysInfo.Device = "❓ Unknown"
        sysInfo.DeviceType = "Unknown"
    end
    
    -- VR
    sysInfo.VREnabled = VRService.VREnabled
    
    -- Touch
    sysInfo.TouchEnabled = UserInputService.TouchEnabled
    sysInfo.KeyboardEnabled = UserInputService.KeyboardEnabled
    sysInfo.MouseEnabled = UserInputService.MouseEnabled
    sysInfo.GamepadEnabled = UserInputService.GamepadEnabled
    sysInfo.AccelerometerEnabled = UserInputService.AccelerometerEnabled
    sysInfo.GyroscopeEnabled = UserInputService.GyroscopeEnabled
    
    -- Platform
    local platform = "Unknown"
    pcall(function()
        platform = UserInputService:GetPlatform().Name
    end)
    sysInfo.Platform = platform
    
    -- Screen
    local screenSize = workspace.CurrentCamera.ViewportSize
    sysInfo.ScreenResolution = string.format("%dx%d", screenSize.X, screenSize.Y)
    sysInfo.ScreenWidth = screenSize.X
    sysInfo.ScreenHeight = screenSize.Y
    sysInfo.AspectRatio = string.format("%.2f:1", screenSize.X / screenSize.Y)
    
    -- Camera
    local cam = workspace.CurrentCamera
    sysInfo.CameraType = tostring(cam.CameraType):gsub("Enum.CameraType.", "")
    sysInfo.CameraSubject = cam.CameraSubject and cam.CameraSubject.Name or "None"
    sysInfo.FieldOfView = cam.FieldOfView
    
    -- FPS
    sysInfo.CurrentFPS = currentFPS
    sysInfo.MinFPS = minFPS
    sysInfo.MaxFPS = maxFPS
    sysInfo.AvgFPS = math.floor((minFPS + maxFPS) / 2)
    
    -- Performance
    if currentFPS >= 55 then
        sysInfo.Performance = "🟢 Отлично"
    elseif currentFPS >= 30 then
        sysInfo.Performance = "🟡 Нормально"
    else
        sysInfo.Performance = "🔴 Плохо"
    end
    
    -- Memory
    sysInfo.MemoryUsage = math.floor(Stats:GetTotalMemoryUsageMb())
    sysInfo.MemoryUsageKB = math.floor(Stats:GetTotalMemoryUsageMb() * 1024)
    
    -- Графика
    sysInfo.GraphicsQuality = settings().Rendering.QualityLevel
    sysInfo.GraphicsMode = settings().Rendering.GraphicsMode
    
    -- Instances
    sysInfo.InstanceCount = Stats.InstanceCount
    sysInfo.PrimitivesCount = Stats.PrimitivesCount
    sysInfo.DataSendKbps = math.floor(Stats.DataSendKbps)
    sysInfo.DataReceiveKbps = math.floor(Stats.DataReceiveKbps)
    sysInfo.PhysicsFPS = math.floor(Stats.PhysicsFPS)
    sysInfo.HeartbeatTime = string.format("%.2f ms", Stats.HeartbeatTimeMs)
    
    return sysInfo
end

-- Функция получения информации об игроке (основная)
local function GetPlayerInfo(player)
    local info = {}
    
    -- Базовая информация
    info.Name = player.Name
    info.DisplayName = player.DisplayName
    info.UserId = player.UserId
    info.AccountAge = player.AccountAge
    info.AccountAgeDays = player.AccountAge
    info.AccountAgeYears = string.format("%.2f", player.AccountAge / 365)
    info.AccountAgeMonths = math.floor(player.AccountAge / 30)
    
    -- Дата создания аккаунта (приблизительно)
    local creationDate = os.time() - (player.AccountAge * 86400)
    info.AccountCreated = os.date("%d.%m.%Y", creationDate)
    
    -- Premium
    local premium = false
    pcall(function()
        premium = player.MembershipType == Enum.MembershipType.Premium
    end)
    info.IsPremium = premium
    info.PremiumStatus = premium and "✅ Premium" or "❌ Free"
    info.MembershipType = tostring(player.MembershipType):gsub("Enum.MembershipType.", "")
    
    -- Verified Badge
    info.HasVerifiedBadge = player.HasVerifiedBadge
    info.VerifiedStatus = player.HasVerifiedBadge and "✅ Verified" or "❌ Not Verified"
    
    -- Friend
    local isFriend = false
    pcall(function()
        isFriend = player:IsFriendsWith(LocalPlayer.UserId)
    end)
    info.IsFriend = isFriend
    info.FriendStatus = isFriend and "✅ Друг" or "❌ Не друг"
    
    -- Team
    if player.Team then
        info.TeamName = player.Team.Name
        info.TeamColor = tostring(player.Team.TeamColor)
        info.TeamPlayers = #player.Team:GetPlayers()
    else
        info.TeamName = "No Team"
        info.TeamColor = "N/A"
        info.TeamPlayers = 0
    end
    
    -- Locale
    info.LocaleId = player.LocaleId or "Unknown"
    info.Region = player.LocaleId or "Unknown"
    
    -- Статус
    info.IsConnected = player.Parent ~= nil
    info.ConnectionStatus = player.Parent and "🟢 Online" or "🔴 Offline"
    
    -- Time
    local timeConnected = tick() - player.AccountAge
    info.TimeInGame = string.format("%.1f мин", (tick() - timeConnected) / 60)
    info.TimeInGameSeconds = math.floor(tick() - timeConnected)
    
    -- Following
    info.FollowUserId = player.FollowUserId
    info.IsFollowing = player.FollowUserId ~= 0
    
    -- Character Age
    if player.Character then
        local charAge = tick() - player.Character:GetPropertyChangedSignal("Parent"):Wait()
        info.CharacterAge = string.format("%.1f сек", charAge)
    else
        info.CharacterAge = "N/A"
    end
    
    -- Guest check
    info.IsGuest = player.UserId < 0
    info.GuestStatus = info.IsGuest and "✅ Guest" or "❌ Not Guest"
    
    -- Chat
    info.CanSendChat = true
    pcall(function()
        info.CanSendChat = TextChatService.ChatVersion == Enum.ChatVersion.TextChatService
    end)
    info.ChatStatus = info.CanSendChat and "✅ Enabled" or "❌ Disabled"
    
    -- Voice Chat
    info.VoiceChatEnabled = false
    pcall(function()
        info.VoiceChatEnabled = player:IsVoiceEnabled()
    end)
    info.VoiceStatus = info.VoiceChatEnabled and "✅ Enabled" or "❌ Disabled"
    
    return info
end

-- Функция получения статистики игрока
local function GetPlayerStats(player)
    local stats = {}
    
    -- Leaderstats
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        stats.Leaderstats = {}
        for _, stat in pairs(leaderstats:GetChildren()) do
            stats.Leaderstats[stat.Name] = tostring(stat.Value)
        end
    else
        stats.Leaderstats = {}
    end
    
    -- Custom stats folders
    for _, folder in pairs(player:GetChildren()) do
        if folder:IsA("Folder") and folder.Name:lower():find("stat") then
            stats[folder.Name] = {}
            for _, stat in pairs(folder:GetChildren()) do
                if stat:IsA("IntValue") or stat:IsA("NumberValue") or stat:IsA("StringValue") then
                    stats[folder.Name][stat.Name] = tostring(stat.Value)
                end
            end
        end
    end
    
    return stats
end

-- Функция получения дополнительной информации
local function GetAdditionalInfo(player)
    local addInfo = {}
    
    -- Server Info
    addInfo.PlaceId = game.PlaceId
    addInfo.JobId = game.JobId ~= "" and string.sub(game.JobId, 1, 25) .. "..." or "Local Server"
    addInfo.GameId = game.GameId
    addInfo.CreatorId = game.CreatorId
    addInfo.CreatorType = game.CreatorType.Name
    
    -- Players
    addInfo.TotalPlayers = #Players:GetPlayers()
    addInfo.MaxPlayers = Players.MaxPlayers
    addInfo.PlayerSlots = string.format("%d/%d", addInfo.TotalPlayers, addInfo.MaxPlayers)
    addInfo.ServerFull = addInfo.TotalPlayers >= addInfo.MaxPlayers
    
    -- Time
    addInfo.ServerTime = os.date("%H:%M:%S")
    addInfo.ServerDate = os.date("%d.%m.%Y")
    addInfo.Uptime = math.floor(time())
    addInfo.UptimeFormatted = string.format("%02d:%02d:%02d", 
        math.floor(time() / 3600),
        math.floor(time() % 3600 / 60),
        math.floor(time() % 60))
    
    -- Lighting
    addInfo.TimeOfDay = Lighting.TimeOfDay
    addInfo.ClockTime = Lighting.ClockTime
    addInfo.Brightness = Lighting.Brightness
    addInfo.FogEnd = Lighting.FogEnd
    addInfo.FogStart = Lighting.FogStart
    addInfo.FogColor = tostring(Lighting.FogColor)
    addInfo.GlobalShadows = Lighting.GlobalShadows
    addInfo.OutdoorAmbient = tostring(Lighting.OutdoorAmbient)
    
    -- Workspace
    addInfo.Gravity = Workspace.Gravity
    addInfo.StreamingEnabled = Workspace.StreamingEnabled
    addInfo.FilteringEnabled = Workspace.FilteringEnabled
    addInfo.AllowThirdPartySales = Workspace.AllowThirdPartySales
    
    -- Sound
    addInfo.MasterVolume = SoundService.MasterVolume
    addInfo.SoundEnabled = SoundService.MasterVolume > 0
    
    -- GUI
    local guiInset = GuiService:GetGuiInset()
    addInfo.GuiInset = string.format("X: %d, Y: %d", guiInset.X, guiInset.Y)
    addInfo.TopbarInset = GuiService.TopbarInset.Height
    
    -- ReplicatedStorage
    addInfo.ReplicatedStorageSize = #ReplicatedStorage:GetChildren()
    
    -- Misc
    addInfo.IsStudio = RunService:IsStudio()
    addInfo.IsServer = RunService:IsServer()
    addInfo.IsClient = RunService:IsClient()
    addInfo.IsLocalPlayer = player == LocalPlayer
    
    return addInfo
end

