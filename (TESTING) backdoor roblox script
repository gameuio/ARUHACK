UI.ExecuteBtn = UI.Utils.CreateButton(UI.InjectContainer, {
    Text = "EXECUTE",
    Icon = "▶️",
    Position = UDim2.new(0, 15, 0, 565),
    Size = UDim2.new(0.32, -7, 0, 55),
    Color = UI.Colors.Button.Success,
    Callback = function()
        local remotePath = UI.TargetBox.Text
        local code = UI.CodeEditor.Text
        
        if remotePath == "" or remotePath:find("Paste remote path") then
            UI.Notify({
                Title = "❌ ERROR",
                Text = "Please specify a target remote path!",
                Duration = 3,
                Color = UI.Colors.Status.Error
            })
            return
        end
        
        if code == "" then
            UI.Notify({
                Title = "⚠️ WARNING",
                Text = "No payload specified. Sending empty call.",
                Duration = 3,
                Color = UI.Colors.Status.Warning
            })
        end
        
        -- Получаем remote
        local success, remote = pcall(function()
            return loadstring("return " .. remotePath)()
        end)
        
        if not success or not remote then
            UI.Notify({
                Title = "❌ INVALID PATH",
                Text = "Remote not found at: " .. remotePath,
                Duration = 4,
                Color = UI.Colors.Status.Error
            })
            
            table.insert(UI.Data.LogEntries, {
                time = os.date("%H:%M:%S"),
                msg = "❌ Invalid remote path: " .. remotePath,
                color = UI.Colors.Status.Error
            })
            return
        end
        
        if not (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
            UI.Notify({
                Title = "❌ NOT A REMOTE",
                Text = "Object is not a RemoteEvent or RemoteFunction",
                Duration = 4,
                Color = UI.Colors.Status.Error
            })
            return
        end
        
        -- Парсим payload
        local payload = nil
        local parseSuccess = false
        
        -- Пытаемся как Lua код
        parseSuccess, payload = pcall(function()
            return loadstring("return " .. code)()
        end)
        
        -- Если не сработало, пытаемся как JSON
        if not parseSuccess then
            parseSuccess, payload = pcall(function()
                return UI.Services.HttpService:JSONDecode(code)
            end)
        end
        
        -- Если всё равно не сработало, используем как строку
        if not parseSuccess then
            payload = code
        end
        
        -- ВАЖНО: Проверяем тип payload
        local payloadType = typeof(payload)
        
        -- Выполняем с защитой
        local execSuccess, execError = pcall(function()
            if remote:IsA("RemoteEvent") then
                -- Для RemoteEvent
                if payloadType == "table" then
                    -- Если это таблица аргументов
                    remote:FireServer(unpack(payload))
                else
                    -- Одиночный аргумент
                    remote:FireServer(payload)
                end
            elseif remote:IsA("RemoteFunction") then
                -- Для RemoteFunction
                if payloadType == "table" then
                    return remote:InvokeServer(unpack(payload))
                else
                    return remote:InvokeServer(payload)
                end
            end
        end)
        
        if execSuccess then
            UI.Notify({
                Title = "✅ SUCCESS",
                Text = string.format("Injected to: %s\nPayload type: %s", remote.Name, payloadType),
                Duration = 4,
                Color = UI.Colors.Status.Success
            })
            
            table.insert(UI.Data.LogEntries, {
                time = os.date("%H:%M:%S"),
                msg = string.format("✅ Injected: %s (%s)", remote.Name, payloadType),
                color = UI.Colors.Status.Success
            })
            
            -- Увеличиваем счетчик
            if not UI.Data.Stats then
                UI.Data.Stats = {InjectionCount = 0}
            end
            UI.Data.Stats.InjectionCount = UI.Data.Stats.InjectionCount + 1
            
        else
            UI.Notify({
                Title = "❌ INJECTION FAILED",
                Text = string.format("Error: %s", tostring(execError)),
                Duration = 5,
                Color = UI.Colors.Status.Error
            })
            
            table.insert(UI.Data.LogEntries, {
                time = os.date("%H:%M:%S"),
                msg = string.format("❌ Failed: %s", tostring(execError)),
                color = UI.Colors.Status.Error
            })
        end
    end
})

