    UI.Notify({
        Title = "🔥 LOADING",
        Text = "Ultimate Remote Spy v" .. UI.Version,
        Duration = 3,
        Color = UI.Colors.Accent.Primary
    })
    
    -- Пытаемся загрузить конфиг
    spawn(function()
        wait(1)
        UI.Config.Load()
    end)
    
    -- Активируем первую вкладку
    if UI.Tabs.SPY then
        UI.Tabs.SPY.button.MouseButton1Click:Fire()
    end
    
    -- Логируем инициализацию
    table.insert(UI.Data.LogEntries, {
        time = os.date("%H:%M:%S"),
        msg = "✅ System initialized successfully",
        color = UI.Colors.Status.Success
    })
    
    table.insert(UI.Data.LogEntries, {
        time = os.date("%H:%M:%S"),
        msg = string.format("📊 Loaded %d tabs", #UI.Tabs),
        color = UI.Colors.Status.Info
