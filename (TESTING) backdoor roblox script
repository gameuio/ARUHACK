            -- Actions
            local actions = {
                {name = "💀", color = Color3.fromRGB(255, 80, 80), cmd = "kill"},
                {name = "🚪", color = Color3.fromRGB(255, 150, 80), cmd = "kick"},
                {name = "📍", color = Color3.fromRGB(100, 180, 255), cmd = "tp"},
                {name = "🧲", color = Color3.fromRGB(150, 100, 255), cmd = "bring"},
                {name = "👁️", color = Color3.fromRGB(100, 255, 200), cmd = "spectate"},
            }
            
            for i, action in ipairs(actions) do
                createButton(item, action.name,
                    UDim2.new(0.55 + (i-1) * 0.09, 0, 0.5, -18),
                    UDim2.new(0, 40, 0, 36),
                    action.color,
                    function()
                        local cmds = {
                            string.format('%s %s', action.cmd, player.Name),
                            {cmd = action.cmd, target = player.Name},
                            {action = action.cmd, player = player.Name}
