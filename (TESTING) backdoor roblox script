function RS.Utils.Notify(config)
    -- Fallback to StarterGui notification if custom UI not available
    if not RS.Notifications.Container then
        RS.Utils.SafeCall(function()
            RS.Services.StarterGui:SetCore("SendNotification", {
                Title = config.Title or "Notification",
                Text = config.Text or "",
                Duration = config.Duration or 5,
                Icon = config.Icon
            })
        end)
        return
    end
    
    -- Queue if too many active
    if #RS.Notifications.Active >= RS.Notifications.MaxActive then
        table.insert(RS.Notifications.Queue, config)
        return
    end
    
    RS.Notifications.Create(config)
end

function RS.Notifications.Create(config)
    if not RS.Notifications.Container then return end
    
    local notif = Instance.new("Frame")
    notif.Name = "Notification"
    notif.Parent = RS.Notifications.Container
    notif.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
    notif.BorderSizePixel = 0
    notif.Size = UDim2.new(0, 320, 0, 90)
    notif.Position = UDim2.new(1, -340, 0, 20 + (#RS.Notifications.Active * 100))
    notif.ZIndex = 1000
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = notif
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = config.Color or Color3.fromRGB(138, 43, 226)
    stroke.Thickness = 2
    stroke.Parent = notif
    
    -- Icon
    if config.Icon then
        local icon = Instance.new("TextLabel")
        icon.Parent = notif
        icon.BackgroundTransparency = 1
        icon.Position = UDim2.new(0, 15, 0, 12)
        icon.Size = UDim2.new(0, 30, 0, 30)
        icon.Font = Enum.Font.GothamBold
        icon.Text = config.Icon
        icon.TextColor3 = Color3.new(1, 1, 1)
        icon.TextSize = 24
        icon.ZIndex = 1001
    end
    
    -- Title
    local title = Instance.new("TextLabel")
    title.Parent = notif
    title.BackgroundTransparency = 1
    title.Position = UDim2.new(0, config.Icon and 55 or 15, 0, 12)
    title.Size = UDim2.new(1, config.Icon and -70 or -30, 0, 22)
    title.Font = Enum.Font.GothamBold
    title.Text = config.Title or "Notification"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.TextSize = 14
    title.TextXAlignment = Enum.TextXAlignment.Left
    title.TextTruncate = Enum.TextTruncate.AtEnd
    title.ZIndex = 1001
    
    -- Message
    local message = Instance.new("TextLabel")
    message.Parent = notif
    message.BackgroundTransparency = 1
    message.Position = UDim2.new(0, config.Icon and 55 or 15, 0, 38)
    message.Size = UDim2.new(1, config.Icon and -70 or -30, 0, 42)
    message.Font = Enum.Font.Gotham
    message.Text = config.Text or ""
    message.TextColor3 = Color3.fromRGB(200, 200, 220)
    message.TextSize = 12
    message.TextXAlignment = Enum.TextXAlignment.Left
    message.TextYAlignment = Enum.TextYAlignment.Top
    message.TextWrapped = true
    message.ZIndex = 1001
    
    -- Progress bar
    local progressBg = Instance.new("Frame")
    progressBg.Parent = notif
    progressBg.BackgroundColor3 = Color3.fromRGB(20, 20, 30)
    progressBg.BorderSizePixel = 0
    progressBg.Position = UDim2.new(0, 0, 1, -4)
    progressBg.Size = UDim2.new(1, 0, 0, 4)
    progressBg.ZIndex = 1001
    
    local progressBar = Instance.new("Frame")
    progressBar.Parent = progressBg
    progressBar.BackgroundColor3 = config.Color or Color3.fromRGB(138, 43, 226)
    progressBar.BorderSizePixel = 0
    progressBar.Size = UDim2.new(1, 0, 1, 0)
    progressBar.ZIndex = 1002
    
    table.insert(RS.Notifications.Active, notif)
    
    -- Slide in animation
    notif.Position = UDim2.new(1, 0, 0, 20 + ((#RS.Notifications.Active - 1) * 100))
    
    RS.Services.TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        Position = UDim2.new(1, -340, 0, 20 + ((#RS.Notifications.Active - 1) * 100))
    }):Play()
    
    -- Progress bar animation
    RS.Services.TweenService:Create(progressBar, TweenInfo.new(config.Duration or 5, Enum.EasingStyle.Linear), {
        Size = UDim2.new(0, 0, 1, 0)
    }):Play()
    
    -- Auto-remove
    spawn(function()
        wait(config.Duration or 5)
        
        -- Slide out
        RS.Services.TweenService:Create(notif, TweenInfo.new(0.3), {
            Position = UDim2.new(1, 0, 0, notif.Position.Y.Offset),
            BackgroundTransparency = 1
        }):Play()
        
        RS.Services.TweenService:Create(stroke, TweenInfo.new(0.3), {
            Transparency = 1
        }):Play()
        
        RS.Services.TweenService:Create(title, TweenInfo.new(0.3), {
            TextTransparency = 1
        }):Play()
        
        RS.Services.TweenService:Create(message, TweenInfo.new(0.3), {
            TextTransparency = 1
        }):Play()
        
        wait(0.3)
        
        -- Remove from active list
        for i, n in ipairs(RS.Notifications.Active) do
            if n == notif then
                table.remove(RS.Notifications.Active, i)
                break
            end
        end
        
        notif:Destroy()
        
        -- Reposition remaining notifications
        for i, n in ipairs(RS.Notifications.Active) do
            RS.Services.TweenService:Create(n, TweenInfo.new(0.2), {
                Position = UDim2.new(1, -340, 0, 20 + ((i - 1) * 100))
            }):Play()
        end
        
        -- Process queue
        if #RS.Notifications.Queue > 0 then
            local queued = table.remove(RS.Notifications.Queue, 1)
            RS.Notifications.Create(queued)
        end
    end)
end

