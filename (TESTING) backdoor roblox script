-- Parse payload
local function parsePayload(text)
    if selectedPayloadType == "STRING" then
        return text
    elseif selectedPayloadType == "NUMBER" then
        return tonumber(text) or 0
    elseif selectedPayloadType == "BOOLEAN" then
        return text:lower() == "true"
    elseif selectedPayloadType == "CUSTOM" then
        local success, result = pcall(function()
            return loadstring("return " .. text)()
        end)
        return success and result or text
    else -- TABLE
        local success, result = pcall(function()
            return HttpService:JSONDecode(text)
        end)
        if not success then
            success, result = pcall(function()
                return loadstring("return " .. text)()
            end)
        end
        return success and result or {}
    end
end

