function RS.ESP.RemoveDrawings(player)
    local drawings = RS.Data.ESP.Drawings[player]
    
    if not drawings then return end
    
    -- Remove box
    for _, line in pairs(drawings.Box) do
        line:Remove()
    end
    
    -- Remove other elements
    drawings.Name:Remove()
    drawings.Distance:Remove()
    drawings.Tracer:Remove()
    drawings.HeadDot:Remove()
    
    drawings.HealthBar.Outline:Remove()
    drawings.HealthBar.Fill:Remove()
    
    for _, line in pairs(drawings.Skeleton) do
        line:Remove()
    end
    
    drawings.LookDirection:Remove()
    
    RS.Data.ESP.Drawings[player] = nil
end

function RS.ESP.UpdatePlayer(player)
    if not RS.Data.ESP.Enabled then return end
    if player == LocalPlayer then return end
    
    local drawings = RS.Data.ESP.Drawings[player]
    if not drawings then return end
    
    local character = player.Character
    
    if not character then
        RS.ESP.HideDrawings(drawings)
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    local head = character:FindFirstChild("Head")
    
    if not rootPart or not humanoid or not head then
        RS.ESP.HideDrawings(drawings)
        return
    end
    
    -- Team check
    if RS.Data.ESP.Settings.TeamCheck then
        if player.Team == LocalPlayer.Team and player.Team ~= nil then
            RS.ESP.HideDrawings(drawings)
            return
        end
    end
    
    -- Distance check
    local localRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not localRoot then
        RS.ESP.HideDrawings(drawings)
        return
    end
    
    local distance = (rootPart.Position - localRoot.Position).Magnitude
    
    if distance > RS.Data.ESP.Settings.MaxDistance then
        RS.ESP.HideDrawings(drawings)
        return
    end
    
    -- WorldToViewportPoint
    local headPos3D = head.Position + Vector3.new(0, 0.5, 0)
    local feetPos3D = rootPart.Position - Vector3.new(0, 3, 0)
    
    local headPos, headOnScreen = Camera:WorldToViewportPoint(headPos3D)
    local feetPos, feetOnScreen = Camera:WorldToViewportPoint(feetPos3D)
    
    if not headOnScreen then
        RS.ESP.HideDrawings(drawings)
        return
    end
    
    -- Calculate box dimensions
    local height = math.abs(headPos.Y - feetPos.Y)
    local width = height / 2
    
    local topLeft = Vector2.new(headPos.X - width / 2, headPos.Y)
    local topRight = Vector2.new(headPos.X + width / 2, headPos.Y)
    local bottomLeft = Vector2.new(feetPos.X - width / 2, feetPos.Y)
    local bottomRight = Vector2.new(feetPos.X + width / 2, feetPos.Y)
    
