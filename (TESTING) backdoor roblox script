RS.Inject = {}

function RS.Inject.ValidateRemote(path)
    local valid, remote = RS.Utils.ParseRemotePath(path)
    
    if not valid then
        return false, remote -- remote contains error message
    end
    
    return true, remote
end

function RS.Inject.ParsePayload(code)
    if not code or code == "" then
        return true, nil
    end
    
    -- Try as Lua expression
    local success, result = pcall(function()
        return loadstring("return " .. code)()
    end)
    
    if success then
        return true, result
    end
    
    -- Try as JSON
    success, result = pcall(function()
        return RS.Services.HttpService:JSONDecode(code)
    end)
    
    if success then
        return true, result
    end
    
    -- Use as raw string
    return true, code
end

function RS.Inject.Execute(remotePath, payloadCode, options)
    options = options or {}
    
    RS.Info("Inject", "Executing injection...", {
        Path = remotePath,
        Payload = payloadCode
    })
    
    -- Validate remote
    local valid, remote = RS.Inject.ValidateRemote(remotePath)
    
    if not valid then
        RS.Error("Inject", "Invalid remote: " .. remote)
        
        RS.Utils.Notify({
            Title = "❌ INVALID REMOTE",
            Text = remote,
            Duration = 5
        })
        
        RS.Data.Inject.Stats.FailedInjections = RS.Data.Inject.Stats.FailedInjections + 1
        return false
    end
    
    -- Parse payload
    local success, payload = RS.Inject.ParsePayload(payloadCode)
    
    if not success then
        RS.Error("Inject", "Invalid payload: " .. tostring(payload))
        
        RS.Utils.Notify({
            Title = "❌ INVALID PAYLOAD",
            Text = "Failed to parse payload",
            Duration = 5
        })
        
        RS.Data.Inject.Stats.FailedInjections = RS.Data.Inject.Stats.FailedInjections + 1
        return false
    end
    
    -- Determine method
    local method = remote:IsA("RemoteEvent") and "FireServer" or "InvokeServer"
    
    -- Execute
    local execSuccess, execResult = RS.Utils.SafeCall(function()
        if payload == nil then
            return remote[method](remote)
        elseif type(payload) == "table" and not getmetatable(payload) then
            -- Assume it's an array of arguments
            return remote[method](remote, unpack(payload))
        else
            return remote[method](remote, payload)
        end
    end)
    
    if execSuccess then
        RS.Success("Inject", string.format(
            "Injection successful: %s.%s()",
            remote.Name,
            method
        ))
        
        RS.Utils.Notify({
            Title = "✅ INJECTION SUCCESS",
            Text = remote.Name,
            Duration = 3
        })
        
        -- Update stats
        RS.Data.Inject.Stats.SuccessfulInjections = RS.Data.Inject.Stats.SuccessfulInjections + 1
        RS.Data.Inject.Stats.TotalInjections = RS.Data.Inject.Stats.TotalInjections + 1
        
        -- Save to history
        if RS.Data.Inject.Settings.SaveHistory then
            table.insert(RS.Data.Inject.History, 1, {
                Remote = remote,
                RemotePath = remotePath,
                Payload = payloadCode,
                Method = method,
                Success = true,
                Timestamp = tick(),
                TimeString = os.date("%H:%M:%S")
            })
            
            if #RS.Data.Inject.History > 100 then
                table.remove(RS.Data.Inject.History)
            end
        end
        
        return true, execResult
    else
        RS.Error("Inject", "Injection failed: " .. tostring(execResult))
        
        RS.Utils.Notify({
            Title = "❌ INJECTION FAILED",
            Text = tostring(execResult),
            Duration = 5
        })
        
        RS.Data.Inject.Stats.FailedInjections = RS.Data.Inject.Stats.FailedInjections + 1
        RS.Data.Inject.Stats.TotalInjections = RS.Data.Inject.Stats.TotalInjections + 1
        
        return false, execResult
    end
end

function RS.Inject.ExecuteMultiple(remotePath, payloadCode, count, delay)
    count = count or 5
    delay = delay or 0.5
    
    RS.Info("Inject", string.format("Starting spam injection: %d times with %s delay", count, delay))
    
    spawn(function()
        local successful = 0
        local failed = 0
        
        for i = 1, count do
            local success = RS.Inject.Execute(remotePath, payloadCode)
            
            if success then
                successful = successful + 1
            else
                failed = failed + 1
            end
            
            if i < count then
                wait(delay)
            end
        end
        
        RS.Success("Inject", string.format(
            "Spam completed: %d/%d successful",
            successful,
            count
        ))
        
        RS.Utils.Notify({
            Title = "🔁 SPAM COMPLETE",
            Text = string.format("%d/%d successful", successful, count),
            Duration = 4
        })
    end)
end

