    elseif payloadType == "Boolean" then
        return text:lower() == "true"
    elseif payloadType == "Custom" then
        local success, result = pcall(function()
            return loadstring("return " .. text)()
        end)
        return success and result or text
    else -- Table
        local success, result = pcall(function()
            return HttpService:JSONDecode(text)
        end)
        if not success then
            success, result = pcall(function()
                return loadstring("return " .. text)()
            end)
        end
        return success and result or {}
    end
end

local function injectPayload(remote, payload)
    local success, err = pcall(function()
        if remote:IsA("RemoteEvent") then
            remote:FireServer(payload)
        elseif remote:IsA("RemoteFunction") then
            remote:InvokeServer(payload)
        end
    end)
    
    if success then
        InjectorStatus.Text = "✅ Injected successfully"
        InjectorStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
        return true
    else
        InjectorStatus.Text = "❌ Injection failed: " .. tostring(err)
        InjectorStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
        return false
    end
end

