-- Функция создания ESP для игрока
function UI.Visuals.CreateESP(player)
    if UI.Visuals.Drawings[player] then
        UI.Visuals.RemoveESP(player)
    end
    
    local drawings = {
        -- Box
        Box = {
            TopLeft = Drawing.new("Line"),
            TopRight = Drawing.new("Line"),
            BottomLeft = Drawing.new("Line"),
            BottomRight = Drawing.new("Line"),
            Left = Drawing.new("Line"),
            Right = Drawing.new("Line"),
            Top = Drawing.new("Line"),
            Bottom = Drawing.new("Line")
        },
        
        -- Name
        Name = Drawing.new("Text"),
        
        -- Distance
        Distance = Drawing.new("Text"),
        
        -- Tracer
        Tracer = Drawing.new("Line"),
        
        -- Health Bar
        HealthBar = {
            Outline = Drawing.new("Square"),
            Fill = Drawing.new("Square")
        }
    }
    
    -- Настройка Box
    for _, line in pairs(drawings.Box) do
        line.Thickness = 1
        line.Color = UI.Visuals.Settings.BoxColor
        line.Transparency = 1
        line.Visible = false
    end
    
    -- Настройка Name
    drawings.Name.Size = 13
    drawings.Name.Center = true
    drawings.Name.Outline = true
    drawings.Name.Color = UI.Visuals.Settings.NameColor
    drawings.Name.Visible = false
    
    -- Настройка Distance
    drawings.Distance.Size = 11
    drawings.Distance.Center = true
    drawings.Distance.Outline = true
    drawings.Distance.Color = Color3.fromRGB(200, 200, 200)
    drawings.Distance.Visible = false
    
    -- Настройка Tracer
    drawings.Tracer.Thickness = 1
    drawings.Tracer.Color = UI.Visuals.Settings.TracerColor
    drawings.Tracer.Transparency = 1
    drawings.Tracer.Visible = false
    
    -- Настройка Health Bar
    drawings.HealthBar.Outline.Thickness = 1
    drawings.HealthBar.Outline.Color = Color3.fromRGB(0, 0, 0)
    drawings.HealthBar.Outline.Filled = false
    drawings.HealthBar.Outline.Visible = false
    
    drawings.HealthBar.Fill.Thickness = 1
    drawings.HealthBar.Fill.Filled = true
    drawings.HealthBar.Fill.Visible = false
    
    UI.Visuals.Drawings[player] = drawings
end

-- Удаление ESP для игрока
function UI.Visuals.RemoveESP(player)
    if not UI.Visuals.Drawings[player] then return end
    
    local drawings = UI.Visuals.Drawings[player]
    
    -- Удаляем Box
    for _, line in pairs(drawings.Box) do
        line:Remove()
    end
    
    -- Удаляем остальное
    drawings.Name:Remove()
    drawings.Distance:Remove()
    drawings.Tracer:Remove()
    drawings.HealthBar.Outline:Remove()
    drawings.HealthBar.Fill:Remove()
    
    UI.Visuals.Drawings[player] = nil
end

-- Обновление ESP для игрока
function UI.Visuals.UpdateESP(player)
    if not UI.Visuals.Enabled then return end
    if player == LocalPlayer then return end
    
    local drawings = UI.Visuals.Drawings[player]
    if not drawings then return end
    
    local character = player.Character
    if not character then
        -- Скрываем все
        for _, line in pairs(drawings.Box) do
            line.Visible = false
        end
        drawings.Name.Visible = false
        drawings.Distance.Visible = false
        drawings.Tracer.Visible = false
        drawings.HealthBar.Outline.Visible = false
        drawings.HealthBar.Fill.Visible = false
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChild("Humanoid")
    
    if not rootPart or not humanoid then return end
    
    -- Team check
    if UI.Visuals.Settings.TeamCheck then
        if player.Team == LocalPlayer.Team then
            for _, line in pairs(drawings.Box) do
                line.Visible = false
            end
            drawings.Name.Visible = false
            drawings.Distance.Visible = false
            drawings.Tracer.Visible = false
            return
        end
    end
    
    -- Проверка дистанции
    local distance = (rootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
    if distance > UI.Visuals.Settings.MaxDistance then
        for _, line in pairs(drawings.Box) do
            line.Visible = false
        end
        drawings.Name.Visible = false
        drawings.Distance.Visible = false
        drawings.Tracer.Visible = false
        drawings.HealthBar.Outline.Visible = false
        drawings.HealthBar.Fill.Visible = false
        return
    end
    
    -- WorldToViewportPoint
    local camera = workspace.CurrentCamera
    local rootPos, onScreen = camera:WorldToViewportPoint(rootPart.Position)
    
    if not onScreen then
        for _, line in pairs(drawings.Box) do
            line.Visible = false
        end
        drawings.Name.Visible = false
        drawings.Distance.Visible = false
        drawings.Tracer.Visible = false
        drawings.HealthBar.Outline.Visible = false
        drawings.HealthBar.Fill.Visible = false
        return
    end
    
    -- Вычисляем размеры бокса
    local head = character:FindFirstChild("Head")
    if not head then return end
    
    local headPos = camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
    local legPos = camera:WorldToViewportPoint(rootPart.Position - Vector3.new(0, 3, 0))
    
    local height = math.abs(headPos.Y - legPos.Y)
    local width = height / 2
    
    -- Boxes
    if UI.Visuals.Settings.Boxes then
        local topLeft = Vector2.new(rootPos.X - width/2, headPos.Y)
        local topRight = Vector2.new(rootPos.X + width/2, headPos.Y)
        local bottomLeft = Vector2.new(rootPos.X - width/2, legPos.Y)
        local bottomRight = Vector2.new(rootPos.X + width/2, legPos.Y)
        
        -- Top
        drawings.Box.Top.From = topLeft
        drawings.Box.Top.To = topRight
        drawings.Box.Top.Visible = true
        
        -- Bottom
        drawings.Box.Bottom.From = bottomLeft
        drawings.Box.Bottom.To = bottomRight
        drawings.Box.Bottom.Visible = true
        
        -- Left
        drawings.Box.Left.From = topLeft
        drawings.Box.Left.To = bottomLeft
        drawings.Box.Left.Visible = true
        
        -- Right
        drawings.Box.Right.From = topRight
        drawings.Box.Right.To = bottomRight
        drawings.Box.Right.Visible = true
    else
        for _, line in pairs(drawings.Box) do
            line.Visible = false
        end
    end
    
    -- Names
    if UI.Visuals.Settings.Names then
        drawings.Name.Text = player.Name
        drawings.Name.Position = Vector2.new(rootPos.X, headPos.Y - 15)
        drawings.Name.Visible = true
    else
        drawings.Name.Visible = false
    end
    
    -- Distance
    if UI.Visuals.Settings.Distance then
        drawings.Distance.Text = string.format("[%d studs]", math.floor(distance))
        drawings.Distance.Position = Vector2.new(rootPos.X, legPos.Y + 5)
        drawings.Distance.Visible = true
    else
        drawings.Distance.Visible = false
    end
    
    -- Tracers
    if UI.Visuals.Settings.Tracers then
        local screenSize = camera.ViewportSize
        drawings.Tracer.From = Vector2.new(screenSize.X / 2, screenSize.Y)
        drawings.Tracer.To = Vector2.new(rootPos.X, legPos.Y)
        drawings.Tracer.Visible = true
    else
        drawings.Tracer.Visible = false
    end
    
    -- Health Bars
    if UI.Visuals.Settings.HealthBars then
        local healthPercent = humanoid.Health / humanoid.MaxHealth
        
        -- Outline
        drawings.HealthBar.Outline.Size = Vector2.new(3, height)
        drawings.HealthBar.Outline.Position = Vector2.new(rootPos.X - width/2 - 8, headPos.Y)
        drawings.HealthBar.Outline.Visible = true
        
        -- Fill
        drawings.HealthBar.Fill.Size = Vector2.new(3, height * healthPercent)
        drawings.HealthBar.Fill.Position = Vector2.new(rootPos.X - width/2 - 8, headPos.Y + (height * (1 - healthPercent)))
        drawings.HealthBar.Fill.Color = Color3.fromRGB(
            math.floor(255 * (1 - healthPercent)),
            math.floor(255 * healthPercent),
            0
        )
        drawings.HealthBar.Fill.Visible = true
    else
        drawings.HealthBar.Outline.Visible = false
        drawings.HealthBar.Fill.Visible = false
    end
end

