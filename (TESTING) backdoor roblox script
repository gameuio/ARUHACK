function RS.ESP.Enable()
    if RS.Data.ESP.Enabled then
        RS.Warning("ESP", "ESP already enabled")
        return false
    end
    
    if not RS.Environment.HasDrawing then
        RS.Error("ESP", "Drawing API not supported")
        return false
    end
    
    RS.Info("ESP", "Enabling ESP...")
    
    -- Create drawings for all players
    for _, player in ipairs(RS.Services.Players:GetPlayers()) do
        if player ~= LocalPlayer then
            RS.Data.ESP.Drawings[player] = RS.ESP.CreateDrawings(player)
        end
    end
    
    RS.Data.ESP.Enabled = true
    RS.Success("ESP", "ESP enabled")
    
    return true
end

function RS.ESP.Disable()
    if not RS.Data.ESP.Enabled then
        return false
    end
    
    RS.Info("ESP", "Disabling ESP...")
    
    -- Remove all drawings
    for player, drawings in pairs(RS.Data.ESP.Drawings) do
        RS.ESP.RemoveDrawings(player)
    end
    
    RS.Data.ESP.Enabled = false
    RS.Success("ESP", "ESP disabled")
    
    return true
end

