    btn.BackgroundColor3 = config.Color or RS.UI.Colors.Button.Primary
    btn.Position = config.Position
    btn.Size = config.Size
    btn.AutoButtonColor = false
    btn.Font = Enum.Font.GothamBold
    btn.Text = config.Icon and (config.Icon .. " " .. config.Text) or config.Text
    btn.TextColor3 = RS.UI.Colors.Text.Primary
    btn.TextSize = config.TextSize or 13
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = btn
    
    if config.Callback then
        btn.MouseButton1Click:Connect(config.Callback)
    end
    
    return btn
end

-- Helper function to create tabs
function RS.UI.CreateTab(name, icon, order)
    local tab = Instance.new("TextButton")
    tab.Name = name .. "Tab"
    tab.Parent = RS.UI.Elements.TabsList
    tab.BackgroundColor3 = RS.UI.Colors.Background.Tertiary
    tab.Size = UDim2.new(0.95, 0, 0, 52)
    tab.AutoButtonColor = false
    tab.Text = ""
    tab.LayoutOrder = order
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = tab
    
    local tabIcon = Instance.new("TextLabel")
    tabIcon.Parent = tab
    tabIcon.BackgroundTransparency = 1
    tabIcon.Position = UDim2.new(0, 14, 0.5, -14)
    tabIcon.Size = UDim2.new(0, 28, 0, 28)
    tabIcon.Font = Enum.Font.GothamBold
    tabIcon.Text = icon
    tabIcon.TextColor3 = RS.UI.Colors.Text.Disabled
    tabIcon.TextSize = 20
    
    local tabText = Instance.new("TextLabel")
    tabText.Parent = tab
    tabText.BackgroundTransparency = 1
    tabText.Position = UDim2.new(0, 48, 0, 0)
    tabText.Size = UDim2.new(1, -54, 1, 0)
    tabText.Font = Enum.Font.GothamBold
    tabText.Text = name
    tabText.TextColor3 = RS.UI.Colors.Text.Tertiary
    tabText.TextSize = 13
    tabText.TextXAlignment = Enum.TextXAlignment.Left
    
    local page = Instance.new("ScrollingFrame")
    page.Name = name .. "Page"
    page.Parent = RS.UI.Elements.Content
    page.BackgroundTransparency = 1
    page.Size = UDim2.new(1, 0, 1, 0)
    page.CanvasSize = UDim2.new(0, 0, 3, 0)
    page.ScrollBarThickness = 6
    page.ScrollBarImageColor3 = RS.UI.Colors.Accent.Primary
    page.Visible = false
    page.BorderSizePixel = 0
    
    local pageLayout = Instance.new("UIListLayout")
    pageLayout.Parent = page
    pageLayout.Padding = UDim.new(0, 12)
    
    local pagePadding = Instance.new("UIPadding")
    pagePadding.Parent = page
    pagePadding.PaddingTop = UDim.new(0, 15)
    pagePadding.PaddingLeft = UDim.new(0, 15)
    pagePadding.PaddingRight = UDim.new(0, 15)
    
    pageLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, pageLayout.AbsoluteContentSize.Y + 30)
    end)
    
    RS.UI.Tabs[name] = {
        Button = tab,
        Icon = tabIcon,
        Text = tabText
    }
    
    RS.UI.Pages[name] = page
    
    tab.MouseButton1Click:Connect(function()
        RS.UI.SwitchTab(name)
    end)
    
    return page
end

function RS.UI.SwitchTab(name)
    for tabName, tabData in pairs(RS.UI.Tabs) do
        local isActive = (tabName == name)
        
        RS.Services.TweenService:Create(tabData.Button, TweenInfo.new(0.2), {
            BackgroundColor3 = isActive and RS.UI.Colors.Background.Elevated or RS.UI.Colors.Background.Tertiary
        }):Play()
        
        RS.Services.TweenService:Create(tabData.Icon, TweenInfo.new(0.2), {
            TextColor3 = isActive and RS.UI.Colors.Accent.Primary or RS.UI.Colors.Text.Disabled
        }):Play()
        
        RS.Services.TweenService:Create(tabData.Text, TweenInfo.new(0.2), {
            TextColor3 = isActive and RS.UI.Colors.Text.Primary or RS.UI.Colors.Text.Tertiary
        }):Play()
        
        RS.UI.Pages[tabName].Visible = isActive
    end
    
    RS.UI.ActiveTab = name
end

function RS.UI.Toggle()
    RS.UI.Visible = not RS.UI.Visible
    RS.UI.Elements.MainFrame.Visible = RS.UI.Visible
    
    if RS.UI.Visible then
        RS.Services.TweenService:Create(RS.UI.Elements.Blur, TweenInfo.new(0.3), {Size = 12}):Play()
    else
        RS.Services.TweenService:Create(RS.UI.Elements.Blur, TweenInfo.new(0.3), {Size = 0}):Play()
    end
end

function RS.UI.Minimize()
    RS.UI.Minimized = not RS.UI.Minimized
    
    local targetSize = RS.UI.Minimized and 
        UDim2.new(0, 900, 0, 60) or
        UDim2.new(0, 900, 0, 700)
    
    RS.Services.TweenService:Create(RS.UI.Elements.MainFrame, TweenInfo.new(0.3), {
        Size = targetSize
    }):Play()
    
    RS.UI.Elements.MinBtn.Text = RS.UI.Minimized and "+" or "─"
end

function RS.UI.Close()
    RS.Services.TweenService:Create(RS.UI.Elements.MainFrame, TweenInfo.new(0.3), {
        Size = UDim2.new(0, 0, 0, 0),
        Position = UDim2.new(0.5, 0, 0.5, 0)
    }):Play()
    
    RS.Services.TweenService:Create(RS.UI.Elements.Blur, TweenInfo.new(0.3), {
        Size = 0
    }):Play()
    
    wait(0.3)
    
    if RS.UI.Elements.ScreenGui then
        RS.UI.Elements.ScreenGui:Destroy()
    end
    
    if RS.UI.Elements.Blur then
        RS.UI.Elements.Blur:Destroy()
    end
end

