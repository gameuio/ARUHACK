-- SPY ENGINE
-- ═══════════════════════════════════════════════════════════════════════════════

function UI.StartSpy()
    if UI.Data.Spy.Active then return false end
    
    local success = pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        UI.Data.Spy.Original.__namecall = mt.__namecall
        
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            if (method == "FireServer" or method == "InvokeServer") and 
               (self:IsA("RemoteEvent") or self:IsA("RemoteFunction")) then
                
                local isOurCall = false
                pcall(function() isOurCall = checkcaller() end)
                
                if not isOurCall and not UI.Data.Spy.Paused then
                    UI.Data.Spy.Stats.TotalCalls = UI.Data.Spy.Stats.TotalCalls + 1
                    
                    local callData = {
                        Remote = self,
                        RemoteName = self.Name,
                        RemotePath = self:GetFullName(),
                        Method = method,
                        Arguments = UI.Utils.SerializeArgs(args),
                        TimeString = os.date("%H:%M:%S")
                    }
                    
                    table.insert(UI.Data.Spy.CapturedCalls, 1, callData)
                    
                    local remoteKey = self:GetFullName()
                    if not UI.Data.Spy.UniqueRemotes[remoteKey] then
                        UI.Data.Spy.UniqueRemotes[remoteKey] = {Remote = self, CallCount = 0}
                        UI.Data.Spy.Stats.UniqueRemotes = UI.Data.Spy.Stats.UniqueRemotes + 1
                    end
                    UI.Data.Spy.UniqueRemotes[remoteKey].CallCount = 
                        UI.Data.Spy.UniqueRemotes[remoteKey].CallCount + 1
                    
                    if UI.UpdateSpyList then
                        UI.UpdateSpyList(callData)
                    end
                end
            end
            
            return UI.Data.Spy.Original.__namecall(self, ...)
        end)
        
        setreadonly(mt, true)
    end)
    
    if success then
        UI.Data.Spy.Active = true
        return true
    end
    return false
end

function UI.StopSpy()
    if not UI.Data.Spy.Active then return false end
    
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        mt.__namecall = UI.Data.Spy.Original.__namecall
        setreadonly(mt, true)
    end)
    
    UI.Data.Spy.Active = false
    return true
end

