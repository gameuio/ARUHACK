-- Network Ownership
function UI.Tools.EnableNetworkOwnership()
    if UI.Tools.NetworkOwnership.Enabled then return end
    UI.Tools.NetworkOwnership.Enabled = true
    
    spawn(function()
        while UI.Tools.NetworkOwnership.Enabled do
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local rootPos = LocalPlayer.Character.HumanoidRootPart.Position
                
                for _, obj in pairs(workspace:GetDescendants()) do
                    if obj:IsA("BasePart") and not obj.Anchored then
                        local distance = (obj.Position - rootPos).Magnitude
                        
                        if distance <= UI.Tools.NetworkOwnership.Radius then
                            -- Пытаемся забрать ownership
                            pcall(function()
                                obj:SetNetworkOwner(LocalPlayer)
                                
                                if not table.find(UI.Tools.NetworkOwnership.OwnedParts, obj) then
                                    table.insert(UI.Tools.NetworkOwnership.OwnedParts, obj)
                                end
                            end)
                        end
                    end
                end
            end
            
            wait(0.5)
        end
    end)
end

function UI.Tools.DisableNetworkOwnership()
    UI.Tools.NetworkOwnership.Enabled = false
    
    -- Возвращаем ownership
    for _, part in pairs(UI.Tools.NetworkOwnership.OwnedParts) do
        pcall(function()
            part:SetNetworkOwnershipAuto()
        end)
    end
    
    UI.Tools.NetworkOwnership.OwnedParts = {}
end

-- Chat Spammer
function UI.Tools.StartChatSpam()
    if UI.Tools.ChatSpammer.Active then return end
    UI.Tools.ChatSpammer.Active = true
    
    spawn(function()
        while UI.Tools.ChatSpammer.Active do
            pcall(function()
                game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
                    UI.Tools.ChatSpammer.Message,
                    "All"
                )
            end)
            
            wait(UI.Tools.ChatSpammer.Delay)
        end
    end)
end

function UI.Tools.StopChatSpam()
    UI.Tools.ChatSpammer.Active = false
end

