-- Hook Remote Function
function hookRemote(remote)
    if hookedRemotes[remote] then
        SpyStatus.Text = "Status: Already hooked - " .. remote.Name
        return
    end
    
    local originalNamecall
    originalNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        local args = {...}
        
        if self == remote and (method == "FireServer" or method == "InvokeServer") then
            table.insert(remoteLog, {
                Remote = remote:GetFullName(),
                Method = method,
                Args = args,
                Time = os.date("%H:%M:%S")
            })
            
            SpyStatus.Text = "🎣 Hooked: " .. remote.Name .. " | " .. method
            SpyStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
            
            -- Log to console
            warn(string.format("[HOOK] %s.%s(%s)", remote:GetFullName(), method, HttpService:JSONEncode(args)))
        end
        
        return originalNamecall(self, ...)
    end)
    
    hookedRemotes[remote] = true
end

-- Block Remote Function
function blockRemote(remote)
    if remote:IsA("RemoteEvent") then
        remote.OnClientEvent:Connect(function() end)
        remote.FireServer = function() end
    elseif remote:IsA("RemoteFunction") then
        remote.OnClientInvoke = function() return nil end
        remote.InvokeServer = function() return nil end
    end
    
    SpyStatus.Text = "🚫 Blocked: " .. remote.Name
    SpyStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
end

-- Fire Remote Function
function fireRemote(remote)
    local success, err = pcall(function()
        if remote:IsA("RemoteEvent") then
            remote:FireServer()
        elseif remote:IsA("RemoteFunction") then
            remote:InvokeServer()
        end
    end)
    
    if success then
        SpyStatus.Text = "✅ Fired: " .. remote.Name
        SpyStatus.TextColor3 = Color3.fromRGB(100, 255, 100)
    else
        SpyStatus.Text = "❌ Failed: " .. tostring(err)
        SpyStatus.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end

