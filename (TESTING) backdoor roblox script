-- Safe function call wrapper
function RS.Utils.SafeCall(func, errorHandler)
    local success, result = pcall(func)
    
    if not success then
        if errorHandler then
            errorHandler(result)
        else
            RS.Error("Utils", "SafeCall failed: " .. tostring(result))
        end
        return false, result
    end
    
    return true, result
end

-- Deep copy table
function RS.Utils.DeepCopy(original)
    local copy
    if type(original) == 'table' then
        copy = {}
        for k, v in next, original, nil do
            copy[RS.Utils.DeepCopy(k)] = RS.Utils.DeepCopy(v)
        end
        setmetatable(copy, RS.Utils.DeepCopy(getmetatable(original)))
    else
        copy = original
    end
    return copy
end

-- Serialize any value to string
function RS.Utils.SerializeValue(value, depth)
    depth = depth or 0
    
    if depth > 5 then
        return "{...}" -- Prevent infinite recursion
    end
    
    local valueType = typeof(value)
    
    if valueType == "nil" then
        return "nil"
        
    elseif valueType == "boolean" then
        return tostring(value)
        
    elseif valueType == "number" then
        if value == math.huge then return "math.huge"
        elseif value == -math.huge then return "-math.huge"
        elseif value ~= value then return "0/0" -- NaN
        else return tostring(value) end
        
    elseif valueType == "string" then
        return string.format("%q", value)
        
    elseif valueType == "table" then
        local items = {}
        local hasIndex = false
        
        for k, v in pairs(value) do
            if type(k) == "number" then
                hasIndex = true
                table.insert(items, RS.Utils.SerializeValue(v, depth + 1))
            else
                local key = type(k) == "string" and k or "[" .. RS.Utils.SerializeValue(k, depth + 1) .. "]"
                table.insert(items, key .. " = " .. RS.Utils.SerializeValue(v, depth + 1))
            end
        end
        
        return "{" .. table.concat(items, ", ") .. "}"
        
    elseif valueType == "Instance" then
        local success, path = pcall(function() return value:GetFullName() end)
        if success then
            return path
        else
            return tostring(value)
        end
        
    elseif valueType == "Vector3" then
        return string.format("Vector3.new(%.2f, %.2f, %.2f)", value.X, value.Y, value.Z)
        
    elseif valueType == "Vector2" then
        return string.format("Vector2.new(%.2f, %.2f)", value.X, value.Y)
        
    elseif valueType == "CFrame" then
        local components = {value:GetComponents()}
        local formattedComponents = {}
        
        for i, component in ipairs(components) do
            table.insert(formattedComponents, string.format("%.2f", component))
        end
        
        return string.format("CFrame.new(%s)", table.concat(formattedComponents, ", "))
        
    elseif valueType == "Color3" then
        return string.format("Color3.fromRGB(%d, %d, %d)", 
            math.floor(value.R * 255),
            math.floor(value.G * 255),
            math.floor(value.B * 255)
        )
        
    elseif valueType == "UDim2" then
        return string.format("UDim2.new(%.2f, %d, %.2f, %d)",
            value.X.Scale, value.X.Offset,
            value.Y.Scale, value.Y.Offset
        )
        
    elseif valueType == "Enum" or valueType == "EnumItem" then
        return tostring(value)
        
    else
        return tostring(value)
    end
end

-- Serialize function arguments
function RS.Utils.SerializeArgs(args)
    local serialized = {}
    
    for i, arg in ipairs(args) do
        table.insert(serialized, {
            Index = i,
            Type = typeof(arg),
            Value = RS.Utils.SerializeValue(arg),
            Raw = arg
        })
    end
    
    return serialized
end

-- Generate Lua code for remote call
function RS.Utils.GenerateRemoteCode(remote, method, args)
    local remotePath = remote:GetFullName()
    local argsStrings = {}
    
    if args then
        for _, arg in ipairs(args) do
            table.insert(argsStrings, arg.Value)
        end
    end
    
    local argsString = table.concat(argsStrings, ", ")
    
    local code = string.format([[
-- Auto-generated by Remote Spy
-- Remote: %s
-- Method: %s
-- Time: %s

local remote = %s

if remote then
    remote:%s(%s)
else
    warn("Remote not found!")
end
]], remote.Name, method, os.date("%Y-%m-%d %H:%M:%S"), remotePath, method, argsString)
    
    return code
end

-- Format bytes
function RS.Utils.FormatBytes(bytes)
    if bytes < 1024 then
        return string.format("%d B", bytes)
    elseif bytes < 1048576 then
        return string.format("%.2f KB", bytes / 1024)
    elseif bytes < 1073741824 then
        return string.format("%.2f MB", bytes / 1048576)
    else
        return string.format("%.2f GB", bytes / 1073741824)
    end
end

-- Format duration
function RS.Utils.FormatDuration(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = seconds % 60
    
    if hours > 0 then
        return string.format("%dh %dm %ds", hours, minutes, secs)
    elseif minutes > 0 then
        return string.format("%dm %ds", minutes, secs)
    else
        return string.format("%ds", secs)
    end
end

-- Get instance path
function RS.Utils.GetInstancePath(instance)
    local success, path = pcall(function()
        return instance:GetFullName()
    end)
    
    return success and path or tostring(instance)
end

-- Check if instance is valid
function RS.Utils.IsValidInstance(instance)
    if not instance then return false end
    
    local success = pcall(function()
        return instance.Parent
    end)
    
    return success
end

-- Parse remote path
function RS.Utils.ParseRemotePath(path)
    local success, remote = pcall(function()
        return loadstring("return " .. path)()
    end)
    
    if not success then
        return false, "Invalid syntax"
    end
    
    if not remote then
        return false, "Remote not found"
    end
    
    if not (remote:IsA("RemoteEvent") or remote:IsA("RemoteFunction")) then
        return false, "Not a RemoteEvent or RemoteFunction"
    end
    
    return true, remote
end

