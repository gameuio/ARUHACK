            itemCorner.CornerRadius = UDim.new(0, 10)
            itemCorner.Parent = item
            
            local itemGradient = Instance.new("UIGradient")
            itemGradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color3.fromRGB(35, 35, 50)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(28, 28, 42))
            }
            itemGradient.Rotation = 90
            itemGradient.Parent = item
            
            -- Avatar
            local avatar = Instance.new("ImageLabel")
            avatar.Parent = item
            avatar.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
            avatar.Position = UDim2.new(0, 10, 0.5, -30)
            avatar.Size = UDim2.new(0, 60, 0, 60)
            avatar.Image = Players:GetUserThumbnailAsync(player.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size150x150)
            
            local avatarCorner = Instance.new("UICorner")
            avatarCorner.CornerRadius = UDim.new(0, 10)
            avatarCorner.Parent = avatar
            
            -- Info
            local nameLabel = createLabel(item, player.Name, UDim2.new(0, 80, 0, 10), UDim2.new(0.4, 0, 0, 22), 14)
            nameLabel.Font = Enum.Font.GothamBold
