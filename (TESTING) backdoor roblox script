-- Cleanup функция
function UI.Cleanup()
    -- Сохраняем конфиг
    UI.Config.Save()
    
    -- Останавливаем все системы
    if UI.Visuals.Enabled then
        UI.Visuals.Disable()
    end
    
    if UI.Player.Flying then
        UI.Player.StopFly()
    end
    
    if UI.Player.InfiniteJump then
        UI.Player.DisableInfiniteJump()
    end
    
    if UI.Player.Flinging then
        UI.Player.DisableFling()
    end
    
    if UI.Tools.NetworkOwnership.Enabled then
        UI.Tools.DisableNetworkOwnership()
    end
    
    if UI.Tools.ChatSpammer.Active then
        UI.Tools.StopChatSpam()
    end
    
    -- Отключаем main loop
    if UI.MainLoop then
        UI.MainLoop:Disconnect()
    end
    
    -- Удаляем GUI
    if UI.Elements.ScreenGui then
        UI.Elements.ScreenGui:Destroy()
    end
    
    if UI.Elements.Blur then
        UI.Elements.Blur:Destroy()
    end
    
    if UI.Notifications.Container then
        UI.Notifications.Container:Destroy()
    end
    
    warn("[CLEANUP] All systems stopped and cleaned up")
end

