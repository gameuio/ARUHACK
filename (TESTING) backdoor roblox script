-- Сериализация аргументов
function UI.Utils.SerializeArgs(args)
    local serialized = {}
    for i, arg in ipairs(args) do
        local argType = typeof(arg)
        local argValue = ""
        
        if argType == "string" then
            argValue = string.format('"%s"', arg)
        elseif argType == "number" then
            argValue = tostring(arg)
        elseif argType == "boolean" then
            argValue = tostring(arg)
        elseif argType == "Instance" then
            argValue = arg:GetFullName()
        elseif argType == "table" then
            local success, json = pcall(function()
                return UI.Services.HttpService:JSONEncode(arg)
            end)
            argValue = success and json or "{...}"
        else
            argValue = tostring(arg)
        end
        
        table.insert(serialized, {Type = argType, Value = argValue, Raw = arg})
    end
    return serialized
end

-- Генерация кода для remote
function UI.Utils.GenerateCode(remote, method, args)
    local argsString = ""
    if args and #args > 0 then
        local argStrings = {}
        for _, arg in ipairs(args) do
            table.insert(argStrings, arg.Value)
        end
        argsString = table.concat(argStrings, ", ")
    end
    
    return string.format(
        "-- Auto-generated\nlocal remote = %s\nremote:%s(%s)",
        remote:GetFullName(),
        method,
        argsString
    )
end

-- Конструктор кнопки
function UI.Utils.CreateButton(parent, config)
    local btn = Instance.new("TextButton")
    btn.Name = (config.Text or "Button"):gsub("%s+", "")
    btn.Parent = parent
    btn.BackgroundColor3 = config.Color or UI.Colors.Button.Primary
    btn.Position = config.Position
    btn.Size = config.Size
    btn.AutoButtonColor = false
    btn.Font = Enum.Font.GothamBold
    btn.Text = config.Icon and (config.Icon .. " " .. config.Text) or config.Text
    btn.TextColor3 = UI.Colors.Text.Primary
    btn.TextSize = 13
    btn.ZIndex = 3
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, UI.Settings.CornerRadius.Medium)
    corner.Parent = btn
    
    local hoverColor = config.HoverColor or UI.Colors.Button.PrimaryHover
    
    btn.MouseEnter:Connect(function()
        UI.Services.TweenService:Create(btn, TweenInfo.new(UI.Settings.AnimationSpeed.Fast), {
            BackgroundColor3 = hoverColor
        }):Play()
    end)
    
    btn.MouseLeave:Connect(function()
        UI.Services.TweenService:Create(btn, TweenInfo.new(UI.Settings.AnimationSpeed.Fast), {
            BackgroundColor3 = config.Color or UI.Colors.Button.Primary
        }):Play()
    end)
    
    if config.Callback then
        btn.MouseButton1Click:Connect(config.Callback)
    end
    
    return btn
end

