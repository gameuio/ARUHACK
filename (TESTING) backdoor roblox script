-- СЕКЦИЯ 4: NOTIFICATION SYSTEM
-- ═══════════════════════════════════════════════════════════════════════════════

UI.Notifications = {
    Container = nil,
    Active = {}
}

function UI.Notify(config)
    if not UI.Notifications.Container then
        UI.Notifications.Container = Instance.new("ScreenGui")
        UI.Notifications.Container.Name = "Notifications"
        UI.Notifications.Container.Parent = UI.Services.CoreGui
        UI.Notifications.Container.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        UI.Notifications.Container.DisplayOrder = 999999
    end
    
    local notif = Instance.new("Frame")
    notif.Parent = UI.Notifications.Container
    notif.BackgroundColor3 = UI.Colors.Background.Secondary
    notif.BorderSizePixel = 0
    notif.Size = UDim2.new(0, 300, 0, 80)
    notif.Position = UDim2.new(1, -320, 0, 20 + (#UI.Notifications.Active * 90))
    notif.ZIndex = 10
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 10)
    corner.Parent = notif
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = config.Color or UI.Colors.Accent.Primary
    stroke.Thickness = 2
    stroke.Parent = notif
    
    local title = UI.Utils.CreateLabel(notif, {
        Text = config.Title or "Notification",
        Position = UDim2.new(0, 15, 0, 10),
        Size = UDim2.new(1, -30, 0, 20),
        TextColor = UI.Colors.Text.Primary,
        TextSize = 14,
        Bold = true
    })
    
    local text = UI.Utils.CreateLabel(notif, {
        Text = config.Text or "",
        Position = UDim2.new(0, 15, 0, 35),
        Size = UDim2.new(1, -30, 0, 35),
        TextColor = UI.Colors.Text.Secondary,
        TextSize = 12,
        TextWrapped = true
    })
    
    table.insert(UI.Notifications.Active, notif)
    
    -- Анимация появления
    notif.Position = UDim2.new(1, 0, 0, 20 + ((#UI.Notifications.Active - 1) * 90))
    UI.Services.TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
        Position = UDim2.new(1, -320, 0, 20 + ((#UI.Notifications.Active - 1) * 90))
    }):Play()
    
    -- Авто-удаление
    spawn(function()
        wait(config.Duration or 5)
        
        UI.Services.TweenService:Create(notif, TweenInfo.new(0.3), {
            Position = UDim2.new(1, 0, 0, notif.Position.Y.Offset),
            BackgroundTransparency = 1
        }):Play()
        
        wait(0.3)
        
        for i, n in ipairs(UI.Notifications.Active) do
            if n == notif then
                table.remove(UI.Notifications.Active, i)
                break
            end
        end
        
        notif:Destroy()
        
        -- Пересчитываем позиции
        for i, n in ipairs(UI.Notifications.Active) do
            UI.Services.TweenService:Create(n, TweenInfo.new(0.2), {
                Position = UDim2.new(1, -320, 0, 20 + ((i - 1) * 90))
            }):Play()
        end
    end)
end

