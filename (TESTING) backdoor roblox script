createHook("__namecall Hook", "Intercept all namecall methods (FireServer, InvokeServer)", Color3.fromRGB(255, 150, 100), function(active)
    if active then
        local oldNamecall
        oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            if method == "FireServer" or method == "InvokeServer" then
                table.insert(logEntries, {
                    time = os.date("%H:%M:%S"),
                    msg = string.format("🎣 %s:%s(%s)", tostring(self), method, HttpService:JSONEncode(args)),
                    color = Color3.fromRGB(255, 200, 100)
                })
            end
            
            return oldNamecall(self, ...)
        end)
        table.insert(logEntries, {time = os.date("%H:%M:%S"), msg = "__namecall hook activated", color = Color3.fromRGB(100, 255, 100)})
    end
end)

