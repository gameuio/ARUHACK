-- Сохранение конфигурации
function UI.Config.Save()
    local config = {
        ESP = {
            Enabled = UI.Visuals.Enabled,
            Boxes = UI.Visuals.Settings.Boxes,
            Names = UI.Visuals.Settings.Names,
            Tracers = UI.Visuals.Settings.Tracers,
            Distance = UI.Visuals.Settings.Distance,
            HealthBars = UI.Visuals.Settings.HealthBars,
            TeamCheck = UI.Visuals.Settings.TeamCheck,
            MaxDistance = UI.Visuals.Settings.MaxDistance
        },
        
        Player = {
            WalkSpeed = UI.Player.Settings.WalkSpeed,
            JumpPower = UI.Player.Settings.JumpPower,
            FlySpeed = UI.Player.Settings.FlySpeed
        },
        
        Exploit = {
            AntiKick = UI.Exploit.AntiKickEnabled,
            AntiAdmin = UI.Exploit.AntiAdminEnabled,
            MemorySpoof = UI.Exploit.MemorySpoofEnabled,
            AdminIDs = UI.Exploit.Settings.AdminIDs,
            AutoLeaveOnAdmin = UI.Exploit.Settings.AutoLeaveOnAdmin
        },
        
        UI = {
            ToggleKey = UI.ToggleKey or "RightControl"
        }
    }
    
    local success, result = pcall(function()
        local json = UI.Services.HttpService:JSONEncode(config)
        writefile(UI.Config.FileName, json)
        return true
    end)
    
    if success then
        UI.Notify({
            Title = "💾 CONFIG SAVED",
            Text = "Configuration saved successfully",
            Duration = 3,
            Color = UI.Colors.Status.Success
        })
        return true
    else
        UI.Notify({
            Title = "❌ SAVE FAILED",
            Text = tostring(result),
            Duration = 5,
            Color = UI.Colors.Status.Error
        })
        return false
    end
end

-- Загрузка конфигурации
function UI.Config.Load()
    local success, result = pcall(function()
        if not isfile(UI.Config.FileName) then
            return nil
        end
        
        local json = readfile(UI.Config.FileName)
        return UI.Services.HttpService:JSONDecode(json)
    end)
    
    if success and result then
        -- Применяем настройки ESP
        UI.Visuals.Settings.Boxes = result.ESP.Boxes
        UI.Visuals.Settings.Names = result.ESP.Names
        UI.Visuals.Settings.Tracers = result.ESP.Tracers
        UI.Visuals.Settings.Distance = result.ESP.Distance
        UI.Visuals.Settings.HealthBars = result.ESP.HealthBars
        UI.Visuals.Settings.TeamCheck = result.ESP.TeamCheck
        UI.Visuals.Settings.MaxDistance = result.ESP.MaxDistance
        
        -- Применяем настройки Player
        UI.Player.Settings.WalkSpeed = result.Player.WalkSpeed
        UI.Player.Settings.JumpPower = result.Player.JumpPower
        UI.Player.Settings.FlySpeed = result.Player.FlySpeed
        
        -- Применяем настройки Exploit
        if result.Exploit.AntiKick then
            UI.Exploit.EnableAntiKick()
        end
        if result.Exploit.AntiAdmin then
            UI.Exploit.EnableAntiAdmin()
        end
        
        UI.Notify({
            Title = "📂 CONFIG LOADED",
            Text = "Configuration loaded successfully",
            Duration = 3,
            Color = UI.Colors.Status.Success
        })
        return true
    else
        UI.Notify({
            Title = "⚠️ NO CONFIG",
            Text = "No saved config found, using defaults",
            Duration = 3,
            Color = UI.Colors.Status.Warning
        })
        return false
    end
end

