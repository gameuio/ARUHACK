-- Anti-Kick
function UI.Exploit.EnableAntiKick()
    if UI.Exploit.AntiKickEnabled then return end
    
    local success = pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        
        local oldNamecall = mt.__namecall
        
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            -- Блокируем Kick
            if method == "Kick" and self == LocalPlayer then
                UI.Exploit.KickAttempts = UI.Exploit.KickAttempts + 1
                
                local reason = args[1] or "No reason provided"
                
                -- Уведомление
                UI.Notify({
                    Title = "🛡️ KICK BLOCKED",
                    Text = string.format("Attempt #%d\nReason: %s", UI.Exploit.KickAttempts, reason),
                    Duration = 5,
                    Color = UI.Colors.Status.Warning
                })
                
                table.insert(UI.Data.LogEntries, {
                    time = os.date("%H:%M:%S"),
                    msg = string.format("🛡️ Blocked kick: %s", reason),
                    color = UI.Colors.Status.Warning
                })
                
                return -- Блокируем кик
            end
            
            return oldNamecall(self, ...)
        end)
        
        setreadonly(mt, true)
    end)
    
    if success then
        UI.Exploit.AntiKickEnabled = true
        return true
    end
    return false
end

-- Anti-Admin
function UI.Exploit.EnableAntiAdmin()
    if UI.Exploit.AntiAdminEnabled then return end
    UI.Exploit.AntiAdminEnabled = true
    
    -- Проверка существующих игроков
    for _, player in pairs(UI.Services.Players:GetPlayers()) do
        UI.Exploit.CheckPlayer(player)
    end
    
    -- Отслеживаем новых игроков
    UI.Exploit.Connections.PlayerAdded = UI.Services.Players.PlayerAdded:Connect(function(player)
        if UI.Exploit.AntiAdminEnabled then
            UI.Exploit.CheckPlayer(player)
        end
    end)
end

function UI.Exploit.DisableAntiAdmin()
    UI.Exploit.AntiAdminEnabled = false
    
    if UI.Exploit.Connections.PlayerAdded then
        UI.Exploit.Connections.PlayerAdded:Disconnect()
    end
end

function UI.Exploit.CheckPlayer(player)
    if player == LocalPlayer then return end
    
    local isAdmin = false
    local reason = ""
    
    -- Проверка по ID
    for _, adminId in ipairs(UI.Exploit.Settings.AdminIDs) do
        if player.UserId == adminId then
            isAdmin = true
            reason = "Matched Admin ID: " .. adminId
            break
        end
    end
    
    -- Проверка по Group Rank
    if not isAdmin and UI.Exploit.Settings.AdminGroupId > 0 then
        local success, rank = pcall(function()
            return player:GetRankInGroup(UI.Exploit.Settings.AdminGroupId)
        end)
        
        if success and rank >= UI.Exploit.Settings.AdminMinRank then
            isAdmin = true
            reason = string.format("Group Rank: %d (Min: %d)", rank, UI.Exploit.Settings.AdminMinRank)
        end
    end
    
    if isAdmin then
        table.insert(UI.Exploit.DetectedAdmins, {
            Player = player,
            Reason = reason,
            DetectedAt = tick()
        })
        
        -- Уведомление
        UI.Notify({
            Title = "⚠️ ADMIN DETECTED",
            Text = string.format("%s\n%s", player.Name, reason),
            Duration = 10,
            Color = UI.Colors.Status.Error
        })
        
        table.insert(UI.Data.LogEntries, {
            time = os.date("%H:%M:%S"),
            msg = string.format("⚠️ Admin detected: %s (%s)", player.Name, reason),
            color = UI.Colors.Status.Error
        })
        
        -- Авто-выход
        if UI.Exploit.Settings.AutoLeaveOnAdmin then
            wait(2)
            LocalPlayer:Kick("Admin detected - Auto leave enabled")
        end
    end
end

-- Memory Spoofer
function UI.Exploit.EnableMemorySpoof()
    if UI.Exploit.MemorySpoofEnabled then return end
    
    pcall(function()
        -- Спуфим getgc
        if getgc then
            local oldGetGC = getgc
            getgc = newcclosure(function(...)
                local results = oldGetGC(...)
                local filtered = {}
                
                for _, obj in pairs(results) do
                    -- Фильтруем наши объекты
                    if typeof(obj) == "table" then
                        if obj ~= UI and obj ~= UI.Data and obj ~= UI.Visuals then
                            table.insert(filtered, obj)
                        end
                    else
                        table.insert(filtered, obj)
                    end
                end
                
                return filtered
            end)
        end
        
        -- Спуфим getgenv
        if getgenv then
            local env = getgenv()
            if env.UI then
                env.UI = nil -- Скрываем из глобальной среды
            end
        end
    end)
    
    UI.Exploit.MemorySpoofEnabled = true
end

