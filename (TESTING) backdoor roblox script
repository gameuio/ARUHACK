                Size = isActive and UDim2.new(0, 4, 0, 24) or UDim2.new(0, 0, 0, 24)
            }):Play()
            
            UI.Pages[tabName].Visible = isActive
        end
        
        UI.ActiveTab = name
    end)
    
    return page
end

