    end
    
    RS.Info("Hooks", "Enabling namecall hook...")
    
    local success = RS.Utils.SafeCall(function()
        local mt = getrawmetatable(game)
        local oldNamecall = mt.__namecall
        
        RS.Data.Hooks.Original.__namecall = oldNamecall
        
        setreadonly(mt, false)
        
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            RS.Data.Hooks.Stats.NamecallHits = RS.Data.Hooks.Stats.NamecallHits + 1
            
            -- Check if we should block
            if RS.Data.Hooks.Settings.BlockMode then
                local path = RS.Utils.GetInstancePath(self)
                
                if RS.Data.Hooks.Blocked[path] then
                    RS.Data.Hooks.Stats.BlockedCalls = RS.Data.Hooks.Stats.BlockedCalls + 1
                    RS.Debug("Hooks", "Blocked namecall: " .. path .. "." .. method)
                    return
                end
            end
            
            -- Log if enabled
            if RS.Data.Hooks.Settings.LogHooks then
                RS.Debug("Hooks", string.format(
                    "Namecall: %s.%s()",
                    tostring(self),
                    method
                ))
            end
            
            return oldNamecall(self, ...)
        end)
        
        setreadonly(mt, true)
    end)
    
    if success then
        RS.Data.Hooks.Active.Namecall = true
        RS.Success("Hooks", "Namecall hook enabled")
