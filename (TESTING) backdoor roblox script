RS.Config = {}

function RS.Config.Save()
    if not RS.Environment.HasWritefile then
        RS.Error("Config", "writefile not supported")
        return false
    end
    
    RS.Info("Config", "Saving configuration...")
    
    local config = {
        Version = RS.Version,
        SavedAt = os.time(),
        
        Spy = {
            Settings = RS.Data.Spy.Settings,
            BlockedRemotes = RS.Data.Spy.BlockedRemotes,
            IgnoredRemotes = RS.Data.Spy.IgnoredRemotes
        },
        
        Inject = {
            Templates = RS.Data.Inject.Templates,
            Settings = RS.Data.Inject.Settings
        },
        
        Hooks = {
            Settings = RS.Data.Hooks.Settings,
            Blocked = RS.Data.Hooks.Blocked
        },
        
        ESP = {
            Settings = RS.Data.ESP.Settings
        },
        
        Player = {
            Settings = RS.Data.Player.Settings
        },
        
        Exploit = {
            Settings = RS.Data.Exploit.Settings
        },
        
        Chat = {
            Settings = RS.Data.Chat.Settings,
            Spammer = {
                Message = RS.Data.Chat.Spammer.Message,
                Delay = RS.Data.Chat.Spammer.Delay
            }
        }
    }
    
    local success, result = pcall(function()
        local json = RS.Services.HttpService:JSONEncode(config)
        writefile(RS.Data.Config.ConfigName, json)
        return true
    end)
    
    if success then
        RS.Data.Config.LastSave = tick()
        RS.Success("Config", "Configuration saved successfully")
        
        RS.Utils.Notify({
            Title = "💾 CONFIG SAVED",
            Text = "All settings saved",
            Duration = 3
        })
        
        return true
    else
        RS.Error("Config", "Failed to save configuration", {Error = result})
        
        RS.Utils.Notify({
            Title = "❌ SAVE FAILED",
            Text = "Check console for details",
            Duration = 5
        })
        
        return false
    end
end

function RS.Config.Load()
    if not RS.Environment.HasReadfile or not RS.Environment.HasIsfile then
        RS.Error("Config", "readfile/isfile not supported")
        return false
    end
    
    if not isfile(RS.Data.Config.ConfigName) then
        RS.Warning("Config", "No config file found")
        return false
    end
    
    RS.Info("Config", "Loading configuration...")
    
    local success, config = pcall(function()
        local json = readfile(RS.Data.Config.ConfigName)
        return RS.Services.HttpService:JSONDecode(json)
    end)
    
    if not success then
        RS.Error("Config", "Failed to load configuration", {Error = config})
        return false
    end
    
    -- Apply settings
    if config.Spy then
        RS.Data.Spy.Settings = config.Spy.Settings or RS.Data.Spy.Settings
        RS.Data.Spy.BlockedRemotes = config.Spy.BlockedRemotes or {}
        RS.Data.Spy.IgnoredRemotes = config.Spy.IgnoredRemotes or {}
    end
    
    if config.Inject then
        RS.Data.Inject.Templates = config.Inject.Templates or {}
        RS.Data.Inject.Settings = config.Inject.Settings or RS.Data.Inject.Settings
    end
    
    if config.Hooks then
        RS.Data.Hooks.Settings = config.Hooks.Settings or RS.Data.Hooks.Settings
        RS.Data.Hooks.Blocked = config.Hooks.Blocked or {}
    end
    
    if config.ESP then
        RS.Data.ESP.Settings = config.ESP.Settings or RS.Data.ESP.Settings
    end
    
    if config.Player then
        RS.Data.Player.Settings = config.Player.Settings or RS.Data.Player.Settings
    end
    
    if config.Exploit then
        RS.Data.Exploit.Settings = config.Exploit.Settings or RS.Data.Exploit.Settings
    end
    
    if config.Chat then
        RS.Data.Chat.Settings = config.Chat.Settings or RS.Data.Chat.Settings
        
        if config.Chat.Spammer then
            RS.Data.Chat.Spammer.Message = config.Chat.Spammer.Message or ""
            RS.Data.Chat.Spammer.Delay = config.Chat.Spammer.Delay or 1
        end
    end
    
    RS.Success("Config", "Configuration loaded successfully")
    
    RS.Utils.Notify({
        Title = "📂 CONFIG LOADED",
        Text = "All settings restored",
        Duration = 3
    })
    
    return true
end

function RS.Config.Reset()
    RS.Info("Config", "Resetting configuration to defaults...")
    
    if RS.Environment.HasIsfile and isfile(RS.Data.Config.ConfigName) then
        if RS.Environment.HasWritefile then
            delfile(RS.Data.Config.ConfigName)
        end
    end
    
    -- Reset all settings to defaults
    RS.Data.Spy.Settings = {
        MaxCalls = 1000,
        AutoClear = false,
        CaptureReturns = true,
        LogToConsole = true,
        ShowNotifications = true,
        FilterDuplicates = false
    }
    
    RS.Success("Config", "Configuration reset to defaults")
    
    return true
end

-- Auto-save system
spawn(function()
    while true do
        wait(RS.Data.Config.SaveInterval)
        
        if RS.Data.Config.AutoSave then
            RS.Config.Save()
        end
    end
end)

