local function addRemoteToList(remote, calls)
    calls = calls or 0
    local safeName = remote:GetFullName():gsub("[^%w]", "_")
    
    if RemoteList:FindFirstChild(safeName) then
        local existing = RemoteList:FindFirstChild(safeName)
        local callLabel = existing:FindFirstChild("CallCount")
        if callLabel then
            callLabel.Text = "📊 " .. calls .. " calls"
            callLabel.TextColor3 = Colors.Warning
        end
        return
    end
    
    local item = Instance.new("Frame")
    item.Name = safeName
    item.Parent = RemoteList
    item.BackgroundColor3 = Color3.fromRGB(32, 32, 45)
    item.Size = UDim2.new(0.98, 0, 0, 70)
    
    local itemCorner = Instance.new("UICorner")
    itemCorner.CornerRadius = UDim.new(0, 10)
    itemCorner.Parent = item
    
    -- Icon
    local icon = createLabel(item, remote:IsA("RemoteEvent") and "📡" or "📞", UDim2.new(0, 10, 0.5, -12), UDim2.new(0, 24, 0, 24), 20)
    icon.TextColor3 = Colors.Info
    
    -- Name
    local nameLabel = createLabel(item, remote.Name, UDim2.new(0, 40, 0, 8), UDim2.new(0.4, 0, 0, 20), 13)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextColor3 = Colors.TextPrimary
    
    -- Path
    local pathLabel = createLabel(item, remote:GetFullName(), UDim2.new(0, 40, 0, 28), UDim2.new(0.4, 0, 0, 15), 10)
    pathLabel.TextColor3 = Colors.TextTertiary
    
    -- Calls
    local callLabel = createLabel(item, "📊 " .. calls .. " calls", UDim2.new(0, 40, 0, 45), UDim2.new(0.3, 0, 0, 18), 11)
    callLabel.Name = "CallCount"
    callLabel.TextColor3 = Colors.Warning
    
    -- Buttons
    createButton(item, "FIRE", UDim2.new(0.55, 0, 0, 8), UDim2.new(0, 60, 0, 25), Colors.ButtonOrange, function()
        pcall(function()
            if remote:IsA("RemoteEvent") then
