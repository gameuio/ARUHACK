RS.Chat = {}

function RS.Chat.EnableLogger()
    if RS.Data.Chat.Logger.Enabled then
        RS.Warning("Chat", "Chat logger already enabled")
        return false
    end
    
    RS.Info("Chat", "Enabling chat logger...")
    
    -- Legacy chat support
    local success = pcall(function()
        for _, player in ipairs(RS.Services.Players:GetPlayers()) do
            player.Chatted:Connect(function(message)
                RS.Chat.LogMessage(player, message)
            end)
        end
        
        RS.Services.Players.PlayerAdded:Connect(function(player)
            player.Chatted:Connect(function(message)
                RS.Chat.LogMessage(player, message)
            end)
        end)
    end)
    
    -- TextChatService support (new chat)
    pcall(function()
        RS.Services.TextChatService.MessageReceived:Connect(function(textChatMessage)
            RS.Chat.LogMessage(
                textChatMessage.TextSource.UserId,
                textChatMessage.Text
            )
        end)
    end)
    
    if success then
        RS.Data.Chat.Logger.Enabled = true
        RS.Success("Chat", "Chat logger enabled")
        return true
    end
    
    return false
end

function RS.Chat.LogMessage(player, message)
    local messageData = {
        Player = type(player) == "number" and RS.Services.Players:GetPlayerByUserId(player) or player,
        PlayerName = type(player) == "number" and RS.Services.Players:GetPlayerByUserId(player).Name or player.Name,
        Message = message,
        Timestamp = tick(),
        TimeString = os.date("%H:%M:%S")
    }
    
    table.insert(RS.Data.Chat.Messages, 1, messageData)
    
    if #RS.Data.Chat.Messages > RS.Data.Chat.Settings.MaxMessages then
        table.remove(RS.Data.Chat.Messages)
    end
    
    RS.Debug("Chat", string.format("[%s] %s", messageData.PlayerName, message))
    
    -- Save to file if enabled
    if RS.Data.Chat.Logger.SaveToFile and RS.Environment.HasWritefile then
        RS.Utils.SafeCall(function()
            local logFile = "RemoteSpy_Chat.txt"
            local logLine = string.format("[%s] %s: %s\n",
                messageData.TimeString,
                messageData.PlayerName,
                message
            )
            
            if isfile(logFile) then
                local existing = readfile(logFile)
                writefile(logFile, existing .. logLine)
            else
                writefile(logFile, logLine)
            end
        end)
    end
    
    -- Update UI if available
    if RS.UI and RS.UI.Chat and RS.UI.Chat.AddMessage then
        RS.UI.Chat.AddMessage(messageData)
    end
end

function RS.Chat.StartSpammer()
    if RS.Data.Chat.Spammer.Active then
        RS.Warning("Chat", "Chat spammer already active")
        return false
    end
    
    if not RS.Data.Chat.Spammer.Message or RS.Data.Chat.Spammer.Message == "" then
        RS.Error("Chat", "No spam message set")
        return false
    end
    
    RS.Info("Chat", "Starting chat spammer...")
    
    RS.Data.Chat.Spammer.Active = true
    
    spawn(function()
        while RS.Data.Chat.Spammer.Active do
            local success = pcall(function()
                -- Try new TextChatService first
                local textChannel = RS.Services.TextChatService.TextChannels:FindFirstChild("RBXGeneral")
                
                if textChannel then
                    textChannel:SendAsync(RS.Data.Chat.Spammer.Message)
                else
                    -- Fallback to legacy chat
                    game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(
                        RS.Data.Chat.Spammer.Message,
                        "All"
                    )
                end
            end)
            
            if success then
                RS.Data.Chat.Spammer.Count = RS.Data.Chat.Spammer.Count + 1
                RS.Debug("Chat", "Spam message sent (#" .. RS.Data.Chat.Spammer.Count .. ")")
            else
                RS.Error("Chat", "Failed to send spam message")
            end
            
            wait(RS.Data.Chat.Spammer.Delay)
        end
    end)
    
    RS.Success("Chat", "Chat spammer started")
    
    return true
end

function RS.Chat.StopSpammer()
    if not RS.Data.Chat.Spammer.Active then
        return false
    end
    
    RS.Data.Chat.Spammer.Active = false
    RS.Success("Chat", string.format("Chat spammer stopped (%d messages sent)", RS.Data.Chat.Spammer.Count))
    
    return true
end

function RS.Chat.ClearMessages()
    local count = #RS.Data.Chat.Messages
    RS.Data.Chat.Messages = {}
    RS.Info("Chat", string.format("Cleared %d chat messages", count))
end

