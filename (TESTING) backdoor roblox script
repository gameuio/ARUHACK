function RS.Player.StartFly()
    if RS.Data.Player.Flying then
        RS.Warning("Player", "Already flying")
        return false
    end
    
    local character = LocalPlayer.Character
    if not character then
        RS.Error("Player", "Character not found")
        return false
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        RS.Error("Player", "HumanoidRootPart not found")
        return false
    end
    
    RS.Info("Player", "Starting fly mode...")
    
    -- Create BodyVelocity
    local bv = Instance.new("BodyVelocity")
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    bv.Parent = rootPart
    
    -- Create BodyGyro
    local bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    bg.P = 9e9
    bg.Parent = rootPart
    
    RS.Data.Player.Objects.FlyBodyVelocity = bv
    RS.Data.Player.Objects.FlyBodyGyro = bg
    
    -- Input handling
    RS.Data.Player.Connections.FlyInput = RS.Services.UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Space then
            bv.Velocity = Vector3.new(bv.Velocity.X, RS.Data.Player.Settings.FlySpeed, bv.Velocity.Z)
        elseif input.KeyCode == Enum.KeyCode.LeftShift then
            bv.Velocity = Vector3.new(bv.Velocity.X, -RS.Data.Player.Settings.FlySpeed, bv.Velocity.Z)
        end
    end)
    
    RS.Data.Player.Connections.FlyInputEnd = RS.Services.UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Space or input.KeyCode == Enum.KeyCode.LeftShift then
            bv.Velocity = Vector3.new(bv.Velocity.X, 0, bv.Velocity.Z)
        end
    end)
    
    -- Main fly loop
    RS.Data.Player.Connections.FlyLoop = RS.Services.RunService.RenderStepped:Connect(function()
        if not RS.Data.Player.Flying then return end
        
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then return end
        
        local moveDirection = humanoid.MoveDirection
        
        if moveDirection.Magnitude > 0 then
            local velocity = (Camera.CFrame.LookVector * moveDirection.Z + Camera.CFrame.RightVector * moveDirection.X) * RS.Data.Player.Settings.FlySpeed
            bv.Velocity = Vector3.new(velocity.X, bv.Velocity.Y, velocity.Z)
        else
            bv.Velocity = Vector3.new(0, bv.Velocity.Y, 0)
        end
        
        bg.CFrame = Camera.CFrame
        
        -- Update stats
        RS.Data.Player.Stats.TimeFlying = RS.Data.Player.Stats.TimeFlying + 1/60
    end)
    
    RS.Data.Player.Flying = true
    RS.Success("Player", "Fly mode enabled")
    
    return true
end

function RS.Player.StopFly()
    if not RS.Data.Player.Flying then
        return false
    end
    
    RS.Info("Player", "Stopping fly mode...")
    
    -- Remove objects
    if RS.Data.Player.Objects.FlyBodyVelocity then
        RS.Data.Player.Objects.FlyBodyVelocity:Destroy()
        RS.Data.Player.Objects.FlyBodyVelocity = nil
