-- Fly
function UI.Player.StartFly()
    if UI.Player.Flying then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    UI.Player.Flying = true
    
    -- Создаем BodyVelocity
    UI.Player.FlyBodyVelocity = Instance.new("BodyVelocity")
    UI.Player.FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    UI.Player.FlyBodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
    UI.Player.FlyBodyVelocity.Parent = rootPart
    
    -- Создаем BodyGyro
    UI.Player.FlyBodyGyro = Instance.new("BodyGyro")
    UI.Player.FlyBodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
    UI.Player.FlyBodyGyro.P = 9e9
    UI.Player.FlyBodyGyro.Parent = rootPart
    
    -- Подключаем управление
    UI.Player.Connections.FlyInput = UI.Services.UserInputService.InputBegan:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Space then
            UI.Player.FlyBodyVelocity.Velocity = Vector3.new(0, UI.Player.Settings.FlySpeed, 0)
        elseif input.KeyCode == Enum.KeyCode.LeftShift then
            UI.Player.FlyBodyVelocity.Velocity = Vector3.new(0, -UI.Player.Settings.FlySpeed, 0)
        end
    end)
    
    UI.Player.Connections.FlyInputEnd = UI.Services.UserInputService.InputEnded:Connect(function(input)
        if input.KeyCode == Enum.KeyCode.Space or input.KeyCode == Enum.KeyCode.LeftShift then
            UI.Player.FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    end)
    
    -- Основной цикл полета
    UI.Player.Connections.FlyLoop = UI.Services.RunService.RenderStepped:Connect(function()
        if not UI.Player.Flying then return end
        
        local camera = workspace.CurrentCamera
        local humanoid = character:FindFirstChild("Humanoid")
        if not humanoid then return end
        
        local moveDirection = humanoid.MoveDirection
        local cameraDirection = camera.CFrame.LookVector
        
        if moveDirection.Magnitude > 0 then
            local velocity = (cameraDirection * moveDirection.Z + camera.CFrame.RightVector * moveDirection.X) * UI.Player.Settings.FlySpeed
            UI.Player.FlyBodyVelocity.Velocity = Vector3.new(velocity.X, UI.Player.FlyBodyVelocity.Velocity.Y, velocity.Z)
        else
            UI.Player.FlyBodyVelocity.Velocity = Vector3.new(0, UI.Player.FlyBodyVelocity.Velocity.Y, 0)
        end
        
        UI.Player.FlyBodyGyro.CFrame = camera.CFrame
    end)
end

function UI.Player.StopFly()
    if not UI.Player.Flying then return end
    
    UI.Player.Flying = false
    
    -- Удаляем объекты
    if UI.Player.FlyBodyVelocity then
        UI.Player.FlyBodyVelocity:Destroy()
        UI.Player.FlyBodyVelocity = nil
    end
    
    if UI.Player.FlyBodyGyro then
        UI.Player.FlyBodyGyro:Destroy()
        UI.Player.FlyBodyGyro = nil
    end
    
    -- Отключаем connections
    if UI.Player.Connections.FlyInput then
        UI.Player.Connections.FlyInput:Disconnect()
    end
    if UI.Player.Connections.FlyInputEnd then
        UI.Player.Connections.FlyInputEnd:Disconnect()
    end
    if UI.Player.Connections.FlyLoop then
        UI.Player.Connections.FlyLoop:Disconnect()
    end
end

