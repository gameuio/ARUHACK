                TextColor3 = isActive and Color3.fromRGB(200, 150, 255) or Color3.fromRGB(150, 150, 180)
            }):Play()
            
            TweenService:Create(tabData.text, TweenInfo.new(0.3), {
                TextColor3 = isActive and Color3.white or Color3.fromRGB(150, 150, 180)
            }):Play()
            
            TweenService:Create(tabData.indicator, TweenInfo.new(0.3), {
                Size = isActive and UDim2.new(0, 4, 0, 30) or UDim2.new(0, 0, 0, 30)
            }):Play()
            
            pages[tabName].Visible = isActive
        end
        
        activeTab = name
    end)
    
    return page
end

