            local idLabel = createLabel(item, "ID: " .. player.UserId, UDim2.new(0, 80, 0, 32), UDim2.new(0.4, 0, 0, 16), 11)
            idLabel.TextColor3 = Color3.fromRGB(150, 150, 170)
            
            local pingLabel = createLabel(item, "Ping: " .. math.floor(player:GetNetworkPing() * 1000) .. "ms", UDim2.new(0, 80, 0, 50), UDim2.new(0.4, 0, 0, 16), 11)
