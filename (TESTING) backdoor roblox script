            return RS.Services.HttpService:JSONEncode(RS.Data.Spy.CapturedCalls)
        end)
        
        if success then
            if RS.Environment.HasSetClipboard then
                setclipboard(json)
                RS.Success("Spy", "Exported calls to clipboard (JSON)")
            end
            return json
        end
    elseif format == "lua" then
        local lines = {}
        table.insert(lines, "-- Captured Remote Calls")
        table.insert(lines, "-- Total: " .. #RS.Data.Spy.CapturedCalls)
        table.insert(lines, "")
        
        for i, call in ipairs(RS.Data.Spy.CapturedCalls) do
            table.insert(lines, string.format("-- Call #%d - %s", i, call.TimeString))
            table.insert(lines, RS.Utils.GenerateRemoteCode(call.Remote, call.Method, call.Arguments))
            table.insert(lines, "")
        end
        
        local code = table.concat(lines, "\n")
        
        if RS.Environment.HasSetClipboard then
            setclipboard(code)
            RS.Success("Spy", "Exported calls to clipboard (Lua)")
        end
        
        return code
    end
end

