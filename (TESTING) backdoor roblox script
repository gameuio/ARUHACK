-- Функция глубокого сканирования
local function deepScan()
    clearScanResults()
    updateStatus(ScanStatus, "🔍 Deep scanning...", Color3.fromRGB(100, 150, 255))
    
    local suspiciousKeywords = {
        "backdoor", "admin", "cmd", "execute", "require", 
        "load", "owner", "creator", "hub", "script",
        "remote", "event", "function", "server", "client",
        "fire", "invoke", "control", "manage", "system"
    }
    
    local count = 0
    
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local name = obj.Name:lower()
            local path = obj:GetFullName():lower()
            
            for _, keyword in pairs(suspiciousKeywords) do
                if name:find(keyword) or path:find(keyword) then
                    table.insert(foundRemotes, obj)
                    createScanResult(obj, #foundRemotes)
                    count = count + 1
                    break
                end
            end
        end
    end
    
    ScanResultsFrame.CanvasSize = UDim2.new(0, 0, 0, #foundRemotes * 50)
    
    if count > 0 then
        updateStatus(ScanStatus, "✅ Found " .. count .. " suspicious remotes!", Color3.fromRGB(100, 255, 100))
    else
        updateStatus(ScanStatus, "❌ No backdoors found", Color3.fromRGB(255, 100, 100))
    end
end

-- Быстрое сканирование
local function quickScan()
    clearScanResults()
    updateStatus(ScanStatus, "⚡ Quick scanning...", Color3.fromRGB(255, 200, 50))
    
    local count = 0
    
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") or obj:IsA("RemoteFunction") then
            local name = obj.Name:lower()
            
            if name:find("backdoor") or name:find("admin") or name:find("cmd") then
                table.insert(foundRemotes, obj)
                createScanResult(obj, #foundRemotes)
                count = count + 1
            end
        end
    end
    
    ScanResultsFrame.CanvasSize = UDim2.new(0, 0, 0, #foundRemotes * 50)
    updateStatus(ScanStatus, count > 0 and "✅ Found " .. count .. " remotes" or "❌ Nothing found", count > 0 and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100))
end

-- Тестирование remote
function testRemote(remote)
    updateStatus(ActionStatus, "Testing: " .. remote.Name, Color3.fromRGB(255, 200, 50))
    
    local testPayloads = {
        "test",
        {cmd = "test"},
        {action = "test"},
        {command = "test"},
        {"test"}
    }
    
    for _, payload in pairs(testPayloads) do
        commandsSent = commandsSent + 1
        pcall(function()
            if remote:IsA("RemoteEvent") then
                remote:FireServer(payload)
            elseif remote:IsA("RemoteFunction") then
                remote:InvokeServer(payload)
            end
        end)
        wait(tonumber(DelayBox.Text) or 0.5)
    end
    
    updateStatus(ActionStatus, "Test completed!", Color3.fromRGB(100, 255, 100))
end

-- Функция отправки команды всем remotes
local function sendCommandToAll(commands)
    local delay = tonumber(DelayBox.Text) or 0.5
    
    for _, remote in pairs(foundRemotes) do
        for _, payload in pairs(commands) do
            commandsSent = commandsSent + 1
            local success = pcall(function()
                if remote:IsA("RemoteEvent") then
                    remote:FireServer(payload)
                elseif remote:IsA("RemoteFunction") then
                    remote:InvokeServer(payload)
                end
            end)
            
            if success then
                successfulCommands = successfulCommands + 1
            end
            
            if verboseLogging then
                print(string.format("[%s] %s -> %s", success and "✓" or "✗", remote.Name, tostring(payload)))
            end
            
            wait(delay)
        end
    end
end

