RS.Logger = {
    Logs = {},
    MaxLogs = 1000,
    EnableConsoleOutput = true,
    EnableFileOutput = false,
    LogLevel = {
        DEBUG = 0,
        INFO = 1,
        SUCCESS = 2,
        WARNING = 3,
        ERROR = 4,
        CRITICAL = 5
    },
    CurrentLevel = 0
}

function RS.Logger:Log(level, category, message, data)
    if level < self.CurrentLevel then return end
    
    local timestamp = os.date("%H:%M:%S")
    local logEntry = {
        Timestamp = timestamp,
        UnixTime = os.time(),
        Level = level,
        LevelName = self:GetLevelName(level),
        Category = category,
        Message = message,
        Data = data or {},
        Caller = debug.info(3, "s") or "Unknown"
    }
    
    table.insert(self.Logs, 1, logEntry)
    
    if #self.Logs > self.MaxLogs then
        table.remove(self.Logs)
    end
    
    if self.EnableConsoleOutput then
        self:PrintToConsole(logEntry)
    end
    
    if self.EnableFileOutput and RS.Environment.HasWritefile then
        self:WriteToFile(logEntry)
    end
    
    if RS.UI and RS.UI.Console and RS.UI.Console.AddLog then
        RS.UI.Console.AddLog(logEntry)
    end
end

function RS.Logger:GetLevelName(level)
    for name, value in pairs(self.LogLevel) do
        if value == level then return name end
    end
    return "UNKNOWN"
end

function RS.Logger:PrintToConsole(entry)
    local colors = {
        [0] = "\27[35m", -- DEBUG (Magenta)
        [1] = "\27[36m", -- INFO (Cyan)
        [2] = "\27[32m", -- SUCCESS (Green)
        [3] = "\27[33m", -- WARNING (Yellow)
        [4] = "\27[31m", -- ERROR (Red)
        [5] = "\27[41m\27[37m" -- CRITICAL (Red BG + White Text)
    }
    
    local color = colors[entry.Level] or "\27[37m"
    local reset = "\27[0m"
    
    local output = string.format(
        "%s[%s] [%s] [%s] %s%s",
        color,
        entry.Timestamp,
        entry.LevelName,
        entry.Category,
        entry.Message,
        reset
    )
    
    print(output)
    
    if entry.Data and next(entry.Data) then
        local success, json = pcall(function()
            return RS.Services.HttpService:JSONEncode(entry.Data)
        end)
        
        if success then
            print("  Data:", json)
        end
    end
end

function RS.Logger:WriteToFile(entry)
    pcall(function()
        local logFile = "RemoteSpy_Logs.txt"
        local logLine = string.format(
            "[%s] [%s] [%s] %s\n",
            entry.Timestamp,
            entry.LevelName,
            entry.Category,
            entry.Message
        )
        
        if isfile(logFile) then
            local existing = readfile(logFile)
            writefile(logFile, existing .. logLine)
        else
            writefile(logFile, logLine)
        end
    end)
end

function RS.Logger:Clear()
    self.Logs = {}
end

function RS.Logger:GetLogs(level, category)
    local filtered = {}
    
    for _, log in ipairs(self.Logs) do
        local matchLevel = not level or log.Level == level
        local matchCategory = not category or log.Category == category
        
        if matchLevel and matchCategory then
            table.insert(filtered, log)
        end
    end
    
    return filtered
end

-- Shortcuts
function RS.Debug(category, msg, data) RS.Logger:Log(RS.Logger.LogLevel.DEBUG, category, msg, data) end
