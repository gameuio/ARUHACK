RS.Spy = {}

function RS.Spy.Start()
    if RS.Data.Spy.Active then
        RS.Warning("Spy", "Spy engine already active")
        return false
    end
    
    RS.Info("Spy", "Starting spy engine...")
    
    -- Environment check
    if not RS.Environment.HasGetRawMetatable then
        RS.Error("Spy", "getrawmetatable not supported - cannot start spy")
        return false
    end
    
    if not RS.Environment.HasGetNamecallMethod then
        RS.Error("Spy", "getnamecallmethod not supported - cannot start spy")
        return false
    end
    
    local success, error = RS.Utils.SafeCall(function()
        local mt = getrawmetatable(game)
        local oldIndex = mt.__index
        local oldNamecall = mt.__namecall
        
        -- Save originals
        RS.Data.Spy.Original.__index = oldIndex
        RS.Data.Spy.Original.__namecall = oldNamecall
        
        setreadonly(mt, false)
        
        -- Hook __namecall
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            local args = {...}
            
            -- Check if this is our call
            local isOurCall = false
            if RS.Environment.HasCheckcaller then
                isOurCall = checkcaller()
            end
            
            -- Capture remote calls
            if not isOurCall and not RS.Data.Spy.Paused then
                if (method == "FireServer" or method == "InvokeServer" or method == "Fire" or method == "Invoke") then
                    if self:IsA("RemoteEvent") or self:IsA("RemoteFunction") or self:IsA("BindableEvent") or self:IsA("BindableFunction") then
                        
                        local remotePath = RS.Utils.GetInstancePath(self)
                        
                        -- Check if blocked
                        if RS.Data.Spy.BlockedRemotes[remotePath] then
                            RS.Data.Spy.Stats.BlockedCalls = RS.Data.Spy.Stats.BlockedCalls + 1
                            RS.Debug("Spy", "Blocked call to " .. remotePath)
                            return
                        end
                        
                        -- Check if ignored
                        if not RS.Data.Spy.IgnoredRemotes[remotePath] then
                            -- Serialize arguments
                            local serializedArgs = RS.Utils.SerializeArgs(args)
                            
                            -- Calculate data size
                            local dataSize = 0
                            for _, arg in ipairs(serializedArgs) do
                                dataSize = dataSize + #tostring(arg.Value)
                            end
                            
                            -- Create call data
                            local callData = {
                                Remote = self,
                                RemoteName = self.Name,
                                RemotePath = remotePath,
                                RemoteClass = self.ClassName,
                                Method = method,
                                Arguments = serializedArgs,
                                ArgumentCount = #args,
                                DataSize = dataSize,
                                Timestamp = tick(),
                                TimeString = os.date("%H:%M:%S"),
                                Caller = debug.info(2, "s") or "Unknown"
                            }
                            
                            -- Save call
                            table.insert(RS.Data.Spy.CapturedCalls, 1, callData)
                            
                            -- Limit size
                            if #RS.Data.Spy.CapturedCalls > RS.Data.Spy.Settings.MaxCalls then
                                table.remove(RS.Data.Spy.CapturedCalls)
                            end
                            
                            -- Update stats
                            RS.Data.Spy.Stats.TotalCalls = RS.Data.Spy.Stats.TotalCalls + 1
                            RS.Data.Spy.Stats.TotalDataSent = RS.Data.Spy.Stats.TotalDataSent + dataSize
                            
                            if method == "FireServer" or method == "Fire" then
                                RS.Data.Spy.Stats.FireServerCalls = RS.Data.Spy.Stats.FireServerCalls + 1
                            else
                                RS.Data.Spy.Stats.InvokeServerCalls = RS.Data.Spy.Stats.InvokeServerCalls + 1
                            end
                            
                            -- Track unique remotes
                            if not RS.Data.Spy.UniqueRemotes[remotePath] then
                                RS.Data.Spy.UniqueRemotes[remotePath] = {
                                    Remote = self,
                                    FirstSeen = tick(),
                                    CallCount = 0,
                                    TotalDataSent = 0
                                }
                                RS.Data.Spy.Stats.UniqueRemotes = RS.Data.Spy.Stats.UniqueRemotes + 1
                            end
                            
                            RS.Data.Spy.UniqueRemotes[remotePath].CallCount = 
                                RS.Data.Spy.UniqueRemotes[remotePath].CallCount + 1
                            RS.Data.Spy.UniqueRemotes[remotePath].TotalDataSent = 
                                RS.Data.Spy.UniqueRemotes[remotePath].TotalDataSent + dataSize
                            
                            -- Log
                            if RS.Data.Spy.Settings.LogToConsole then
                                RS.Debug("Spy", string.format(
                                    "Captured: %s.%s() - %d args",
                                    callData.RemoteName,
                                    method,
                                    #args
                                ))
                            end
                            
                            -- Update UI
                            if RS.UI and RS.UI.Spy and RS.UI.Spy.UpdateList then
                                RS.UI.Spy.UpdateList(callData)
                            end
                            
                            -- Notification
                            if RS.Data.Spy.Settings.ShowNotifications then
                                -- Only show for first 10 calls to avoid spam
                                if RS.Data.Spy.Stats.TotalCalls <= 10 then
                                    RS.Utils.Notify({
                                        Title = "🔍 CAPTURED",
                                        Text = callData.RemoteName,
                                        Duration = 2
                                    })
                                end
                            end
                        end
                    end
                end
            end
            
            return oldNamecall(self, ...)
        end)
        
        setreadonly(mt, true)
    end)
    
    if success then
        RS.Data.Spy.Active = true
        RS.Data.Spy.Stats.StartTime = tick()
        RS.Success("Spy", "Spy engine started successfully")
        
        RS.Utils.Notify({
            Title = "✅ SPY STARTED",
            Text = "Remote calls are being captured",
            Duration = 3
        })
        
        return true
    else
        RS.Error("Spy", "Failed to start spy engine", {Error = error})
        
        RS.Utils.Notify({
            Title = "❌ SPY FAILED",
            Text = "Check console for details",
            Duration = 5
        })
        
        return false
    end
end

function RS.Spy.Stop()
    if not RS.Data.Spy.Active then
        RS.Warning("Spy", "Spy engine not active")
        return false
    end
    
    RS.Info("Spy", "Stopping spy engine...")
    
    local success = RS.Utils.SafeCall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        
        if RS.Data.Spy.Original.__namecall then
            mt.__namecall = RS.Data.Spy.Original.__namecall
        end
        
        if RS.Data.Spy.Original.__index then
            mt.__index = RS.Data.Spy.Original.__index
        end
        
        setreadonly(mt, true)
    end)
    
    if success then
        RS.Data.Spy.Active = false
        
        local runtime = tick() - RS.Data.Spy.Stats.StartTime
        
        RS.Success("Spy", string.format(
            "Spy stopped - Captured %d calls in %s",
            RS.Data.Spy.Stats.TotalCalls,
            RS.Utils.FormatDuration(math.floor(runtime))
        ))
        
        RS.Utils.Notify({
            Title = "⏸️ SPY STOPPED",
            Text = string.format("%d calls captured", RS.Data.Spy.Stats.TotalCalls),
            Duration = 3
        })
        
        return true
    end
    
    return false
end

