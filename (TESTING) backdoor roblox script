-- Tab Switching
local function switchTab(tab, page)
    -- Reset all tabs
    for _, t in pairs({ScanTab, ActionsTab, PlayersTab, SettingsTab}) do
        t.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
        t.TextColor3 = Color3.fromRGB(180, 180, 180)
    end
    
    -- Hide all pages
    for _, p in pairs({ScanPage, ActionsPage, PlayersPage, SettingsPage}) do
        p.Visible = false
    end
    
    -- Activate selected
    tab.BackgroundColor3 = Color3.fromRGB(50, 120, 200)
    tab.TextColor3 = Color3.fromRGB(255, 255, 255)
    page.Visible = true
end

ScanTab.MouseButton1Click:Connect(function() switchTab(ScanTab, ScanPage) end)
ActionsTab.MouseButton1Click:Connect(function() switchTab(ActionsTab, ActionsPage) end)
