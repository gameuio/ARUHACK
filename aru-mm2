local function EnableGunAimbot()
    if Connections.Aimbot then return end
    
    Connections.Aimbot = RunService.RenderStepped:Connect(function()
        if not Settings.GunAimbot then return end
        
        pcall(function()
            if GetRole(LocalPlayer) ~= "Sheriff" then return end
            
            local char = LocalPlayer.Character
            if not char then return end
            
            local gun = char:FindFirstChild("Gun") or char:FindFirstChild("Revolver")
            if not gun then return end
            
            local target = nil
            if Settings.AutoShoot then
                target = GetMurderer()
            else
                target = GetClosestPlayer(Settings.GunRange)
            end
            
            if not target or not target.Character then return end
            
            local targetPart = Settings.HeadshotOnly and target.Character:FindFirstChild("Head") or target.Character:FindFirstChild("HumanoidRootPart")
            if not targetPart then return end
            
            local cam = Workspace.CurrentCamera
            local targetPos = targetPart.Position
            
            -- Predict Movement
            if Settings.PredictMovement then
                local targetVel = targetPart.AssemblyLinearVelocity
                local distance = (targetPos - cam.CFrame.Position).Magnitude
                local timeToHit = distance / 300 -- Bullet speed estimation
                targetPos = targetPos + (targetVel * timeToHit)
            end
            
            -- Smooth Aiming
            local currentLook = cam.CFrame.LookVector
            local targetLook = (targetPos - cam.CFrame.Position).Unit
            local smoothLook = currentLook:Lerp(targetLook, Settings.AimbotSmoothing)
            
            cam.CFrame = CFrame.new(cam.CFrame.Position, cam.CFrame.Position + smoothLook)
            
            -- Silent Aim
            if Settings.SilentAim then
                -- Aim without camera movement
                local ray = Ray.new(gun.Handle.Position, (targetPos - gun.Handle.Position).Unit * Settings.GunRange)
                local hit, position = Workspace:FindPartOnRayWithIgnoreList(ray, {LocalPlayer.Character})
                if hit and hit:IsDescendantOf(target.Character) then
                    -- Fire
                end
            end
            
            -- Auto Shoot
            if Settings.AutoShoot then
                mouse1press()
                task.wait(0.05)
                mouse1release()
                
                GameStats.ShotsHit = GameStats.ShotsHit + 1
            end
            
            -- Trigger Bot
            if Settings.TriggerBot then
                local mouse = LocalPlayer:GetMouse()
                if mouse.Target and mouse.Target:IsDescendantOf(target.Character) then
                    mouse1click()
                end
            end
        end)
    end)
    
    SendWebhook("Gun Aimbot Enabled", "Aimbot system ON", 15158332)
end

local function DisableGunAimbot()
    if Connections.Aimbot then
        Connections.Aimbot:Disconnect()
        Connections.Aimbot = nil
    end
end

