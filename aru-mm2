local function CreateStatsDisplay()
    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "StatsDisplay"
    ScreenGui.ResetOnSpawn = false
    ScreenGui.DisplayOrder = 999997
    ScreenGui.IgnoreGuiInset = true
    
    pcall(function() ScreenGui.Parent = CoreGui end)
    if not ScreenGui.Parent then
        ScreenGui.Parent = LocalPlayer.PlayerGui
    end
    
    local Frame = Instance.new("Frame")
    Frame.Size = UDim2.new(0, 250, 0, 200)
    Frame.Position = UDim2.new(1, -260, 0, 10)
    Frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Frame.BackgroundTransparency = 0.3
    Frame.BorderSizePixel = 0
    Frame.Parent = ScreenGui
    
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 10)
    UICorner.Parent = Frame
    
    local Title = Instance.new("TextLabel")
    Title.Size = UDim2.new(1, 0, 0, 30)
    Title.BackgroundTransparency = 1
    Title.Text = "📊 Session Stats"
    Title.TextColor3 = Color3.fromRGB(255, 255, 255)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 16
    Title.Parent = Frame
    
    local StatsLabel = Instance.new("TextLabel")
    StatsLabel.Size = UDim2.new(1, -20, 1, -40)
    StatsLabel.Position = UDim2.new(0, 10, 0, 35)
    StatsLabel.BackgroundTransparency = 1
    StatsLabel.Text = ""
    StatsLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    StatsLabel.Font = Enum.Font.Code
    StatsLabel.TextSize = 12
    StatsLabel.TextXAlignment = Enum.TextXAlignment.Left
    StatsLabel.TextYAlignment = Enum.TextYAlignment.Top
    StatsLabel.Parent = Frame
    
    task.spawn(function()
        while ScreenGui.Parent do
            local sessionTime = os.time() - GameStats.SessionStart
            local hours = math.floor(sessionTime / 3600)
            local minutes = math.floor((sessionTime % 3600) / 60)
            local seconds = sessionTime % 60
            
            local statsText = string.format([[
⏱️ Session: %02d:%02d:%02d
🔪 Kills: %d
💰 Coins: %d
🎮 Games: %d
📍 Teleports: %d
🎯 Aim Accuracy: %.1f%%
📊 FPS: %d | Ping: %d ms
]], 
                hours, minutes, seconds,
                GameStats.Kills,
                GameStats.CoinsCollected,
                GameStats.GamesPlayed,
                GameStats.TPCount,
                GameStats.AimbotShots > 0 and (GameStats.AimbotHits / GameStats.AimbotShots * 100) or 0,
                GetFPS(),
                GetPing()
            )
            
            StatsLabel.Text = statsText
            task.wait(1)
        end
    end)
    
    return ScreenGui
end

