    -- ИСПРАВЛЕНИЕ: Функция переключения GUI
    local function ToggleGui()
        isGuiVisible = not isGuiVisible
        
        -- Ищем GUI по разным именам
        local mainGui = CoreGui:FindFirstChild("Kavo UI") or 
                       CoreGui:FindFirstChild("MM2GUI") or
                       CoreGui:FindFirstChild("Library")
        
        if mainGui then
            mainGui.Enabled = isGuiVisible
            
            -- Анимация кнопки
            if isGuiVisible then
                TweenService:Create(ToggleButton, TweenInfo.new(0.3), {
                    BackgroundColor3 = Color3.fromRGB(88, 101, 242)
                }):Play()
                
                TweenService:Create(StatusIndicator, TweenInfo.new(0.3), {
                    BackgroundColor3 = Color3.fromRGB(67, 181, 129)
                }):Play()
                
                TweenService:Create(Icon, TweenInfo.new(0.3), {
                    Rotation = 0
                }):Play()
                
                Label.Text = "MM2 Menu"
            else
                TweenService:Create(ToggleButton, TweenInfo.new(0.3), {
                    BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                }):Play()
                
                TweenService:Create(StatusIndicator, TweenInfo.new(0.3), {
                    BackgroundColor3 = Color3.fromRGB(237, 66, 69)
                }):Play()
                
                TweenService:Create(Icon, TweenInfo.new(0.3), {
                    Rotation = 180
                }):Play()
                
                Label.Text = "Menu Hidden"
            end
            
            -- Звук
            local sound = Instance.new("Sound")
            sound.SoundId = "rbxassetid://6895079853"
            sound.Volume = 0.3
            sound.Parent = ScreenGui
            sound:Play()
            game:GetService("Debris"):AddItem(sound, 2)
        end
    end
    
    -- ИСПРАВЛЕНИЕ: Обработчик клика
    ToggleButton.MouseButton1Click:Connect(function()
        if not isDragging then
            ToggleGui()
        end
    end)
    
    -- ИСПРАВЛЕНИЕ: Система перетаскивания
    local function updateInput(input)
        local delta = input.Position - dragStart
        local position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
        ToggleButton.Position = position
    end
    
    ToggleButton.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
            dragStart = input.Position
            startPos = ToggleButton.Position
            
            local moveConnection
            moveConnection = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    isDragging = false
                    if moveConnection then
                        moveConnection:Disconnect()
                    end
                end
            end)
        end
    end)
    
    ToggleButton.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and ToggleButton.InputBegan then
            local delta = input.Position - dragStart
            if delta.Magnitude > 5 then
                isDragging = true
                updateInput(input)
            end
        end
    end)
    
    -- Hover эффекты
    ToggleButton.MouseEnter:Connect(function()
        if not isDragging then
            TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
                Size = UDim2.new(0, 65, 0, 65)
            }):Play()
            
            TweenService:Create(Icon, TweenInfo.new(0.2), {
                Size = UDim2.new(0, 38, 0, 38),
                Position = UDim2.new(0.5, -19, 0.5, -19)
            }):Play()
            
            TweenService:Create(Label, TweenInfo.new(0.2), {
                TextTransparency = 0
            }):Play()
        end
    end)
    
    ToggleButton.MouseLeave:Connect(function()
        TweenService:Create(ToggleButton, TweenInfo.new(0.2), {
            Size = UDim2.new(0, 60, 0, 60)
        }):Play()
        
        TweenService:Create(Icon, TweenInfo.new(0.2), {
            Size = UDim2.new(0, 35, 0, 35),
            Position = UDim2.new(0.5, -17.5, 0.5, -17.5)
        }):Play()
        
        TweenService:Create(Label, TweenInfo.new(0.2), {
            TextTransparency = 0.3
        }):Play()
    end)
    
    -- Анимация появления
    ToggleButton.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(ToggleButton, TweenInfo.new(0.5, Enum.EasingStyle.Back), {
        Size = UDim2.new(0, 60, 0, 60)
    }):Play()
    
    StarterGui:SetCore("SendNotification", {
        Title = "MM2 Toggle Button",
        Text = "✅ Кнопка создана! Можно перетаскивать",
        Duration = 3
    })
    
    return ScreenGui
end

