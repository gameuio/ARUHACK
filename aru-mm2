local function SafeTeleport(position, teleportType)
    if not LocalPlayer.Character then return false end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    if typeof(position) ~= "Vector3" then return false end
    if position.Y < -500 or position.Y > 10000 then return false end
    if math.abs(position.X) > 100000 or math.abs(position.Z) > 100000 then return false end
    
    teleportType = teleportType or Settings.TeleportType
    local success = false
    
    pcall(function()
        if teleportType == "Instant" then
            hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
        elseif teleportType == "Smooth" then
            local distance = (hrp.Position - position).Magnitude
            local duration = math.min(distance / 100, 2)
            
            local tween = TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
            })
            tween:Play()
        else
            hrp.Anchored = true
            wait(0.05)
            hrp.CFrame = CFrame.new(position + Vector3.new(0, 5, 0))
            wait(0.05)
            hrp.Anchored = false
        end
        success = true
    end)
    
    return success
end

local function GetRole(player)
    if not player or not player.Character then return "Innocent" end
    
    local backpack = player.Backpack
    local character = player.Character
    
    for _, tool in pairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then return "Murderer" end
            if tool.Name == "Gun" or tool.Name == "Revolver" then return "Sheriff" end
        end
    end
    
    for _, tool in pairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then return "Murderer" end
            if tool.Name == "Gun" or tool.Name == "Revolver" then return "Sheriff" end
        end
    end
    
    return "Innocent"
end

local function GetMurderer()
    for _, player in pairs(Players:GetPlayers()) do
        if GetRole(player) == "Murderer" then
            return player
        end
    end
    return nil
end

