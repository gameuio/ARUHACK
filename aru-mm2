local function SetupCoinESP()
    local function CreateCoinESP(coin)
        if not coin:IsA("BasePart") then return end
        if coin:FindFirstChild("CoinESP") then return end
        
        local hl = Instance.new("BoxHandleAdornment")
        hl.Name = "CoinESP"
        hl.Size = coin.Size + Vector3.new(0.5, 0.5, 0.5)
        hl.Color3 = Color3.fromRGB(255, 255, 0)
        hl.Transparency = 0.5
        hl.AlwaysOnTop = true
        hl.ZIndex = 10
        hl.Adornee = coin
        hl.Parent = coin
    end
    
    local function UpdateCoinESP()
        for _, obj in pairs(Workspace:GetDescendants()) do
            if (obj.Name == "Coin" or obj.Name == "CoinContainer") and obj:IsA("BasePart") then
                if Settings.CoinESP then
                    CreateCoinESP(obj)
                else
                    if obj:FindFirstChild("CoinESP") then
                        obj.CoinESP:Destroy()
                    end
                end
            end
        end
    end
    
    Workspace.DescendantAdded:Connect(function(obj)
        if Settings.CoinESP and (obj.Name == "Coin" or obj.Name == "CoinContainer") then
            task.wait(0.1)
            CreateCoinESP(obj)
        end
    end)
    
    return UpdateCoinESP
end

