-- ============= СОБЫТИЯ И ОБРАБОТЧИКИ =============

LocalPlayer.CharacterAdded:Connect(function(character)
    wait(1)
    
    pcall(function()
        local humanoid = character:WaitForChild("Humanoid")
        humanoid.WalkSpeed = Settings.WalkSpeed
        humanoid.JumpPower = Settings.JumpPower
        
        if Settings.NoFall or Settings.AntiRagdoll then
            humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
        end
        
        if Settings.ESPEnabled then
            wait(0.5)
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    CreateAdvancedESP(player)
                end
            end
        end
        
        if Settings.Fly then
            DisableFly()
            wait(0.5)
            EnableFly()
        end
        
        if Settings.NoClip then
            DisableNoClip()
            wait(0.5)
            EnableNoClip()
        end
    end)
end)

-- Горячая клавиша для GUI
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.RightControl then
        local mainGui = CoreGui:FindFirstChild("Kavo UI")
        if mainGui then
            mainGui.Enabled = not mainGui.Enabled
            LogAction("GUI " .. (mainGui.Enabled and "Opened" or "Closed"), "User toggled GUI with hotkey")
        end
    end
end)

