local function EnableKillAura()
    if Connections.KillAura then return end
    
    Connections.KillAura = RunService.Heartbeat:Connect(function()
        if not Settings.KillAura then return end
        
        pcall(function()
            if GetRole(LocalPlayer) ~= "Murderer" then return end
            
            local char = LocalPlayer.Character
            if not char or not char:FindFirstChild("HumanoidRootPart") then return end
            
            local knife = char:FindFirstChildOfClass("Tool") or LocalPlayer.Backpack:FindFirstChild("Knife")
            if not knife or knife.Name ~= "Knife" then return end
            
            if knife.Parent == LocalPlayer.Backpack then
                char.Humanoid:EquipTool(knife)
                task.wait(0.1)
            end
            
            local hrp = char.HumanoidRootPart
            local oldCFrame = hrp.CFrame
            
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer and player.Character then
                    local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
                    local targetHum = player.Character:FindFirstChild("Humanoid")
                    
                    if targetHRP and targetHum and targetHum.Health > 0 then
                        local dist = (targetHRP.Position - hrp.Position).Magnitude
                        if dist <= Settings.KillAuraRange then
                            if Settings.SilentKill then
                                -- Silent Kill (без телепорта)
                                local knifeHandle = knife:FindFirstChild("Handle")
                                if knifeHandle then
                                    firetouchinterest(knifeHandle, targetHRP, 0)
                                    task.wait()
                                    firetouchinterest(knifeHandle, targetHRP, 1)
                                end
                            else
                                -- Normal Kill (с телепортом)
                                hrp.CFrame = targetHRP.CFrame
                                knife:Activate()
                                task.wait(0.05)
                                hrp.CFrame = oldCFrame
                            end
                            
                            if Settings.InstantKill then
                                targetHum.Health = 0
                            end
                            
                            GameStats.Kills = GameStats.Kills + 1
                            task.wait(0.1)
                        end
                    end
                end
            end
        end)
        task.wait(0.05)
    end)
    
    SendWebhook("Kill Aura Enabled", "Auto attack system ON", 15158332)
end

