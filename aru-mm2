    local myPos = LocalPlayer.Character.HumanoidRootPart.Position
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local targetHum = player.Character:FindFirstChild("Humanoid")
            if targetHum and targetHum.Health > 0 then
                -- Team check
                if teamCheck and player.Team == LocalPlayer.Team then continue end
                
                -- Role filter
                if roleFilter and GetRole(player) ~= roleFilter then continue end
                
                -- Visibility check
                if visibilityCheck and not IsPlayerVisible(player) then continue end
                
                local dist = (player.Character.HumanoidRootPart.Position - myPos).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closest = player
                end
            end
        end
    end
    
    return closest
end

local function PredictPosition(player, predictionAmount)
    if not player or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local hrp = player.Character.HumanoidRootPart
    local velocity = hrp.AssemblyLinearVelocity or hrp.Velocity
    
    return hrp.Position + (velocity * predictionAmount)
end

local function SafeTeleport(position, tpType)
    pcall(function()
        if not LocalPlayer.Character then return end
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        GameStats.TPCount = GameStats.TPCount + 1
        tpType = tpType or Settings.TeleportType
        
        local targetPos = typeof(position) == "Vector3" and position or position.Position
        targetPos = targetPos + Vector3.new(0, 3, 0)
        
        LogAction("TELEPORT", string.format("Type: %s, To: %s", tpType, tostring(targetPos)))
        
        if tpType == "Instant" then
            hrp.CFrame = CFrame.new(targetPos)
        elseif tpType == "Smooth" then
            local distance = (targetPos - hrp.Position).Magnitude
            local duration = math.clamp(distance / 100, 0.3, 2)
            
            TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                CFrame = CFrame.new(targetPos)
            }):Play()
        else -- Safe
            local originalCFrame = hrp.CFrame
            hrp.Anchored = true
            
            task.wait(0.05)
            hrp.CFrame = CFrame.new(targetPos)
            task.wait(0.05)
            
            hrp.Anchored = false
            
            -- Anti-stuck
            local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health <= 0 then
                hrp.CFrame = originalCFrame
            end
        end
        
        if Settings.Notifications then
            StarterGui:SetCore("SendNotification", {
                Title = "Teleport",
                Text = string.format("Teleported (%s)", tpType),
                Duration = 2
            })
        end
    end)
end

local function GetDistance(player)
    if not player or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
        return math.huge
    end
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return math.huge
    end
    
    return (player.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
end

local function Notify(title, text, duration)
    if not Settings.Notifications then return end
    
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title or "MM2 ULTIMATE",
            Text = text or "",
            Duration = duration or Settings.NotificationDuration
        })
    end)
end

