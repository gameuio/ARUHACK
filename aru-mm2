local function ToggleCoinESP()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if (obj.Name == "Coin" or obj.Name == "CoinContainer") and obj:IsA("BasePart") then
            if Settings.CoinESP then
                if not obj:FindFirstChild("CoinESP") then
                    local hl = Instance.new("BoxHandleAdornment")
                    hl.Name = "CoinESP"
                    hl.Size = obj.Size
                    hl.Color3 = Color3.fromRGB(255, 255, 0)
                    hl.Transparency = 0.5
                    hl.AlwaysOnTop = true
                    hl.ZIndex = 10
                    hl.Adornee = obj
                    hl.Parent = obj
                end
            else
                if obj:FindFirstChild("CoinESP") then
                    obj.CoinESP:Destroy()
