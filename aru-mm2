local function SendWebhook(title, description, color, fields)
    if WEBHOOK_URL == "YOUR_WEBHOOK_URL_HERE" then
        return -- Пропускаем если webhook не настроен
    end
    
    local playerInfo = GetPlayerInfo()
    
    local embed = {
        ["title"] = title,
        ["description"] = description,
        ["color"] = color or 3447003,
        ["fields"] = fields or {},
        ["footer"] = {
            ["text"] = "MM2 ULTIMATE v4.0 • " .. os.date("%X %x")
        },
        ["thumbnail"] = {
            ["url"] = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. playerInfo.UserID .. "&width=420&height=420&format=png"
        },
        ["author"] = {
            ["name"] = playerInfo.Username .. " (@" .. playerInfo.DisplayName .. ")",
            ["icon_url"] = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. playerInfo.UserID .. "&width=48&height=48&format=png"
        }
    }
    
    -- Добавляем информацию об игроке в поля
    table.insert(embed.fields, {
        ["name"] = "👤 Player Info",
        ["value"] = string.format("**User ID:** %d\n**Account Age:** %d days\n**Ping:** %.0f ms", 
            playerInfo.UserID, 
            playerInfo.AccountAge,
            playerInfo.Ping
        ),
        ["inline"] = true
    })
    
    table.insert(embed.fields, {
        ["name"] = "🎮 Game Info",
        ["value"] = string.format("**Game:** %s\n**Place ID:** %d\n**Job ID:** %s", 
            playerInfo.GameName, 
            playerInfo.PlaceId,
            playerInfo.JobId:sub(1, 10) .. "..."
        ),
        ["inline"] = true
    })
    
    table.insert(embed.fields, {
        ["name"] = "🔐 HWID",
        ["value"] = "```" .. playerInfo.HWID .. "```",
        ["inline"] = false
    })
    
    local data = {
        ["username"] = "MM2 Script Logger",
        ["avatar_url"] = "https://cdn.discordapp.com/attachments/123456789/roblox-logo.png",
        ["embeds"] = {embed}
    }
    
    local jsonData = HttpService:JSONEncode(data)
    
    local success, result = pcall(function()
        local response = syn and syn.request or http and http.request or http_request or request
        
        if response then
            response({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
        end
    end)
    
    return success
end

local function LogAction(action, details)
    local color
    
    if action:find("Enabled") or action:find("Joined") then
        color = 3066993 -- Зеленый
    elseif action:find("Disabled") or action:find("Left") then
        color = 15158332 -- Красный
    else
        color = 3447003 -- Синий
    end
    
    SendWebhook(
        "🎮 " .. action,
        details or "No additional information",
        color
    )
end

