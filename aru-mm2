local function GetHWID()
    return game:GetService("RbxAnalyticsService"):GetClientId()
end

local function GetPlayerInfo()
    return {
        Username = LocalPlayer.Name,
        DisplayName = LocalPlayer.DisplayName,
        UserID = LocalPlayer.UserId,
        AccountAge = LocalPlayer.AccountAge,
        HWID = GetHWID(),
        GameName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name,
        PlaceId = game.PlaceId,
        JobId = game.JobId,
        Ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
    }
end

local function SendWebhook(title, description, color, fields)
    if WEBHOOK_URL == "YOUR_WEBHOOK_URL_HERE" then return end
    
    pcall(function()
        local playerInfo = GetPlayerInfo()
        
        local embed = {
            ["title"] = title,
            ["description"] = description,
            ["color"] = color or 3447003,
            ["fields"] = fields or {},
            ["footer"] = {
                ["text"] = "MM2 ULTIMATE v5.0 • " .. os.date("%X %x")
            },
            ["thumbnail"] = {
                ["url"] = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. playerInfo.UserID .. "&width=420&height=420&format=png"
            },
            ["author"] = {
                ["name"] = playerInfo.Username .. " (@" .. playerInfo.DisplayName .. ")",
                ["icon_url"] = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. playerInfo.UserID .. "&width=48&height=48&format=png"
            }
        }
        
        table.insert(embed.fields, {
            ["name"] = "👤 Player Info",
            ["value"] = string.format("**User ID:** %d\n**Account Age:** %d days\n**Ping:** %.0f ms", 
                playerInfo.UserID, 
                playerInfo.AccountAge,
                playerInfo.Ping
            ),
            ["inline"] = true
        })
        
        table.insert(embed.fields, {
            ["name"] = "🎮 Game Info",
            ["value"] = string.format("**Game:** %s\n**Place ID:** %d", 
                playerInfo.GameName, 
                playerInfo.PlaceId
            ),
            ["inline"] = true
        })
        
        local data = {
            ["username"] = "MM2 Script Logger",
            ["embeds"] = {embed}
        }
        
        local jsonData = HttpService:JSONEncode(data)
        
        local response = syn and syn.request or http and http.request or http_request or request
        
        if response then
            response({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json"
                },
                Body = jsonData
            })
        end
    end)
end

local function LogAction(action, details)
    local color = 3447003
    
    if action:find("Enabled") or action:find("Joined") then
        color = 3066993
    elseif action:find("Disabled") or action:find("Left") then
        color = 15158332
    end
    
    SendWebhook("🎮 " .. action, details or "No additional information", color)
end

