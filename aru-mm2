local function GetRole(player)
    if not player or not player.Character then return "Innocent" end
    
    -- Проверяем кэш
    if Cache.Players[player] and Cache.Players[player].Role and 
       os.time() - Cache.Players[player].LastCheck < 0.5 then
        return Cache.Players[player].Role
    end
    
    local role = "Innocent"
    
    -- Проверка в Backpack
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then 
                role = "Murderer"
                break
            elseif tool.Name == "Gun" or tool.Name == "Revolver" then 
                role = "Sheriff"
                break
            end
        end
    end
    
    -- Проверка в Character
    if role == "Innocent" then
        for _, tool in pairs(player.Character:GetChildren()) do
            if tool:IsA("Tool") then
                if tool.Name == "Knife" then 
                    role = "Murderer"
                    break
                elseif tool.Name == "Gun" or tool.Name == "Revolver" then 
                    role = "Sheriff"
                    break
                end
            end
        end
    end
    
    -- Обновляем кэш
    Cache.Players[player] = {
        Role = role,
        LastCheck = os.time()
    }
    
    return role
end

local function GetMurderer()
    for _, player in pairs(Players:GetPlayers()) do
