                box.Name = "Box"
                box.Size = char:GetExtentsSize()
                box.Color3 = Color3.new(0, 1, 0)
                box.Transparency = 0.7
                box.AlwaysOnTop = true
                box.ZIndex = 5
                box.Adornee = hrp
                box.Parent = billboard
            end
            
            -- Tracer ESP
            if Settings.TracerESP then
                local tracer = Drawing.new("Line")
                tracer.Visible = true
                tracer.Color = Color3.new(1, 1, 1)
                tracer.Thickness = 2
                tracer.Transparency = 0.7
                billboard:SetAttribute("Tracer", tracer)
            end
            
            -- Skeleton ESP
            if Settings.SkeletonESP then
                local function CreateLine(from, to)
                    if not from or not to then return end
                    local att0 = Instance.new("Attachment", from)
                    local att1 = Instance.new("Attachment", to)
                    local beam = Instance.new("Beam")
                    beam.Attachment0 = att0
                    beam.Attachment1 = att1
                    beam.Color = ColorSequence.new(Color3.new(1, 1, 1))
                    beam.Width0 = 0.1
                    beam.Width1 = 0.1
                    beam.FaceCamera = true
                    beam.Parent = from
                    return beam
                end
                
                local head = char:FindFirstChild("Head")
                local torso = char:FindFirstChild("Torso") or char:FindFirstChild("UpperTorso")
                local leftArm = char:FindFirstChild("Left Arm") or char:FindFirstChild("LeftUpperArm")
                local rightArm = char:FindFirstChild("Right Arm") or char:FindFirstChild("RightUpperArm")
                local leftLeg = char:FindFirstChild("Left Leg") or char:FindFirstChild("LeftUpperLeg")
                local rightLeg = char:FindFirstChild("Right Leg") or char:FindFirstChild("RightUpperLeg")
                
                if head and torso then CreateLine(head, torso) end
                if torso and leftArm then CreateLine(torso, leftArm) end
                if torso and rightArm then CreateLine(torso, rightArm) end
                if torso and leftLeg then CreateLine(torso, leftLeg) end
                if torso and rightLeg then CreateLine(torso, rightLeg) end
            end
            
            -- Chams ESP
            if Settings.ChamsESP then
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.Name ~= "HumanoidRootPart" then
                        local cham = Instance.new("BoxHandleAdornment")
                        cham.Size = part.Size
                        cham.Color3 = Color3.new(1, 0, 1)
                        cham.Transparency = 0.5
                        cham.AlwaysOnTop = true
                        cham.ZIndex = 3
                        cham.Adornee = part
                        cham.Parent = billboard
                    end
                end
            end
            
            self.Objects[player] = billboard
            
            -- Update Loop
            task.spawn(function()
                while billboard.Parent and Settings.ESPEnabled do
                    pcall(function()
                        if not char or not char.Parent or not hrp.Parent then
                            self:Remove(player)
                            return
                        end
                        
                        local role = GetRole(player)
                        local health = char:FindFirstChild("Humanoid") and math.floor(char.Humanoid.Health) or 0
                        local distance = GetDistance(player)
                        
                        -- Update visibility based on distance
                        billboard.Enabled = distance <= Settings.ESPMaxDistance
                        
                        if not billboard.Enabled then
                            task.wait(1)
                            return
                        end
                        
                        -- Update text
                        nameLabel.Text = Settings.NameESP and player.Name or ""
                        roleLabel.Text = Settings.RoleESP and ("[" .. role .. "]") or ""
                        
                        local distText = Settings.DistanceESP and (math.floor(distance) .. "m") or ""
                        local healthText = Settings.HealthESP and (health .. " HP") or ""
                        
                        if distText ~= "" and healthText ~= "" then
                            infoLabel.Text = distText .. "\n" .. healthText
                        else
                            infoLabel.Text = distText .. healthText
                        end
                        
                        -- Update colors based on role
                        local color = Settings.ESPColor.Innocent
                        if role == "Murderer" then
                            color = Settings.ESPColor.Murderer
                        elseif role == "Sheriff" then
                            color = Settings.ESPColor.Sheriff
                        end
                        
                        frame.BackgroundColor3 = color
                        frame.BorderColor3 = color
                        
                        if Settings.BoxESP then
                            local box = billboard:FindFirstChild("Box")
                            if box then
                                box.Color3 = color
                                box.Size = char:GetExtentsSize()
                            end
                        end
                        
                        -- Update tracer
                        if Settings.TracerESP and billboard:GetAttribute("Tracer") then
                            local tracer = billboard:GetAttribute("Tracer")
                            if tracer then
                                local cam = Workspace.CurrentCamera
                                local screenPos, onScreen = cam:WorldToViewportPoint(hrp.Position)
                                
                                if onScreen then
                                    tracer.From = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y)
                                    tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                                    tracer.Color = color
                                    tracer.Visible = true
                                else
                                    tracer.Visible = false
                                end
                            end
                        end
                    end)
                    
                    task.wait(Settings.ESPRefreshRate)
                end
            end)
        end)
    end)
end

function ESPSystem:Remove(player)
    pcall(function()
        if self.Objects[player] then
            -- Remove tracer
            local billboard = self.Objects[player]
            if billboard:GetAttribute("Tracer") then
                local tracer = billboard:GetAttribute("Tracer")
                if tracer then
                    tracer:Remove()
                end
            end
            
            billboard:Destroy()
            self.Objects[player] = nil
        end
    end)
end

function ESPSystem:RemoveAll()
    for player, _ in pairs(self.Objects) do
        self:Remove(player)
    end
    self.Objects = {}
end

function ESPSystem:Update()
    if not Settings.ESPEnabled then
        self:RemoveAll()
        return
    end
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            if player.Character and not self.Objects[player] then
                self:Create(player)
            end
        end
    end
end

-- ============= ADVANCED KILL AURA =============

local KillAuraSystem = {
    Enabled = false,
    Targets = {},
    LastAttack = 0,
    Kills = 0
}

function KillAuraSystem:GetBestTarget()
    local targets = {}
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local hrp = player.Character:FindFirstChild("HumanoidRootPart")
            local hum = player.Character:FindFirstChild("Humanoid")
            
            if hrp and hum and hum.Health > 0 then
                local distance = GetDistance(player)
                
                if distance <= Settings.KillAuraRange then
                    -- Team check
                    if Settings.KillAuraTeamCheck and player.Team == LocalPlayer.Team then
                        continue
                    end
                    
                    -- Whitelist check
                    if table.find(Settings.KillAuraWhitelist, player.Name) then
                        continue
                    end
                    
                    table.insert(targets, {
                        Player = player,
                        Distance = distance,
                        Role = GetRole(player)
                    })
                end
            end
        end
    end
    
    if #targets == 0 then return nil end
    
    -- Sort by priority
    if Settings.KillAuraPriority == "Closest" then
        table.sort(targets, function(a, b)
            return a.Distance < b.Distance
        end)
    elseif Settings.KillAuraPriority == "Sheriff" then
        table.sort(targets, function(a, b)
            if a.Role == "Sheriff" and b.Role ~= "Sheriff" then
                return true
            elseif a.Role ~= "Sheriff" and b.Role == "Sheriff" then
                return false
            else
                return a.Distance < b.Distance
            end
        end)
    else -- Random
        local randomIndex = math.random(1, #targets)
        return targets[randomIndex].Player
    end
    
    return targets[1].Player
end

function KillAuraSystem:Attack(target)
    pcall(function()
        if not target or not target.Character then return end
        
        local char = LocalPlayer.Character
        if not char then return end
        
        local knife = char:FindFirstChildOfClass("Tool")
        if not knife or knife.Name ~= "Knife" then
            knife = LocalPlayer.Backpack:FindFirstChild("Knife")
            if knife then
                char.Humanoid:EquipTool(knife)
                task.wait(0.1)
            else
                return
            end
        end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
        
        if not hrp or not targetHRP then return end
        
        if Settings.SilentKill then
            local knifeHandle = knife:FindFirstChild("Handle")
            if knifeHandle then
                firetouchinterest(knifeHandle, targetHRP, 0)
                task.wait()
                firetouchinterest(knifeHandle, targetHRP, 1)
            end
        else
            local originalCFrame = hrp.CFrame
            hrp.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 2)
            
            knife:Activate()
            task.wait(0.05)
            
            hrp.CFrame = originalCFrame
        end
        
        if Settings.InstantKill then
            local targetHum = target.Character:FindFirstChild("Humanoid")
            if targetHum then
                targetHum.Health = 0
            end
        end
        
        self.Kills = self.Kills + 1
        GameStats.Kills = GameStats.Kills + 1
        GameStats.KillAuraKills = GameStats.KillAuraKills + 1
        
        LogAction("KILL_AURA", string.format("Killed %s", target.Name))
        
        if Settings.Notifications then
            Notify("Kill Aura", string.format("Killed %s (%d total)", target.Name, self.Kills), 2)
        end
    end)
end

function KillAuraSystem:Enable()
    if Connections.KillAura then return end
    
    self.Enabled = true
    
    Connections.KillAura = RunService.Heartbeat:Connect(function()
        if not Settings.KillAura then return end
        if GetRole(LocalPlayer) ~= "Murderer" then return end
        
        local now = tick()
        if now - self.LastAttack < Settings.KillAuraDelay then return end
        
        local target = self:GetBestTarget()
        if target then
            self:Attack(target)
            self.LastAttack = now
        end
    end)
    
    LogAction("KILL_AURA", "Enabled")
end

function KillAuraSystem:Disable()
    if Connections.KillAura then
        Connections.KillAura:Disconnect()
        Connections.KillAura = nil
    end
    
    self.Enabled = false
    LogAction("KILL_AURA", "Disabled")
end

-- ============= ADVANCED AIMBOT =============

local AimbotSystem = {
    Enabled = false,
    CurrentTarget = nil,
    FOVCircle = nil,
    Hits = 0,
    Shots = 0
}

function AimbotSystem:CreateFOVCircle()
    if self.FOVCircle then
        self.FOVCircle:Remove()
    end
    
    if not Drawing then return end
    
    self.FOVCircle = Drawing.new("Circle")
    self.FOVCircle.Visible = Settings.AimbotFOVCircle
    self.FOVCircle.Thickness = 2
    self.FOVCircle.NumSides = 64
    self.FOVCircle.Radius = Settings.AimbotFOV
    self.FOVCircle.Color = Color3.fromRGB(255, 255, 255)
    self.FOVCircle.Transparency = 0.7
    self.FOVCircle.Filled = false
end

function AimbotSystem:UpdateFOVCircle()
    if not self.FOVCircle then return end
    
    local cam = Workspace.CurrentCamera
    self.FOVCircle.Position = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    self.FOVCircle.Radius = Settings.AimbotFOV
    self.FOVCircle.Visible = Settings.AimbotFOVCircle and Settings.GunAimbot
end

function AimbotSystem:GetBestTarget()
    local cam = Workspace.CurrentCamera
    local centerScreen = Vector2.new(cam.ViewportSize.X / 2, cam.ViewportSize.Y / 2)
    
    local bestTarget = nil
    local shortestDistance = Settings.AimbotFOV
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character then
            local char = player.Character
            local targetPart = char:FindFirstChild(Settings.AimbotBone)
            local hum = char:FindFirstChild("Humanoid")
            
            if targetPart and hum and hum.Health > 0 then
                -- Visibility check
                if Settings.AimbotVisibilityCheck and not IsPlayerVisible(player) then
                    continue
                end
                
                local screenPos, onScreen = cam:WorldToViewportPoint(targetPart.Position)
                
                if onScreen then
                    local distanceFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
                    
                    if distanceFromCenter < shortestDistance then
                        shortestDistance = distanceFromCenter
                        bestTarget = player
                    end
                end
            end
        end
    end
    
    return bestTarget
end

function AimbotSystem:AimAt(target)
    pcall(function()
        if not target or not target.Character then return end
        
        local char = target.Character
        local targetPart = char:FindFirstChild(Settings.AimbotBone)
        
        if not targetPart then return end
        
        local cam = Workspace.CurrentCamera
        local targetPos = targetPart.Position
        
        -- Prediction
        if Settings.AimbotPrediction then
            local predictedPos = PredictPosition(target, Settings.AimbotPredictionAmount)
            if predictedPos then
                targetPos = predictedPos
            end
        end
        
        if Settings.SilentAim then
            -- Silent aim (no camera movement)
            local args = {
                [1] = targetPos
            }
            
            -- Try to find and call the shoot remote
            for _, v in pairs(ReplicatedStorage:GetDescendants()) do
                if v:IsA("RemoteEvent") and (v.Name:lower():find("shoot") or v.Name:lower():find("fire")) then
                    v:FireServer(unpack(args))
                end
            end
        else
            -- Visual aimbot (smooth camera movement)
            local currentLook = cam.CFrame.LookVector
            local targetLook = (targetPos - cam.CFrame.Position).Unit
            local smoothLook = currentLook:Lerp(targetLook, Settings.AimbotSmoothing)
            
            cam.CFrame = CFrame.new(cam.CFrame.Position, cam.CFrame.Position + smoothLook)
        end
        
        -- Auto shoot
        if Settings.AutoShoot then
            self.Shots = self.Shots + 1
            GameStats.AimbotShots = GameStats.AimbotShots + 1
            
            mouse1press()
            task.wait(0.05)
            mouse1release()
            
            -- Check for hit (simplified)
            task.spawn(function()
                task.wait(0.2)
                local hum = char:FindFirstChild("Humanoid")
                if hum and hum.Health <= 0 then
                    self.Hits = self.Hits + 1
                    GameStats.AimbotHits = GameStats.AimbotHits + 1
                end
            end)
        end
    end)
end

function AimbotSystem:Enable()
    if Connections.Aimbot then return end
    
    self.Enabled = true
    self:CreateFOVCircle()
    
    Connections.Aimbot = RunService.RenderStepped:Connect(function()
        if not Settings.GunAimbot then return end
        if GetRole(LocalPlayer) ~= "Sheriff" then return end
        
        self:UpdateFOVCircle()
        
        local target = Settings.AutoShoot and GetMurderer() or self:GetBestTarget()
        
        if target then
            self.CurrentTarget = target
            self:AimAt(target)
        else
            self.CurrentTarget = nil
        end
    end)
    
    LogAction("AIMBOT", "Enabled")
end

function AimbotSystem:Disable()
    if Connections.Aimbot then
        Connections.Aimbot:Disconnect()
        Connections.Aimbot = nil
    end
    
    if self.FOVCircle then
        self.FOVCircle:Remove()
        self.FOVCircle = nil
    end
    
    self.Enabled = false
    self.CurrentTarget = nil
    
    LogAction("AIMBOT", "Disabled")
end

-- ============= COIN FARM SYSTEM =============

local CoinFarmSystem = {
    Enabled = false,
    CoinsCollected = 0,
    Path = nil,
    CurrentCoin = nil
}

function CoinFarmSystem:GetAllCoins()
    local coins = {}
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj.Name == "Coin" or obj.Name == "CoinContainer" then
            if obj:IsA("BasePart") or (obj:IsA("Model") and obj:FindFirstChild("Coin")) then
                local coinPart = obj:IsA("BasePart") and obj or obj:FindFirstChild("Coin")
                if coinPart then
                    table.insert(coins, coinPart)
                end
            end
        end
    end
    
    return coins
end

function CoinFarmSystem:GetNearestCoin()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return nil
    end
    
    local myPos = LocalPlayer.Character.HumanoidRootPart.Position
    local nearestCoin = nil
    local shortestDist = math.huge
    
    for _, coin in pairs(self:GetAllCoins()) do
        local dist = (coin.Position - myPos).Magnitude
        if dist < shortestDist then
            shortestDist = dist
            nearestCoin = coin
        end
    end
    
    return nearestCoin
end

function CoinFarmSystem:CollectCoin(coin)
    pcall(function()
        if not coin or not coin.Parent then return end
        if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
        
        local hrp = LocalPlayer.Character.HumanoidRootPart
        
        if Settings.FarmMode == "Teleport" then
            SafeTeleport(coin.Position, "Instant")
            task.wait(0.1)
        elseif Settings.FarmMode == "Path" then
            local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid then
                humanoid:MoveTo(coin.Position)
                humanoid.MoveToFinished:Wait()
            end
        else -- Nearest (touch)
            local dist = (coin.Position - hrp.Position).Magnitude
            if dist <= Settings.FarmDistance then
                firetouchinterest(hrp, coin, 0)
                task.wait()
                firetouchinterest(hrp, coin, 1)
                
                self.CoinsCollected = self.CoinsCollected + 1
                GameStats.CoinsCollected = GameStats.CoinsCollected + 1
                
                LogAction("COIN_FARM", string.format("Collected coin #%d", self.CoinsCollected))
            end
        end
        
        task.wait(Settings.FarmDelay)
    end)
end

function CoinFarmSystem:Enable()
    if Connections.CoinFarm then return end
    
    self.Enabled = true
    
    Connections.CoinFarm = RunService.Heartbeat:Connect(function()
        if not Settings.AutoFarmCoins then return end
        
        pcall(function()
            local coin = self:GetNearestCoin()
            if coin then
                self.CurrentCoin = coin
                self:CollectCoin(coin)
            end
        end)
    end)
    
    LogAction("COIN_FARM", "Enabled")
end

function CoinFarmSystem:Disable()
    if Connections.CoinFarm then
        Connections.CoinFarm:Disconnect()
        Connections.CoinFarm = nil
    end
    
    self.Enabled = false
    self.CurrentCoin = nil
    
    LogAction("COIN_FARM", "Disabled")
end

