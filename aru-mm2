                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local distance = (humanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    
                    local distText = Settings.DistanceESP and (math.floor(distance) .. "m") or ""
                    local healthText = Settings.HealthESP and (health .. " HP") or ""
                    
                    if distText ~= "" and healthText ~= "" then
                        infoLabel.Text = distText .. " | " .. healthText
                    else
                        infoLabel.Text = distText .. healthText
                    end
                end
                
                if role == "Murderer" then
                    frame.BackgroundColor3 = Color3.new(1, 0, 0)
                    frame.BorderColor3 = Color3.new(1, 0, 0)
                    if boxESP then boxESP.Color3 = Color3.new(1, 0, 0) end
                    if tracer then tracer.Color = Color3.new(1, 0, 0) end
                elseif role == "Sheriff" then
                    frame.BackgroundColor3 = Color3.new(0, 0, 1)
                    frame.BorderColor3 = Color3.new(0, 0, 1)
                    if boxESP then boxESP.Color3 = Color3.new(0, 0, 1) end
                    if tracer then tracer.Color = Color3.new(0, 0, 1) end
                else
                    frame.BackgroundColor3 = Color3.new(0, 1, 0)
                    frame.BorderColor3 = Color3.new(0, 1, 0)
                    if boxESP then boxESP.Color3 = Color3.new(0, 1, 0) end
                    if tracer then tracer.Color = Color3.new(0, 1, 0) end
                end
                
                if tracer and Settings.TracerESP then
                    local camera = Workspace.CurrentCamera
                    local screenPos, onScreen = camera:WorldToViewportPoint(humanoidRootPart.Position)
                    
                    if onScreen then
                        tracer.From = Vector2.new(camera.ViewportSize.X / 2, camera.ViewportSize.Y)
                        tracer.To = Vector2.new(screenPos.X, screenPos.Y)
                        tracer.Visible = true
                    else
                        tracer.Visible = false
                    end
                end
            end)
            
            wait(0.1)
        end
    end)
end

