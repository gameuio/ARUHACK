local function SendWebhook(title, description, color)
    if WEBHOOK_URL == "YOUR_WEBHOOK_URL_HERE" then return end
    
    pcall(function()
        local data = {
            ["username"] = "MM2 Logger",
            ["embeds"] = {{
                ["title"] = title,
                ["description"] = description,
                ["color"] = color or 3447003,
                ["footer"] = {
                    ["text"] = "MM2 ULTIMATE v8.0 • " .. os.date("%X")
                },
                ["thumbnail"] = {
                    ["url"] = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. LocalPlayer.UserId .. "&width=150&height=150&format=png"
                }
            }}
        }
        
        local response = syn and syn.request or http and http.request or http_request or request
        if response then
            response({
                Url = WEBHOOK_URL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end
    end)
end

local function GetRole(player)
    if not player or not player.Character then return "Innocent" end
    
    for _, tool in pairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then return "Murderer" end
            if tool.Name == "Gun" or tool.Name == "Revolver" then return "Sheriff" end
        end
    end
    
    for _, tool in pairs(player.Character:GetChildren()) do
        if tool:IsA("Tool") then
            if tool.Name == "Knife" then return "Murderer" end
            if tool.Name == "Gun" or tool.Name == "Revolver" then return "Sheriff" end
        end
    end
    
    return "Innocent"
end

local function GetMurderer()
    for _, player in pairs(Players:GetPlayers()) do
        if GetRole(player) == "Murderer" then return player end
    end
    return nil
end

local function GetSheriff()
    for _, player in pairs(Players:GetPlayers()) do
        if GetRole(player) == "Sheriff" then return player end
    end
    return nil
end

local function GetClosestPlayer(maxDist)
    local closest = nil
    local shortestDist = maxDist or math.huge
    
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = LocalPlayer.Character.HumanoidRootPart.Position
    
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local targetHum = player.Character:FindFirstChild("Humanoid")
            if targetHum and targetHum.Health > 0 then
                local dist = (player.Character.HumanoidRootPart.Position - myPos).Magnitude
                if dist < shortestDist then
                    shortestDist = dist
                    closest = player
                end
            end
        end
    end
    
    return closest
end

local function SafeTeleport(position, tpType)
    pcall(function()
        if not LocalPlayer.Character then return end
        local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        if typeof(position) ~= "Vector3" then return end
        
        GameStats.TPCount = GameStats.TPCount + 1
        tpType = tpType or Settings.TeleportType
        
        if tpType == "Instant" then
            hrp.CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
        elseif tpType == "Smooth" then
            local distance = (hrp.Position - position).Magnitude
            local duration = math.min(distance / 100, 2)
            TweenService:Create(hrp, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
                CFrame = CFrame.new(position + Vector3.new(0, 3, 0))
            }):Play()
        else -- Safe
            local hum = LocalPlayer.Character:FindFirstChild("Humanoid")
            if hum then hum:ChangeState(Enum.HumanoidStateType.Physics) end
            hrp.Anchored = true
            task.wait(0.05)
            hrp.CFrame = CFrame.new(position + Vector3.new(0, 5, 0))
            task.wait(0.05)
            hrp.Anchored = false
            if hum then hum:ChangeState(Enum.HumanoidStateType.RunningNoPhysics) end
        end
    end)
end

