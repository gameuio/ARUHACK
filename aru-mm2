        headCircle.Radius = 1
        headCircle.Color3 = Color3.new(1, 0, 0)
        headCircle.Transparency = 0.5
        headCircle.AlwaysOnTop = true
        headCircle.Adornee = character.Head
        headCircle.Parent = character.Head
    end
    
    ESPObjects[player] = billboard
    
    spawn(function()
        while billboard.Parent and Settings.ESPEnabled do
            pcall(function()
                local role = GetRole(player)
                local health = ""
                
                if character:FindFirstChild("Humanoid") then
                    health = math.floor(character.Humanoid.Health)
                end
                
                if Settings.NameESP then
                    nameLabel.Text = player.Name
