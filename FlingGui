    CreateTween(ToggleButton, TweenInfo.new(0.3), {Size = UDim2.new(0, 80, 0, 80)}):Play()
    CreateTween(ToggleIcon, TweenInfo.new(0.3), {Rotation = 15, TextSize = 40}):Play()
