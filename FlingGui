local function CreatePremiumBeam(target)
    if not Settings.ShowBeams then return end
    if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return end
    if not target.Character or not target.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local beam = Instance.new("Beam")
    
    local attach0 = Instance.new("Attachment")
    attach0.Parent = Player.Character.HumanoidRootPart
    
    local attach1 = Instance.new("Attachment")
    attach1.Parent = target.Character.HumanoidRootPart
    
    beam.Attachment0 = attach0
    beam.Attachment1 = attach1
    beam.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 200, 255)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(150, 220, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 240, 255))
    }
    beam.Width0 = 0.8
    beam.Width1 = 0.8
    beam.FaceCamera = true
    beam.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0.2),
        NumberSequenceKeypoint.new(0.5, 0.1),
        NumberSequenceKeypoint.new(1, 0.2)
    }
    beam.LightEmission = 1
    beam.LightInfluence = 0
    beam.Texture = "rbxassetid://1215691065"
    beam.TextureSpeed = 3
    beam.TextureMode = Enum.TextureMode.Wrap
    beam.TextureLength = 2
    beam.Parent = Player.Character.HumanoidRootPart
    
    local particle0 = CreateAeroParticles(attach0)
    local particle1 = CreateAeroParticles(attach1)
    
    return {Beam = beam, Attach0 = attach0, Attach1 = attach1, Particle0 = particle0, Particle1 = particle1}
end

local function RemoveBeam(playerName)
    if TargetBeams[playerName] then
        if TargetBeams[playerName].Beam then TargetBeams[playerName].Beam:Destroy() end
        if TargetBeams[playerName].Attach0 then TargetBeams[playerName].Attach0:Destroy() end
        if TargetBeams[playerName].Attach1 then TargetBeams[playerName].Attach1:Destroy() end
        if TargetBeams[playerName].Particle0 then TargetBeams[playerName].Particle0:Destroy() end
        if TargetBeams[playerName].Particle1 then TargetBeams[playerName].Particle1:Destroy() end
        TargetBeams[playerName] = nil
    end
end

local function CreateHighlight(character)
    if not Settings.TargetHighlight then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "FlingHighlight"
    highlight.Adornee = character
    highlight.FillColor = Color3.fromRGB(100, 200, 255)
    highlight.OutlineColor = Color3.fromRGB(150, 220, 255)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0
    highlight.Parent = character
    
    return highlight
end

local function GetNearestPlayer()
    if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return nil end
    
    local myPos = Player.Character.HumanoidRootPart.Position
    local nearestPlayer = nil
    local shortestDistance = Settings.AutoTargetRadius or 100
    
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (player.Character.HumanoidRootPart.Position - myPos).Magnitude
            if distance < shortestDistance then
                shortestDistance = distance
                nearestPlayer = player
            end
        end
    end
    
    return nearestPlayer, shortestDistance
end

