    end)
    
    return yPosition + 50
end

-- ИСПРАВЛЕННАЯ ФУНКЦИЯ СЛАЙДЕРА
local function CreateSlider(labelText, minValue, maxValue, defaultValue, callback, yPosition)
    local sliderFrame = Instance.new("Frame")
    sliderFrame.Position = UDim2.new(0, 0, 0, yPosition)
    sliderFrame.Size = UDim2.new(1, -10, 0, 60)
    sliderFrame.BackgroundColor3 = Color3.fromRGB(35, 35, 50)
    sliderFrame.BorderSizePixel = 0
    sliderFrame.Parent = SettingsContainer
    
    AddCorners(sliderFrame, 6)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, -60, 0, 20)
    label.Position = UDim2.new(0, 10, 0, 5)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = sliderFrame
    
    local valueLabel = Instance.new("TextLabel")
    valueLabel.Size = UDim2.new(0, 50, 0, 20)
    valueLabel.Position = UDim2.new(1, -55, 0, 5)
    valueLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    valueLabel.BorderSizePixel = 0
    valueLabel.Text = tostring(defaultValue)
    valueLabel.TextColor3 = Color3.fromRGB(100, 200, 255)
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 12
    valueLabel.Parent = sliderFrame
    
    AddCorners(valueLabel, 4)
    
    local sliderBar = Instance.new("Frame")
    sliderBar.Position = UDim2.new(0, 10, 0, 35)
    sliderBar.Size = UDim2.new(1, -20, 0, 15)
    sliderBar.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
    sliderBar.BorderSizePixel = 0
    sliderBar.Parent = sliderFrame
    
    AddCorners(sliderBar, 7)
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBar
    
    AddCorners(sliderFill, 7)
    AddGradient(sliderFill, ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 150, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(150, 100, 255))
    })
    
    local sliderButton = Instance.new("Frame") -- Изменено с TextButton на Frame
    sliderButton.Position = UDim2.new((defaultValue - minValue) / (maxValue - minValue), -8, 0.5, -8)
    sliderButton.Size = UDim2.new(0, 16, 0, 16)
    sliderButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderButton.BorderSizePixel = 0
    sliderButton.Parent = sliderBar
    
    AddCorners(sliderButton, 8)
    CreateShadow(sliderButton)
    
    local currentValue = defaultValue
    local draggingSlider = false
    
    -- Сделаем весь слайдер кликабельным
    local sliderHitbox = Instance.new("TextButton")
    sliderHitbox.Size = UDim2.new(1, 0, 1, 0)
    sliderHitbox.BackgroundTransparency = 1
    sliderHitbox.Text = ""
    sliderHitbox.ZIndex = 5
    sliderHitbox.Parent = sliderBar
    
    -- Функция обновления слайдера
    local function updateSlider(input)
        local mousePos = input.Position.X
        local barPos = sliderBar.AbsolutePosition.X
        local barSize = sliderBar.AbsoluteSize.X
        
        local percentage = math.clamp((mousePos - barPos) / barSize, 0, 1)
        currentValue = math.floor(minValue + (maxValue - minValue) * percentage)
        
        sliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
        sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        valueLabel.Text = tostring(currentValue)
        
        callback(currentValue)
    end
    
    -- Клик по бару
    sliderHitbox.MouseButton1Down:Connect(function()
        draggingSlider = true
        CreateTween(sliderButton, TweenInfo.new(0.1), {
            Size = UDim2.new(0, 20, 0, 20),
            BackgroundColor3 = Color3.fromRGB(255, 255, 255)
        }):Play()
    end)
    
    -- Отпускание кнопки мыши
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if draggingSlider then
                draggingSlider = false
                CreateTween(sliderButton, TweenInfo.new(0.2), {
                    Size = UDim2.new(0, 16, 0, 16),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                }):Play()
            end
        end
    end)
    
    -- Перемещение мыши
    sliderHitbox.MouseMoved:Connect(function(x, y)
        if draggingSlider then
            local input = {Position = Vector2.new(x, y)}
            updateSlider(input)
        end
    end)
    
    -- Клик по бару для мгновенного перемещения
    sliderHitbox.MouseButton1Click:Connect(function()
        local mouseLocation = UserInputService:GetMouseLocation()
        updateSlider({Position = mouseLocation})
    end)
    
    return yPosition + 70
end

