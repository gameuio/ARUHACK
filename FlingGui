-- 5. GRAVITY GUN
function ToggleGravityGun()
    if GrabbedPlayer or GrabbedObject then
        -- SLING MODE
        if GrabbedPlayer and GrabbedPlayer.Character and GrabbedPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local rootPart = GrabbedPlayer.Character.HumanoidRootPart
            local camera = workspace.CurrentCamera
            local direction = camera.CFrame.LookVector
            local velocity = direction * Settings.SlingPower
            
            ClaimNetworkOwnership(rootPart)
            rootPart.AssemblyLinearVelocity = velocity
            
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "🧲 Gravity Gun",
                Text = "Slung " .. GrabbedPlayer.Name .. "!",
                Duration = 2
            })
        elseif GrabbedObject then
            local camera = workspace.CurrentCamera
            local direction = camera.CFrame.LookVector
            local velocity = direction * Settings.SlingPower
            
            ClaimNetworkOwnership(GrabbedObject)
            GrabbedObject.AssemblyLinearVelocity = velocity
            
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "🧲 Gravity Gun",
                Text = "Slung object!",
                Duration = 2
            })
        end
        
        -- Cleanup
        if GrabConnection then
            GrabConnection:Disconnect()
            GrabConnection = nil
        end
        
        if GrabAlign then GrabAlign:Destroy() end
        if GrabAttachment0 then GrabAttachment0:Destroy() end
        if GrabAttachment1 then GrabAttachment1:Destroy() end
        
        RemoveBeam("GrabbedPlayer")
        GrabbedPlayer = nil
        GrabbedObject = nil
        GrabAlign = nil
        GrabAttachment0 = nil
        GrabAttachment1 = nil
        
    else
        -- GRAB MODE
        local nearest, distance = GetNearestPlayer()
        
        if nearest and distance < 30 then
            GrabbedPlayer = nearest
            
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "🧲 Gravity Gun",
                Text = "Grabbed " .. nearest.Name .. "! Press again to sling!",
                Duration = 3
            })
            
            if nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart") then
                local targetRoot = nearest.Character.HumanoidRootPart
                
                ClaimNetworkOwnership(targetRoot)
                
                -- Create AlignPosition for smooth grab
                GrabAttachment0 = Instance.new("Attachment")
                GrabAttachment0.Parent = Player.Character.HumanoidRootPart
                
                GrabAttachment1 = Instance.new("Attachment")
                GrabAttachment1.Parent = targetRoot
                
                GrabAlign = Instance.new("AlignPosition")
                GrabAlign.Attachment0 = GrabAttachment1
                GrabAlign.Attachment1 = GrabAttachment0
                GrabAlign.MaxForce = 50000
                GrabAlign.MaxVelocity = 50
                GrabAlign.Responsiveness = 20
                GrabAlign.ReactionForceEnabled = false
                GrabAlign.ApplyAtCenterOfMass = true
                GrabAlign.Parent = targetRoot
                
                TargetBeams["GrabbedPlayer"] = CreateBeam(nearest)
                
                GrabConnection = RunService.Heartbeat:Connect(function()
                    if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                        local myRoot = Player.Character.HumanoidRootPart
                        local offset = myRoot.CFrame.LookVector * Settings.GrabDistance
                        GrabAttachment0.WorldPosition = myRoot.Position + offset + Vector3.new(0, 2, 0)
                    else
                        if GrabConnection then
                            GrabConnection:Disconnect()
                        end
                        if GrabAlign then GrabAlign:Destroy() end
                        if GrabAttachment0 then GrabAttachment0:Destroy() end
                        if GrabAttachment1 then GrabAttachment1:Destroy() end
                        RemoveBeam("GrabbedPlayer")
                    end
                end)
            end
        else
            -- Try to grab nearest object
            if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                local myPos = Player.Character.HumanoidRootPart.Position
                local nearestObj = nil
                local nearestDist = 30
                
                for _, obj in pairs(workspace:GetPartBoundsInRadius(myPos, 30)) do
                    if obj:IsA("BasePart") and not obj.Anchored and obj:CanSetNetworkOwnership() and obj.Parent ~= Player.Character then
                        local dist = (obj.Position - myPos).Magnitude
                        if dist < nearestDist then
                            nearestDist = dist
                            nearestObj = obj
                        end
                    end
                end
                
                if nearestObj then
                    GrabbedObject = nearestObj
                    ClaimNetworkOwnership(nearestObj)
                    
                    GrabAttachment0 = Instance.new("Attachment")
                    GrabAttachment0.Parent = Player.Character.HumanoidRootPart
                    
                    GrabAttachment1 = Instance.new("Attachment")
                    GrabAttachment1.Parent = nearestObj
                    
                    GrabAlign = Instance.new("AlignPosition")
