-- 3. RAGDOLL LAUNCHER
function ToggleRagdollLauncher()
    RagdollLauncherActive = not RagdollLauncherActive
    
    if RagdollLauncherActive then
        LaunchableObjects = {}
        
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("BasePart") and not obj.Anchored and obj:CanSetNetworkOwnership() then
