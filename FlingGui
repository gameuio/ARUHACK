function ToggleBlackHole()
    BlackHoleActive = not BlackHoleActive
    
    if BlackHoleActive then
        if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return end
        
        -- Create black hole visual
        BlackHolePart = Instance.new("Part")
        BlackHolePart.Name = "BlackHole"
        BlackHolePart.Size = Vector3.new(Settings.BlackHoleRadius * 2, Settings.BlackHoleRadius * 2, Settings.BlackHoleRadius * 2)
        BlackHolePart.Shape = Enum.PartType.Ball
        BlackHolePart.Material = Enum.Material.ForceField
        BlackHolePart.Color = Color3.fromRGB(20, 20, 50)
        BlackHolePart.Transparency = 0.5
        BlackHolePart.CanCollide = false
        BlackHolePart.Anchored = true
        BlackHolePart.CFrame = Player.Character.HumanoidRootPart.CFrame + Vector3.new(0, 10, 0)
        BlackHolePart.Parent = workspace
        
        -- Add particles
        local particle = CreateAeroParticles(BlackHolePart, ColorSequence.new{
            ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 50, 150)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(100, 100, 200)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 20, 80))
        })
        particle.Rate = 100
        particle.Speed = NumberRange.new(-10, -5)
        
        -- Add glow
        local light = Instance.new("PointLight")
        light.Color = Color3.fromRGB(100, 100, 255)
        light.Brightness = 2
        light.Range = Settings.BlackHoleRadius * 2
        light.Parent = BlackHolePart
        
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🌑 Black Hole",
            Text = "ACTIVATED! Players will be sucked in!",
            Duration = 3
        })
        
        BlackHoleConnection = RunService.Heartbeat:Connect(function()
            if not BlackHolePart or not BlackHolePart.Parent then
                BlackHoleActive = false
                return
            end
            
            local blackHolePos = BlackHolePart.Position
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local targetRoot = player.Character.HumanoidRootPart
                    local distance = (targetRoot.Position - blackHolePos).Magnitude
                    
                    if distance < Settings.BlackHoleRadius then
                        -- Pull towards black hole
                        local direction = (blackHolePos - targetRoot.Position).Unit
                        local pullStrength = (1 - distance / Settings.BlackHoleRadius) * Settings.BlackHolePower
                        
                        targetRoot.Velocity = direction * pullStrength
                        
                        -- If very close, explosion effect
                        if distance < 5 then
                            local explosionDirection = (targetRoot.Position - blackHolePos).Unit
                            targetRoot.Velocity = explosionDirection * 200
                            targetRoot.RotVelocity = Vector3.new(
                                math.random(-50, 50),
                                math.random(-50, 50),
                                math.random(-50, 50)
                            )
                        end
                    end
                end
            end
        end)
        
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🌑 Black Hole",
            Text = "Deactivated",
            Duration = 2
        })
        
        if BlackHoleConnection then
            BlackHoleConnection:Disconnect()
            BlackHoleConnection = nil
        end
        
        if BlackHolePart then
            BlackHolePart:Destroy()
            BlackHolePart = nil
        end
    end
end

