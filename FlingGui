local isGUIVisible = false

local function ToggleGUI()
    isGUIVisible = not isGUIVisible
    
    if isGUIVisible then
        MainFrame.Visible = true
        CreateTween(MainFrame, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
            Size = UDim2.new(0, 500, 0, 680),
            Position = UDim2.new(0.5, -250, 0.5, -340)
        }):Play()
        CreateTween(ToggleIcon, TweenInfo.new(0.3), {Rotation = 180}):Play()
    else
        CreateTween(MainFrame, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 0, 0, 0),
            Position = UDim2.new(0.5, 0, 0.5, 0)
        }):Play()
        CreateTween(ToggleIcon, TweenInfo.new(0.3), {Rotation = 0}):Play()
        wait(0.4)
        MainFrame.Visible = false
    end
end

