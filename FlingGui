    sliderBar.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    sliderBar.BorderSizePixel = 0
    sliderBar.Parent = sliderFrame
    
    AddCorners(sliderBar, 7)
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(80, 160, 220)
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBar
    
    AddCorners(sliderFill, 7)
    
    local sliderButton = Instance.new("Frame")
    sliderButton.Position = UDim2.new((defaultValue - minValue) / (maxValue - minValue), -8, 0.5, -8)
    sliderButton.Size = UDim2.new(0, 16, 0, 16)
    sliderButton.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    sliderButton.BorderSizePixel = 0
    sliderButton.Parent = sliderBar
    
    AddCorners(sliderButton, 8)
    
    local currentValue = defaultValue
    local draggingSlider = false
    
    local sliderHitbox = Instance.new("TextButton")
    sliderHitbox.Size = UDim2.new(1, 0, 1, 0)
    sliderHitbox.BackgroundTransparency = 1
    sliderHitbox.Text = ""
    sliderHitbox.ZIndex = 5
    sliderHitbox.Parent = sliderBar
    
    local function updateSlider(input)
        local mousePos = input.Position.X
        local barPos = sliderBar.AbsolutePosition.X
        local barSize = sliderBar.AbsoluteSize.X
        
        local percentage = math.clamp((mousePos - barPos) / barSize, 0, 1)
        
        if maxValue - minValue <= 10 then
            currentValue = math.floor((minValue + (maxValue - minValue) * percentage) * 10) / 10
        else
            currentValue = math.floor(minValue + (maxValue - minValue) * percentage)
        end
        
        sliderButton.Position = UDim2.new(percentage, -8, 0.5, -8)
        sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        valueLabel.Text = tostring(currentValue)
        
        callback(currentValue)
    end
    
    sliderHitbox.MouseButton1Down:Connect(function()
        draggingSlider = true
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            draggingSlider = false
        end
    end)
    
    sliderHitbox.MouseMoved:Connect(function(x, y)
        if draggingSlider then
            updateSlider({Position = Vector2.new(x, y)})
        end
    end)
    
    sliderHitbox.MouseButton1Click:Connect(function()
        local mouseLocation = UserInputService:GetMouseLocation()
        updateSlider({Position = mouseLocation})
    end)
    
    return yPosition + 68
end

