    AddCorners(valueLabel, 6)
    
    local sliderBar = Instance.new("Frame")
    sliderBar.Position = UDim2.new(0, 10, 0, 40)
    sliderBar.Size = UDim2.new(1, -20, 0, 16)
    sliderBar.BackgroundColor3 = Color3.fromRGB(180, 230, 255)
    sliderBar.BackgroundTransparency = 0.5
    sliderBar.BorderSizePixel = 0
    sliderBar.Parent = sliderFrame
    
    AddCorners(sliderBar, 8)
    
    local sliderFill = Instance.new("Frame")
    sliderFill.Size = UDim2.new((defaultValue - minValue) / (maxValue - minValue), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
    sliderFill.BackgroundTransparency = 0.2
    sliderFill.BorderSizePixel = 0
    sliderFill.Parent = sliderBar
    
    AddCorners(sliderFill, 8)
    AddGradient(sliderFill, ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(120, 220, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(100, 200, 255))
    })
    
    local sliderButton = Instance.new("Frame")
    sliderButton.Position = UDim2.new((defaultValue - minValue) / (maxValue - minValue), -10, 0.5, -10)
    sliderButton.Size = UDim2.new(0, 20, 0, 20)
    sliderButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderButton.BorderSizePixel = 0
    sliderButton.Parent = sliderBar
    
    AddCorners(sliderButton, 10)
    CreateShadow(sliderButton)
    
    local currentValue = defaultValue
    local draggingSlider = false
    
    local sliderHitbox = Instance.new("TextButton")
    sliderHitbox.Size = UDim2.new(1, 0, 1, 0)
    sliderHitbox.BackgroundTransparency = 1
    sliderHitbox.Text = ""
    sliderHitbox.ZIndex = 5
    sliderHitbox.Parent = sliderBar
    
    local function updateSlider(input)
        local mousePos = input.Position.X
        local barPos = sliderBar.AbsolutePosition.X
        local barSize = sliderBar.AbsoluteSize.X
        
        local percentage = math.clamp((mousePos - barPos) / barSize, 0, 1)
        
        if maxValue - minValue <= 10 then
            currentValue = math.floor((minValue + (maxValue - minValue) * percentage) * 10) / 10
        else
            currentValue = math.floor(minValue + (maxValue - minValue) * percentage)
        end
        
        sliderButton.Position = UDim2.new(percentage, -10, 0.5, -10)
        sliderFill.Size = UDim2.new(percentage, 0, 1, 0)
        valueLabel.Text = tostring(currentValue)
        
        callback(currentValue)
    end
    
    sliderHitbox.MouseButton1Down:Connect(function()
        draggingSlider = true
        CreateTween(sliderButton, TweenInfo.new(0.1), {Size = UDim2.new(0, 24, 0, 24)}):Play()
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            if draggingSlider then
                draggingSlider = false
                CreateTween(sliderButton, TweenInfo.new(0.2), {Size = UDim2.new(0, 20, 0, 20)}):Play()
            end
        end
    end)
    
    sliderHitbox.MouseMoved:Connect(function(x, y)
        if draggingSlider then
            updateSlider({Position = Vector2.new(x, y)})
        end
    end)
    
    sliderHitbox.MouseButton1Click:Connect(function()
        local mouseLocation = UserInputService:GetMouseLocation()
        updateSlider({Position = mouseLocation})
    end)
    
    return yPosition + 75
end

local function CreateDropdown(labelText, options, defaultValue, callback, yPosition)
    local dropFrame = Instance.new("Frame")
    dropFrame.Position = UDim2.new(0, 0, 0, yPosition)
    dropFrame.Size = UDim2.new(1, -10, 0, 40)
    dropFrame.BackgroundColor3 = Color3.fromRGB(220, 245, 255)
    dropFrame.BackgroundTransparency = 0.3
    dropFrame.BorderSizePixel = 0
    dropFrame.ClipsDescendants = false
    dropFrame.ZIndex = 2
    dropFrame.Parent = SettingsContainer
    
    AddCorners(dropFrame, 8)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.45, 0, 1, 0)
    label.Position = UDim2.new(0, 10, 0, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(80, 180, 255)
    label.Font = Enum.Font.Gotham
    label.TextSize = 13
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = dropFrame
    
    local dropButton = Instance.new("TextButton")
    dropButton.Position = UDim2.new(0.48, 0, 0.5, -16)
    dropButton.Size = UDim2.new(0.5, 0, 0, 32)
    dropButton.BackgroundColor3 = Color3.fromRGB(180, 230, 255)
    dropButton.BackgroundTransparency = 0.5
    dropButton.BorderSizePixel = 0
    dropButton.Text = defaultValue .. " ▼"
    dropButton.TextColor3 = Color3.fromRGB(80, 180, 255)
    dropButton.Font = Enum.Font.GothamBold
    dropButton.TextSize = 12
    dropButton.AutoButtonColor = false
    dropButton.ZIndex = 3
    dropButton.Parent = dropFrame
    
    AddCorners(dropButton, 8)
    
    local dropList = Instance.new("Frame")
    dropList.Position = UDim2.new(0.48, 0, 1, 5)
    dropList.Size = UDim2.new(0.5, 0, 0, #options * 38)
    dropList.BackgroundColor3 = Color3.fromRGB(200, 240, 255)
    dropList.BackgroundTransparency = 0.2
    dropList.BorderSizePixel = 0
    dropList.Visible = false
    dropList.ZIndex = 5
    dropList.Parent = dropFrame
    
    AddCorners(dropList, 8)
    CreateShadow(dropList)
    AddStroke(dropList, Color3.fromRGB(150, 220, 255), 2)
    
    for i, option in ipairs(options) do
        local optionButton = Instance.new("TextButton")
        optionButton.Position = UDim2.new(0, 6, 0, (i - 1) * 38 + 6)
        optionButton.Size = UDim2.new(1, -12, 0, 32)
        optionButton.BackgroundColor3 = Color3.fromRGB(180, 230, 255)
        optionButton.BackgroundTransparency = 0.5
        optionButton.BorderSizePixel = 0
        optionButton.Text = option
        optionButton.TextColor3 = Color3.fromRGB(80, 180, 255)
        optionButton.Font = Enum.Font.Gotham
        optionButton.TextSize = 12
        optionButton.AutoButtonColor = false
        optionButton.ZIndex = 6
        optionButton.Parent = dropList
        
        AddCorners(optionButton, 6)
        
        optionButton.MouseEnter:Connect(function()
            CreateTween(optionButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(100, 200, 255), BackgroundTransparency = 0.2}):Play()
        end)
        
        optionButton.MouseLeave:Connect(function()
            CreateTween(optionButton, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(180, 230, 255), BackgroundTransparency = 0.5}):Play()
        end)
        
        optionButton.MouseButton1Click:Connect(function()
            dropButton.Text = option .. " ▼"
            dropList.Visible = false
            callback(option)
        end)
    end
    
    dropButton.MouseButton1Click:Connect(function()
        dropList.Visible = not dropList.Visible
    end)
    
    return yPosition + 50
end

