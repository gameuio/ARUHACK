local function RefreshPlayerList()
    for _, child in pairs(PlayerScrollFrame:GetChildren()) do
        child:Destroy()
    end
    PlayerCheckboxes = {}
    
    local PlayerList = Players:GetPlayers()
    table.sort(PlayerList, function(a, b) return a.Name:lower() < b.Name:lower() end)
    
    local yPosition = 0
    for _, player in ipairs(PlayerList) do
        if player ~= Player then
            PlayerCheckboxes[player.Name] = CreatePlayerEntry(player, yPosition)
            yPosition = yPosition + 38
        end
    end
    
    PlayerScrollFrame.CanvasSize = UDim2.new(0, 0, 0, yPosition)
end

local function CountSelectedTargets()
    local count = 0
    for _ in pairs(SelectedTargets) do
        count = count + 1
    end
    return count
end

function UpdateStatus()
    local count = CountSelectedTargets()
    
    if count > 0 then
        NotificationBadge.Text = tostring(count)
        NotificationBadge.Visible = true
    else
        NotificationBadge.Visible = false
    end
    
    if FlingActive then
        StatusLabel.Text = "CHAOS ACTIVE"
        StatusDetail.Text = count .. " target(s) in chaos"
        StatusIcon.TextColor3 = Color3.fromRGB(200, 50, 50)
    else
        StatusLabel.Text = "READY FOR CHAOS"
        if count > 0 then
            StatusDetail.Text = count .. " target(s) selected"
        else
            StatusDetail.Text = "Select chaos modes or targets"
        end
        StatusIcon.TextColor3 = Color3.fromRGB(50, 180, 50)
    end
end

local function ToggleAllPlayers(select)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= Player then
            local checkboxData = PlayerCheckboxes[player.Name]
            if checkboxData then
                if select then
                    SelectedTargets[player.Name] = player
                    checkboxData.Checkmark.Visible = true
                    CreateTween(checkboxData.Checkmark, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
                    CreateTween(checkboxData.CheckboxContainer, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 180, 50)}):Play()
                    
                    if player.Character then
                        TargetHighlights[player.Name] = CreateHighlight(player.Character)
                        TargetBeams[player.Name] = CreateBeam(player)
                    end
                else
                    SelectedTargets[player.Name] = nil
                    CreateTween(checkboxData.Checkmark, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
                    CreateTween(checkboxData.CheckboxContainer, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}):Play()
                    wait(0.2)
                    checkboxData.Checkmark.Visible = false
                    
                    if TargetHighlights[player.Name] then
                        TargetHighlights[player.Name]:Destroy()
                        TargetHighlights[player.Name] = nil
                    end
                    
                    RemoveBeam(player.Name)
                end
            end
        end
    end
    
    UpdateStatus()
end

