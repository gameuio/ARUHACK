-- 6. VORTEX MODE
function ToggleVortex()
    VortexActive = not VortexActive
    
    if VortexActive then
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🌪️ Vortex Mode",
            Text = "ACTIVATED! Players will orbit around you!",
            Duration = 3
        })
        
        VortexConnection = RunService.Heartbeat:Connect(function()
            if not Player.Character or not Player.Character:FindFirstChild("HumanoidRootPart") then return end
            
            local myRoot = Player.Character.HumanoidRootPart
            local myPos = myRoot.Position
            
            for _, player in ipairs(Players:GetPlayers()) do
                if player ~= Player and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                    local targetRoot = player.Character.HumanoidRootPart
                    local distance = (targetRoot.Position - myPos).Magnitude
                    
                    if distance < Settings.VortexRadius then
                        ClaimNetworkOwnership(targetRoot)
                        
                        local angle = tick() * Settings.VortexSpeed + (player.UserId % 360)
                        local radius = Settings.VortexRadius * 0.7
                        
                        local offsetX = math.cos(math.rad(angle)) * radius
                        local offsetZ = math.sin(math.rad(angle)) * radius
                        local height = math.sin(tick() * 2) * 5
                        
                        local targetPos = myPos + Vector3.new(offsetX, height, offsetZ)
                        
                        local direction = (targetPos - targetRoot.Position).Unit
                        targetRoot.AssemblyLinearVelocity = direction * 50
                        targetRoot.AssemblyAngularVelocity = Vector3.new(
                            math.random(-10, 10),
                            math.random(-10, 10),
                            math.random(-10, 10)
                        )
                    end
                end
            end
        end)
        
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🌪️ Vortex Mode",
            Text = "Deactivated",
            Duration = 2
        })
        
        if VortexConnection then
            VortexConnection:Disconnect()
            VortexConnection = nil
        end
    end
end

