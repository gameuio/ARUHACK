function AutoTargetNearest()
    local nearestPlayer, distance = GetNearestPlayer()
    
    if nearestPlayer then
        for name, _ in pairs(SelectedTargets) do
            SelectedTargets[name] = nil
            local checkbox = PlayerCheckboxes[name]
            if checkbox then
                CreateTween(checkbox.Checkmark, TweenInfo.new(0.2), {TextTransparency = 1}):Play()
                CreateTween(checkbox.CheckboxContainer, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(220, 245, 255)
                }):Play()
                checkbox.Checkmark.Visible = false
            end
            
            if TargetHighlights[name] then
                TargetHighlights[name]:Destroy()
                TargetHighlights[name] = nil
            end
            RemoveBeam(name)
        end
        
        SelectedTargets[nearestPlayer.Name] = nearestPlayer
        local checkbox = PlayerCheckboxes[nearestPlayer.Name]
        if checkbox then
            checkbox.Checkmark.Visible = true
            CreateTween(checkbox.Checkmark, TweenInfo.new(0.2), {TextTransparency = 0}):Play()
            CreateTween(checkbox.CheckboxContainer, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(100, 255, 150)
            }):Play()
        end
        
        if nearestPlayer.Character then
            TargetHighlights[nearestPlayer.Name] = CreateHighlight(nearestPlayer.Character)
            TargetBeams[nearestPlayer.Name] = CreatePremiumBeam(nearestPlayer)
        end
        
        UpdateStatus()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🎯 Auto-Target",
            Text = "Locked onto " .. nearestPlayer.Name .. " (" .. math.floor(distance) .. " studs)",
            Duration = 3
        })
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "🎯 Auto-Target",
            Text = "No players found nearby!",
            Duration = 2
        })
    end
end

