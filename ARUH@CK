local function createBackgroundMusic()
    if not DATA.backgroundMusic then
        DATA.backgroundMusic = Instance.new("Sound")
        DATA.backgroundMusic.SoundId = "rbxassetid://99612100069480"
        DATA.backgroundMusic.Volume = STATE.musicVolume
        DATA.backgroundMusic.Looped = true
        DATA.backgroundMusic.Parent = screenGui
    end
end

local function toggleMusic()
    STATE.musicEnabled = not STATE.musicEnabled
    createBackgroundMusic()
    if STATE.musicEnabled then
        DATA.backgroundMusic:Play()
        Notify("ARUSCRIPT V5", "🎵 Music Started!")
    else
        DATA.backgroundMusic:Stop()
        Notify("ARUSCRIPT V5", "🔇 Music Stopped!")
    end
end

local function setMusicVolume(vol)
    createBackgroundMusic()
    STATE.musicVolume = math.clamp(vol, 0, 1)
    DATA.backgroundMusic.Volume = STATE.musicVolume
    Config.Settings.MusicVolume = STATE.musicVolume
    SaveConfig()
    Notify("ARUSCRIPT V5", "🎵 Volume: " .. math.floor(STATE.musicVolume * 100) .. "%")
end

