local function UpdateButtonStatus(name, enabled)
    if GUI.Buttons[name] and GUI.Buttons[name].Status then
        local status = GUI.Buttons[name].Status
        status.Text = enabled and "ON" or "OFF"
        Services.TweenService:Create(status, TweenInfo.new(0.2), {
            TextColor3 = enabled and Color3.fromRGB(0, 255, 0) or Color3.fromRGB(255, 50, 50),
            BackgroundColor3 = enabled and Color3.fromRGB(0, 50, 0) or Color3.fromRGB(50, 0, 0)
        }):Play()
    end
end

