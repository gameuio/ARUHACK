-- Flashlight
local function toggleFlashlight()
    flashlightEnabled = not flashlightEnabled
    flashlightBtn.Text = flashlightEnabled and "⟨ DISABLE FLASHLIGHT ⟩" or "⟨ FLASHLIGHT ⟩"
    
    if flashlightEnabled then
        local light = Instance.new("Part")
        light.Shape = Enum.PartType.Ball
        light.CanCollide = false
        light.CanTouch = false
        light.Transparency = 1
        light.Name = "Flashlight"
        light.Parent = workspace
        
        local pointLight = Instance.new("PointLight")
        pointLight.Brightness = 3
        pointLight.Range = 30
        pointLight.Color = Color3.fromRGB(255, 255, 255)
        pointLight.Parent = light
        
        connections.flashlight = RunService.Heartbeat:Connect(function()
            if light and light.Parent then
                local char = Players.LocalPlayer.Character
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        light.Position = hrp.Position + hrp.CFrame.LookVector * 5
                    end
                end
            end
        end)
    else
        if connections.flashlight then
            connections.flashlight:Disconnect()
        end
        local light = workspace:FindFirstChild("Flashlight")
        if light then light:Destroy() end
    end
    
    Notify("ARUSCRIPT V5", "Flashlight: " .. tostring(flashlightEnabled))
end

