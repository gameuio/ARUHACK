-- RAINBOW
spawn(function()
    while S.rain do
        local c = U.Rain()
        pcall(function()
            if G.MS then G.MS.Color = c end
            if G.TS then G.TS.Color = c end
            if G.SS then G.SS.Color = c end
            if G.CS then G.CS.Color = c end
        end)
        wait(0.01)
    end
end)

-- KEYBIND
Serv.UIS.InputBegan:Connect(function(i, g)
    if g then return end
    if i.KeyCode == Enum.KeyCode.RightShift then
        if S.show then
            S.show = false
            Serv.TS:Create(G.Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Size = UDim2.new(0,0,0,0), Position = UDim2.new(0.5,0,0.5,0)}):Play()
            wait(0.5)
            G.Main.Visible = false
            G.Tog.Visible = true
        else
            S.show = true
            G.Tog.Visible = false
            G.Main.Visible = true
            G.Main.Size = UDim2.new(0,0,0,0)
            G.Main.Position = UDim2.new(0.5,0,0.5,0)
            Serv.TS:Create(G.Main, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Size = UDim2.new(0,850,0,600), Position = UDim2.new(0.5,-425,0.5,-300)}):Play()
        end
    end
end)

