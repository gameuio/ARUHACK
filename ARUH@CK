local function ToggleInfJump()
    State.infJump = not State.infJump
    UpdateButton("InfJump", State.infJump)
    
    if State.infJump then
        Data.connections.infJump = UserInputService.JumpRequest:Connect(function()
            local hum = GetHumanoid()
            if hum then
                hum:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end)
    else
        if Data.connections.infJump then
            Data.connections.infJump:Disconnect()
        end
    end
    
    Notify("INF JUMP", tostring(State.infJump))
end

