local function TgESP()
    State.esp = not State.esp
    UpdateButton("ESP", State.esp)
    if State.esp then
        for _, p in pairs(Plrs:GetPlayers()) do
            if p ~= LP and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r and not r:FindFirstChild("ESP") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP"
                    box.Size = Vector3.new(4, 6, 1)
                    box.Adornee = r
                    box.Color3 = Color3.fromRGB(0, 255, 0)
                    box.AlwaysOnTop = true
                    box.Transparency = 0.5
                    box.ZIndex = 10
                    box.Parent = r
                end
            end
        end
    else
        for _, p in pairs(Plrs:GetPlayers()) do
            if p.Character then
                for _, v in pairs(p.Character:GetDescendants()) do
                    if v.Name == "ESP" then v:Destroy() end
                end
            end
        end
    end
    Notify("ESP", State.esp and "Включен" or "Выключен")
end

local function TgFly()
    State.fly = not State.fly
    UpdateButton("Fly", State.fly)
    if State.fly then
        local r = GetRoot()
        if r then
            Data.bv = Instance.new("BodyVelocity")
            Data.bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            Data.bv.Velocity = Vector3.new(0, 0, 0)
            Data.bv.Parent = r
            Data.bg = Instance.new("BodyGyro")
            Data.bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            Data.bg.CFrame = r.CFrame
            Data.bg.Parent = r
            Data.con.fly = Run.Heartbeat:Connect(function()
                if not State.fly then return end
                local md = Vector3.new(0, 0, 0)
                if UIS:IsKeyDown(Enum.KeyCode.W) then md = md + Cam.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S) then md = md - Cam.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A) then md = md - Cam.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D) then md = md + Cam.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space) then md = md + Vector3.new(0, 1, 0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then md = md - Vector3.new(0, 1, 0) end
                if Data.bv then Data.bv.Velocity = md * State.flySpeed end
                if Data.bg then Data.bg.CFrame = Cam.CFrame end
            end)
        end
    else
        if Data.con.fly then Data.con.fly:Disconnect() end
        if Data.bv then Data.bv:Destroy() Data.bv = nil end
        if Data.bg then Data.bg:Destroy() Data.bg = nil end
    end
    Notify("FLY", State.fly and "Включен (WASD)" or "Выключен")
end

