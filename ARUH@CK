local function CreateSlider(category, name, text, min, max, default, callback, order)
    if not GUI.Categories[category] then return end
    
    local frame = Instance.new("Frame", GUI.Categories[category])
    frame.Size = UDim2.new(1, 0, 0, 75)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 42)
    frame.BorderSizePixel = 0
