    textLabel.Size = UDim2.new(1, -80, 1, 0)
    textLabel.Position = UDim2.new(0, 18, 0, 0)
    textLabel.Text = buttonText
    textLabel.TextSize = 15
    textLabel.TextColor3 = Color3.fromRGB(220, 220, 240)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.BackgroundTransparency = 1
    textLabel.Parent = functionButton
    
    local statusLabel = Instance.new("TextLabel")
    statusLabel.Name = "StatusLabel"
    statusLabel.Size = UDim2.new(0, 60, 0, 28)
    statusLabel.Position = UDim2.new(1, -70, 0.5, -14)
    statusLabel.Text = "OFF"
    statusLabel.TextSize = 13
    statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
    statusLabel.Font = Enum.Font.GothamBlack
    statusLabel.BackgroundColor3 = Color3.fromRGB(50, 20, 20)
    statusLabel.BorderSizePixel = 0
    statusLabel.Parent = functionButton
    
    local statusCorner = Instance.new("UICorner")
    statusCorner.CornerRadius = UDim.new(0, 8)
    statusCorner.Parent = statusLabel
    
    local statusStroke = Instance.new("UIStroke")
    statusStroke.Color = Color3.fromRGB(255, 50, 50)
    statusStroke.Thickness = 1
    statusStroke.Parent = statusLabel
    
    functionButton.MouseEnter:Connect(function()
        TweenService:Create(functionButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(35, 35, 50)
        }):Play()
        
        TweenService:Create(buttonStroke, TweenInfo.new(0.2), {
            Transparency = 0,
            Thickness = 2,
            Color = GetRainbowColor()
        }):Play()
    end)
    
    functionButton.MouseLeave:Connect(function()
        TweenService:Create(functionButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(25, 25, 35)
        }):Play()
        
        TweenService:Create(buttonStroke, TweenInfo.new(0.2), {
            Transparency = 0.5,
            Thickness = 1,
            Color = Color3.fromRGB(50, 50, 70)
        }):Play()
    end)
    
    FunctionButtons[buttonName] = {
        Button = functionButton,
        StatusLabel = statusLabel,
        StatusStroke = statusStroke
    }
    
    return functionButton
end

local function UpdateButtonStatus(buttonName, isEnabled)
    if FunctionButtons[buttonName] then
        local statusLabel = FunctionButtons[buttonName].StatusLabel
        local statusStroke = FunctionButtons[buttonName].StatusStroke
        
        statusLabel.Text = isEnabled and "ON" or "OFF"
        
        TweenService:Create(statusLabel, TweenInfo.new(0.3), {
            TextColor3 = isEnabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100),
            BackgroundColor3 = isEnabled and Color3.fromRGB(20, 80, 20) or Color3.fromRGB(50, 20, 20)
        }):Play()
        
        TweenService:Create(statusStroke, TweenInfo.new(0.3), {
            Color = isEnabled and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
        }):Play()
    end
end

