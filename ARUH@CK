local function createButton(name, text, order, col)
    local container = Instance.new("Frame")
    container.Name = name .. "_C"
    container.BackgroundTransparency = 1
    container.LayoutOrder = order

    if col then
        container.Size = UDim2.new(0.485, 0, 0, 38)
    else
        container.Size = UDim2.new(1, 0, 0, 38)
    end
    container.Parent = contentFrame

    local btn = Instance.new("TextButton", container)
    btn.Name = name
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Text = "⟨ " .. text .. " ⟩"
    btn.TextScaled = true
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = Enum.Font.Code
    btn.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    btn.BackgroundTransparency = 0.35
    btn.BorderSizePixel = 0
    btn.AutoButtonColor = false

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)
    Instance.new("UIPadding", btn).PaddingLeft = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke", btn)
    stroke.Color = Color3.fromRGB(255, 0, 0)
    stroke.Thickness = 2
    stroke.Transparency = 0.2

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.1), {BackgroundTransparency = 0.15}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.1), {Thickness = 3, Transparency = 0}):Play()
