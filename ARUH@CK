            local mv = Vector3.new(0,0,0)
            local spd = 30

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then mv = mv + Camera.CFrame.LookVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then mv = mv - Camera.CFrame.LookVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then mv = mv - Camera.CFrame.RightVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then mv = mv + Camera.CFrame.RightVector * spd end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then mv = mv + Vector3.new(0, spd, 0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then mv = mv - Vector3.new(0, spd, 0) end

            freecamBV.Velocity = mv
            Camera.CFrame = CFrame.new(freecamCamera.Position) * (Camera.CFrame - Camera.CFrame.Position)
        end)
    else
        if connections.freecam then connections.freecam:Disconnect() end
        if freecamCamera then freecamCamera:Destroy() end
        Camera.CameraType = Enum.CameraType.Custom
    end

    Notify("ARUSCRIPT V6", "Freecam: " .. tostring(freecamEnabled))
end

