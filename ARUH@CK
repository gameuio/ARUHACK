            wait(0.02)
        end
    end
    
    TweenService:Create(frame, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = targetPos}):Play()
    TweenService:Create(blur, TweenInfo.new(0.3), {Size = targetBlur}):Play()
    
    for i = 1, 3 do
        frameStroke1.Transparency = 1
        wait(0.05)
        frameStroke1.Transparency = 0
        wait(0.05)
    end
end

