    functionButton.Text = ""
    functionButton.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    functionButton.BorderSizePixel = 0
    functionButton.AutoButtonColor = false
    functionButton.Parent = containerFrame
    
    local buttonCorner = Instance.new("UICorner")
