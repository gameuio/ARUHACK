            if elapsedTime >= interval and not popupShown[index] then
                showDiscordPopup()
                popupShown[index] = true
                print("✅ Pop-up #" .. index .. " показан через " .. (interval/60) .. " минут!")
                SendWebhook("📢 Discord Pop-up #" .. index .. " показан пользователю")
            end
        end
    end
end)

-- ============== МУЗЫКА ==============

local function createBackgroundMusic()
    if not backgroundMusic then
        backgroundMusic = Instance.new("Sound")
        backgroundMusic.SoundId = MUSIC_ID
        backgroundMusic.Volume = musicVolume
        backgroundMusic.Looped = true
        backgroundMusic.Parent = screenGui
    end
end

local function playMusic()
    createBackgroundMusic()
    if musicEnabled then
        backgroundMusic:Play()
        Notify("ARUSCRIPT V5", "🎵 Music Started!")
    end
end

local function stopMusic()
    createBackgroundMusic()
    backgroundMusic:Stop()
    musicEnabled = false
    Notify("ARUSCRIPT V5", "🔇 Music Stopped!")
end

local function toggleMusic()
    musicEnabled = not musicEnabled
    if musicEnabled then
        playMusic()
    else
        stopMusic()
    end
end

local function setMusicVolume(vol)
    createBackgroundMusic()
    musicVolume = math.clamp(vol, 0, 1)
    backgroundMusic.Volume = musicVolume
    Config.Settings.MusicVolume = musicVolume
    SaveConfig()
    Notify("ARUSCRIPT V5", "🎵 Volume: " .. math.floor(musicVolume * 100) .. "%")
end

