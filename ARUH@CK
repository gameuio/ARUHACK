-- Save Config
local function SaveConfig()
    if writefile then
        pcall(function()
            Config.Settings.ESPColor = espColor
            writefile("AruScriptV5_Config.json", HttpService:JSONEncode(Config))
            Notify("Config System", "✅ Configuration Saved Successfully!")
            consoleLog("Config saved to file", Color3.fromRGB(0, 255, 0))
        end)
    else
        Notify("Config System", "❌ Executor doesn't support writefile")
    end
end

-- Load Config
local function LoadConfig()
    if isfile and readfile and isfile("AruScriptV5_Config.json") then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile("AruScriptV5_Config.json"))
            
            -- Загрузка настроек
            for key, value in pairs(decoded.Settings) do
                if Config.Settings[key] ~= nil then
                    Config.Settings[key] = value
                end
            end
            
            -- Применение загруженных настроек
            speed = Config.Settings.FlySpeed
            speedhackSpeed = Config.Settings.SpeedhackSpeed
            aimbotFOV = Config.Settings.AimbotFOV
            aimbotSmooth = Config.Settings.AimbotSmooth
            bhopPower = Config.Settings.BhopPower
            customWalkSpeed = Config.Settings.WalkSpeed
            customJumpPower = Config.Settings.JumpPower
            customGravity = Config.Settings.Gravity
            musicVolume = Config.Settings.MusicVolume
            musicTrackId = Config.Settings.MusicTrackId
            
            if decoded.Waypoints then
                waypointsList = decoded.Waypoints
            end
            
            Notify("Config System", "✅ Configuration Loaded Successfully!")
            consoleLog("Config loaded from file", Color3.fromRGB(0, 255, 0))
        end)
    else
        consoleLog("No config file found, using defaults", Color3.fromRGB(255, 255, 0))
    end
end

