    categoryButton.Parent = Sidebar
    
    local buttonCorner = Instance.new("UICorner")
    buttonCorner.CornerRadius = UDim.new(0, 10)
    buttonCorner.Parent = categoryButton
    
    local buttonGradient = Instance.new("UIGradient")
    buttonGradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(30, 30, 40)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(20, 20, 30))
    }
    buttonGradient.Rotation = 90
    buttonGradient.Parent = categoryButton
    
    local iconLabel = Instance.new("TextLabel")
    iconLabel.Size = UDim2.new(0, 35, 1, 0)
    iconLabel.Position = UDim2.new(0, 8, 0, 0)
    iconLabel.Text = iconText
    iconLabel.TextSize = 20
    iconLabel.TextColor3 = Color3.fromRGB(150, 150, 170)
    iconLabel.Font = Enum.Font.GothamBold
    iconLabel.BackgroundTransparency = 1
    iconLabel.Parent = categoryButton
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -50, 1, 0)
    textLabel.Position = UDim2.new(0, 43, 0, 0)
    textLabel.Text = categoryName
    textLabel.TextSize = 14
    textLabel.TextColor3 = Color3.fromRGB(150, 150, 170)
    textLabel.Font = Enum.Font.GothamBold
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.BackgroundTransparency = 1
    textLabel.Parent = categoryButton
    
    categoryButton.MouseEnter:Connect(function()
        if CurrentCategory ~= categoryName then
            TweenService:Create(categoryButton, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(35, 35, 45)
            }):Play()
        end
    end)
    
    categoryButton.MouseLeave:Connect(function()
        if CurrentCategory ~= categoryName then
            TweenService:Create(categoryButton, TweenInfo.new(0.2), {
                BackgroundColor3 = Color3.fromRGB(25, 25, 35)
            }):Play()
        end
    end)
    
    categoryButton.MouseButton1Click:Connect(function()
        print("📂 Переключение на категорию: " .. categoryName)
        
        -- Сброс всех кнопок категорий
        for _, button in pairs(Sidebar:GetChildren()) do
            if button:IsA("TextButton") then
                TweenService:Create(button, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(25, 25, 35)
                }):Play()
                
                for _, child in pairs(button:GetChildren()) do
                    if child:IsA("TextLabel") then
                        TweenService:Create(child, TweenInfo.new(0.2), {
                            TextColor3 = Color3.fromRGB(150, 150, 170)
                        }):Play()
                    end
                end
            end
        end
        
        -- Активация выбранной категории
        TweenService:Create(categoryButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(0, 255, 255)
        }):Play()
        
        TweenService:Create(iconLabel, TweenInfo.new(0.2), {
            TextColor3 = Color3.fromRGB(0, 0, 0)
        }):Play()
        
        TweenService:Create(textLabel, TweenInfo.new(0.2), {
            TextColor3 = Color3.fromRGB(0, 0, 0)
        }):Play()
        
        CurrentCategory = categoryName
        
        -- Показать/скрыть контейнеры
        for _, container in pairs(ContentFrame:GetChildren()) do
            if container:IsA("Frame") then
                container.Visible = (container.Name == categoryName .. "Container")
            end
        end
    end)
    
    CategoryButtons[categoryName] = categoryButton
    
