local function CreateTextBox(category, name, placeholder, order)
    local container = Instance.new("Frame")
    container.Size = UDim2.new(1, 0, 0, 50)
    container.BackgroundTransparency = 1
    container.LayoutOrder = order
    container.Parent = GUI.Categories[category]
    
    local box = Instance.new("TextBox")
    box.Size = UDim2.new(1, 0, 1, 0)
    box.PlaceholderText = placeholder
    box.Text = ""
    box.TextSize = 14
    box.TextColor3 = Color3.fromRGB(255, 255, 255)
    box.PlaceholderColor3 = Color3.fromRGB(120, 120, 140)
    box.Font = Enum.Font.GothamMedium
    box.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    box.BorderSizePixel = 0
    box.ClearTextOnFocus = false
    box.Parent = container
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 12)
    corner.Parent = box
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(50, 50, 70)
    stroke.Thickness = 1
    stroke.Transparency = 0.5
    stroke.Parent = box
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 18)
    padding.PaddingRight = UDim.new(0, 18)
    padding.Parent = box
    
    box.Focused:Connect(function()
        Services.TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(0, 255, 255), Transparency = 0, Thickness = 2}):Play()
    end)
    
    box.FocusLost:Connect(function()
        Services.TweenService:Create(stroke, TweenInfo.new(0.2), {Color = Color3.fromRGB(50, 50, 70), Transparency = 0.5, Thickness = 1}):Play()
    end)
    
    GUI.Buttons[name] = box
    return box
end

local function UpdateButtonStatus(name, enabled)
    if GUI.Buttons[name] and GUI.Buttons[name].Status then
        local status = GUI.Buttons[name].Status
        local stroke = GUI.Buttons[name].Stroke
        status.Text = enabled and "ON" or "OFF"
        Services.TweenService:Create(status, TweenInfo.new(0.3), {
            TextColor3 = enabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100),
            BackgroundColor3 = enabled and Color3.fromRGB(20, 80, 20) or Color3.fromRGB(50, 20, 20)
        }):Play()
        Services.TweenService:Create(stroke, TweenInfo.new(0.3), {
            Color = enabled and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 50, 50)
        }):Play()
    end
end

