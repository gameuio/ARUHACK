local function toggleFly()
    STATE.flying = not STATE.flying
    flyBtn.Text = STATE.flying and "⟨ DISABLE FLY ⟩" or "⟨ FLY MODE ⟩"
    
    if STATE.flying then
        local char = Players.LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                DATA.bodyVelocity = Instance.new("BodyVelocity")
                DATA.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                DATA.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                DATA.bodyVelocity.Parent = hrp
                
                DATA.bodyGyro = Instance.new("BodyGyro")
                DATA.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
                DATA.bodyGyro.CFrame = hrp.CFrame
                DATA.bodyGyro.Parent = hrp
                
                DATA.connections.fly = RunService.Heartbeat:Connect(function()
                    if not STATE.flying then return end
                    local camera = workspace.CurrentCamera
                    local moveDir = Vector3.new(0, 0, 0)
                    
                    if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + camera.CFrame.LookVector * STATE.speed end
                    if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - camera.CFrame.LookVector * STATE.speed end
                    if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - camera.CFrame.RightVector * STATE.speed end
                    if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + camera.CFrame.RightVector * STATE.speed end
                    if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir = moveDir + Vector3.new(0, STATE.speed, 0) end
                    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0, STATE.speed, 0) end
                    
                    if DATA.bodyVelocity then DATA.bodyVelocity.Velocity = moveDir end
                    if DATA.bodyGyro then DATA.bodyGyro.CFrame = camera.CFrame end
                end)
            end
        end
    else
        if DATA.connections.fly then DATA.connections.fly:Disconnect() end
        if DATA.bodyVelocity then DATA.bodyVelocity:Destroy() end
        if DATA.bodyGyro then DATA.bodyGyro:Destroy() end
    end
    
    Notify("ARUSCRIPT V5", "Fly: " .. tostring(STATE.flying))
end

