-- Функция воспроизведения музыки
local function playMusic()
    if musicEnabled then
        if currentSong == nil or not currentSong.Parent then
            currentSong = Instance.new("Sound")
            currentSong.Name = "BackgroundMusic"
            currentSong.Volume = musicVolume
            currentSong.Looped = true -- БЕСКОНЕЧНЫЙ ПОВТОР
            currentSong.Parent = workspace
        end
        
        currentSong.SoundId = musicTrackId
        
        if not currentSong.Playing then
            currentSong:Play()
            consoleLog("🎵 Now playing: " .. musicTrackId, Color3.fromRGB(0, 200, 255))
        end
    end
end

-- Функция включения/выключения музыки
local function toggleMusic()
    musicEnabled = not musicEnabled
    
    if musicEnabled then
        playMusic()
        
        -- Плавное увеличение громкости (fade in)
        if fadeConnection then fadeConnection:Disconnect() end
        
        currentSong.Volume = 0
        local targetVolume = musicVolume
        local fadeInTime = 2
        local startTime = tick()
        
        fadeConnection = RunService.Heartbeat:Connect(function()
            local elapsed = tick() - startTime
            local progress = math.min(elapsed / fadeInTime, 1)
            currentSong.Volume = targetVolume * progress
            
            if progress >= 1 then
                fadeConnection:Disconnect()
            end
        end)
        
        consoleLog("🎵 Music: ENABLED (Fade In)", Color3.fromRGB(0, 255, 100))
        Notify("Music Player", "🎵 Music Enabled - Fading In...")
    else
        -- Плавное уменьшение громкости (fade out)
        if fadeConnection then fadeConnection:Disconnect() end
        
        local fadeOutTime = 3
        local startTime = tick()
        local startVolume = currentSong.Volume
        
        fadeConnection = RunService.Heartbeat:Connect(function()
            local elapsed = tick() - startTime
            local progress = math.min(elapsed / fadeOutTime, 1)
            currentSong.Volume = startVolume * (1 - progress)
            
            if progress >= 1 then
                currentSong:Stop()
                fadeConnection:Disconnect()
                consoleLog("🎵 Music: DISABLED (Fade Out Complete)", Color3.fromRGB(255, 100, 0))
            end
        end)
        
        Notify("Music Player", "🎵 Music Disabled - Fading Out...")
    end
    
    SendWebhook("🎵 Music: " .. tostring(musicEnabled))
end

-- Функция изменения громкости
local function setMusicVolume(volume)
    if volume >= 0 and volume <= 1 then
        musicVolume = volume
        if currentSong then
            currentSong.Volume = volume
        end
        Config.Settings.MusicVolume = volume
        consoleLog("🔊 Volume: " .. math.floor(volume * 100) .. "%", Color3.fromRGB(100, 255, 100))
    end
end

-- Функция изменения ID трека
local function setMusicTrackId(id)
    musicTrackId = id
    Config.Settings.MusicTrackId = id
    SaveConfig()
    
    if musicEnabled and currentSong then
        currentSong:Stop()
        currentSong.SoundId = id
        currentSong:Play()
        consoleLog("🎵 Track changed to: " .. id, Color3.fromRGB(0, 200, 255))
        Notify("Music Player", "Track Changed!")
    else
        consoleLog("🎵 Track ID saved (enable music to play)", Color3.fromRGB(100, 200, 255))
    end
end

