    valueLabel.Size = UDim2.new(0, 60, 0, 25)
    valueLabel.Position = UDim2.new(1, -70, 0, 10)
    valueLabel.Text = tostring(default)
    valueLabel.TextSize = 14
    valueLabel.TextColor3 = Color3.fromRGB(0, 255, 255)
    valueLabel.Font = Enum.Font.GothamBlack
    valueLabel.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    valueLabel.BorderSizePixel = 0
    
    local valueLabelCorner = Instance.new("UICorner", valueLabel)
    valueLabelCorner.CornerRadius = UDim.new(0, 8)
    
    local sliderBack = Instance.new("Frame", frame)
    sliderBack.Size = UDim2.new(1, -40, 0, 8)
    sliderBack.Position = UDim2.new(0, 20, 0, 48)
    sliderBack.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    sliderBack.BorderSizePixel = 0
    
    local sliderBackCorner = Instance.new("UICorner", sliderBack)
    sliderBackCorner.CornerRadius = UDim.new(1, 0)
    
    local sliderFill = Instance.new("Frame", sliderBack)
    sliderFill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    sliderFill.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    sliderFill.BorderSizePixel = 0
    
    local sliderFillCorner = Instance.new("UICorner", sliderFill)
    sliderFillCorner.CornerRadius = UDim.new(1, 0)
    
    local sliderKnob = Instance.new("Frame", sliderBack)
    sliderKnob.Size = UDim2.new(0, 18, 0, 18)
    sliderKnob.Position = UDim2.new((default - min) / (max - min), -9, 0.5, -9)
    sliderKnob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    sliderKnob.BorderSizePixel = 0
    
    local sliderKnobCorner = Instance.new("UICorner", sliderKnob)
    sliderKnobCorner.CornerRadius = UDim.new(1, 0)
    
    local sliderKnobStroke = Instance.new("UIStroke", sliderKnob)
    sliderKnobStroke.Thickness = 3
    sliderKnobStroke.Color = Color3.fromRGB(0, 255, 255)
    
    local dragging = false
    
    local function updateSlider(input)
        local pos = math.clamp((input.Position.X - sliderBack.AbsolutePosition.X) / sliderBack.AbsoluteSize.X, 0, 1)
        local value = math.floor(min + (max - min) * pos)
        
        sliderFill.Size = UDim2.new(pos, 0, 1, 0)
        sliderKnob.Position = UDim2.new(pos, -9, 0.5, -9)
        valueLabel.Text = tostring(value)
        
        if callback then callback(value) end
    end
    
    sliderBack.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            updateSlider(input)
        end
    end)
    
    sliderBack.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateSlider(input)
        end
    end)
    
    Data.sliders[name] = {
        Frame = frame,
        Fill = sliderFill,
        Knob = sliderKnob,
        ValueLabel = valueLabel,
        Min = min,
        Max = max,
        Callback = callback
    }
    
    return frame
end

local function UpdateButton(name, enabled)
    if GUI.Buttons[name] and GUI.Buttons[name].Status then
        local status = GUI.Buttons[name].Status
        local stroke = GUI.Buttons[name].Stroke
        status.Text = enabled and "ON" or "OFF"
        TS:Create(status, TweenInfo.new(0.3), {
            TextColor3 = enabled and Color3.fromRGB(100, 255, 100) or Color3.fromRGB(255, 100, 100),
            BackgroundColor3 = enabled and Color3.fromRGB(25, 80, 25) or Color3.fromRGB(60, 25, 25)
        }):Play()
        TS:Create(stroke, TweenInfo.new(0.3), {
            Color = enabled and Color3.fromRGB(50, 255, 50) or Color3.fromRGB(255, 60, 60)
        }):Play()
    end
end

