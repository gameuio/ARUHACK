-- 1. ESP
local function ToggleESP()
    State.esp = not State.esp
    UpdateButton("ESP", State.esp)
    
    if State.esp then
        for _, p in pairs(Plrs:GetPlayers()) do
            if p ~= LP and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r and not r:FindFirstChild("ESP_Box") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP_Box"
                    box.Size = Vector3.new(4, 6, 1)
                    box.Adornee = r
                    box.Color3 = Color3.fromRGB(0, 255, 0)
                    box.AlwaysOnTop = true
                    box.Transparency = 0.5
                    box.ZIndex = 10
                    box.Parent = r
                end
            end
        end
        
        Data.connections.espUpdate = Plrs.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function(c)
                wait(0.5)
                if State.esp and c:FindFirstChild("HumanoidRootPart") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP_Box"
                    box.Size = Vector3.new(4, 6, 1)
                    box.Adornee = c.HumanoidRootPart
                    box.Color3 = Color3.fromRGB(0, 255, 0)
                    box.AlwaysOnTop = true
                    box.Transparency = 0.5
                    box.ZIndex = 10
                    box.Parent = c.HumanoidRootPart
                end
            end)
        end)
    else
        ClearConnection("espUpdate")
        for _, p in pairs(Plrs:GetPlayers()) do
            if p.Character then
                for _, v in pairs(p.Character:GetDescendants()) do
                    if v.Name == "ESP_Box" then v:Destroy() end
                end
            end
        end
    end
    Notify("ESP", State.esp and "Включен" or "Выключен")
end

-- 2. FLY
local function ToggleFly()
    State.fly = not State.fly
    UpdateButton("Fly", State.fly)
    
    if State.fly then
        local root = GetRoot()
        if not root then return end
        
        local bg = Instance.new("BodyGyro", root)
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.CFrame = root.CFrame
        
        local bv = Instance.new("BodyVelocity", root)
        bv.Velocity = Vector3.new(0, 0, 0)
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        
        Data.connections.flyLoop = Run.Heartbeat:Connect(function()
            if not State.fly or not root or not root.Parent then
                ClearConnection("flyLoop")
                if bg then bg:Destroy() end
                if bv then bv:Destroy() end
                return
            end
            
            bg.CFrame = Cam.CFrame
            local velocity = Vector3.new(0, 0, 0)
            
            if UIS:IsKeyDown(Enum.KeyCode.W) then
                velocity = velocity + Cam.CFrame.LookVector * State.flySpeed
            end
            if UIS:IsKeyDown(Enum.KeyCode.S) then
                velocity = velocity - Cam.CFrame.LookVector * State.flySpeed
            end
            if UIS:IsKeyDown(Enum.KeyCode.D) then
                velocity = velocity + Cam.CFrame.RightVector * State.flySpeed
            end
            if UIS:IsKeyDown(Enum.KeyCode.A) then
                velocity = velocity - Cam.CFrame.RightVector * State.flySpeed
            end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then
                velocity = velocity + Vector3.new(0, State.flySpeed, 0)
            end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then
                velocity = velocity - Vector3.new(0, State.flySpeed, 0)
            end
            
            bv.Velocity = velocity
        end)
        Notify("FLY", "Включен (WASD + Space/Shift)")
    else
        ClearConnection("flyLoop")
        local root = GetRoot()
        if root then
            for _, v in pairs(root:GetChildren()) do
                if v:IsA("BodyGyro") or v:IsA("BodyVelocity") then
                    v:Destroy()
                end
            end
        end
        Notify("FLY", "Выключен")
    end
end

