-- 1. ESP
local function ToggleESP()
    State.esp = not State.esp
    UpdateButton("ESP", State.esp)
    if State.esp then
        for _, p in pairs(Plrs:GetPlayers()) do
            if p ~= LP and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r and not r:FindFirstChild("ESP_Box") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP_Box"
                    box.Size = Vector3.new(4, 6, 1)
                    box.Adornee = r
                    box.Color3 = Color3.fromRGB(0, 255, 0)
                    box.AlwaysOnTop = true
                    box.Transparency = 0.5
                    box.ZIndex = 10
                    box.Parent = r
                end
            end
        end
        Data.connections.espUpdate = Plrs.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function(c)
                wait(0.5)
                if State.esp and c:FindFirstChild("HumanoidRootPart") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESP_Box"
                    box.Size = Vector3.new(4, 6, 1)
                    box.Adornee = c.HumanoidRootPart
                    box.Color3 = Color3.fromRGB(0, 255, 0)
                    box.AlwaysOnTop = true
                    box.Transparency = 0.5
                    box.ZIndex = 10
                    box.Parent = c.HumanoidRootPart
                end
            end)
        end)
    else
        ClearConnection("espUpdate")
        for _, p in pairs(Plrs:GetPlayers()) do
            if p.Character then
                for _, v in pairs(p.Character:GetDescendants()) do
                    if v.Name == "ESP_Box" then v:Destroy() end
                end
            end
        end
    end
