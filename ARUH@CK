UIS.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        if State.show then
            State.show = false
            TS:Create(GUI.Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0), Position = UDim2.new(0.5, 0, 0.5, 0)
            }):Play()
            wait(0.5)
            GUI.Main.Visible = false
            GUI.Toggle.Visible = true
        else
            State.show = true
            GUI.Toggle.Visible = false
            GUI.Main.Visible = true
            GUI.Main.Size = UDim2.new(0, 0, 0, 0)
            GUI.Main.Position = UDim2.new(0.5, 0, 0.5, 0)
            TS:Create(GUI.Main, TweenInfo.new(0.6, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 950, 0, 680),
                Position = UDim2.new(0.5, -475, 0.5, -340)
            }):Play()
        end
    end
end)

