-- ============== ESP ==============

local function clearESP()
    for player, objects in pairs(espObjects) do
        for _, obj in pairs(objects) do
            pcall(function() obj:Remove() end)
        end
        espObjects[player] = nil
    end
end

local function createESPForPlayer(player)
    if player == LocalPlayer then return end
    if not player.Character then return end

    local char = player.Character
    local hrp  = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head")
    if not hrp then return end

    local objs = {}

    -- Box
    if espBoxesEnabled then
        local box = Instance.new("BoxHandleAdornment")
        box.Name = "ESPBox"
        box.Size = Vector3.new(4, 6, 1)
        box.Adornee = hrp
        box.Color3 = espColor
        box.AlwaysOnTop = true
        box.ZIndex = 5
        box.Transparency = 0.4
        box.Parent = hrp
        table.insert(objs, box)
    end

    -- Имя
    if espNameEnabled and head then
        local bb = Instance.new("BillboardGui")
        bb.Name = "ESPName"
        bb.Size = UDim2.new(0, 120, 0, 30)
        bb.StudsOffset = Vector3.new(0, 3.5, 0)
        bb.Adornee = head
        bb.AlwaysOnTop = true
        bb.Parent = head

        local lbl = Instance.new("TextLabel", bb)
        lbl.Size = UDim2.new(1, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = player.Name
        lbl.TextColor3 = espColor
        lbl.Font = Enum.Font.Code
        lbl.TextScaled = true
        table.insert(objs, bb)
    end

    -- Здоровье
    if espHealthEnabled and head then
        local bb2 = Instance.new("BillboardGui")
        bb2.Name = "ESPHealth"
        bb2.Size = UDim2.new(0, 80, 0, 20)
        bb2.StudsOffset = Vector3.new(0, 5, 0)
        bb2.Adornee = head
        bb2.AlwaysOnTop = true
        bb2.Parent = head

        local hum = char:FindFirstChildOfClass("Humanoid")
        local lbl2 = Instance.new("TextLabel", bb2)
        lbl2.Size = UDim2.new(1, 0, 1, 0)
        lbl2.BackgroundTransparency = 1
        lbl2.Text = hum and math.floor(hum.Health) .. " HP" or "? HP"
        lbl2.TextColor3 = Color3.fromRGB(0, 255, 100)
        lbl2.Font = Enum.Font.Code
        lbl2.TextScaled = true
        table.insert(objs, bb2)
    end

    -- Дистанция
    if espDistanceEnabled then
        local myHRP = getHRP()
        if myHRP and head then
            local dist = math.floor((myHRP.Position - hrp.Position).Magnitude)
            local bb3 = Instance.new("BillboardGui")
            bb3.Name = "ESPDist"
            bb3.Size = UDim2.new(0, 80, 0, 20)
            bb3.StudsOffset = Vector3.new(0, -3, 0)
            bb3.Adornee = hrp
            bb3.AlwaysOnTop = true
            bb3.Parent = hrp

            local lbl3 = Instance.new("TextLabel", bb3)
            lbl3.Size = UDim2.new(1, 0, 1, 0)
            lbl3.BackgroundTransparency = 1
            lbl3.Text = dist .. "m"
            lbl3.TextColor3 = Color3.fromRGB(255, 200, 0)
            lbl3.Font = Enum.Font.Code
            lbl3.TextScaled = true
            table.insert(objs, bb3)
        end
    end

    espObjects[player] = objs
end

local function toggleESP()
    espEnabled = not espEnabled

    if espEnabled then
        espBoxesEnabled   = true
        espNameEnabled    = true
        espHealthEnabled  = true
        espDistanceEnabled= true

        for _, p in pairs(Players:GetPlayers()) do
            createESPForPlayer(p)
        end

        connections.espAdded = Players.PlayerAdded:Connect(function(p)
            p.CharacterAdded:Connect(function()
                wait(1)
                createESPForPlayer(p)
            end)
        end)

        connections.espUpdate = RunService.Heartbeat:Connect(function()
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        local dist = espObjects[p] and true
                        if not dist then createESPForPlayer(p) end

                        -- Обновляем дистанцию
                        local myHRP = getHRP()
                        if myHRP then
                            local distBB = hrp:FindFirstChild("ESPDist")
                            if distBB then
                                local lbl = distBB:FindFirstChildOfClass("TextLabel")
                                if lbl then
                                    lbl.Text = math.floor((myHRP.Position - hrp.Position).Magnitude) .. "m"
                                end
                            end
                        end

                        -- Обновляем HP
                        local head = p.Character:FindFirstChild("Head")
                        local hum  = p.Character:FindFirstChildOfClass("Humanoid")
                        if head and hum then
                            local bb2 = head:FindFirstChild("ESPHealth")
                            if bb2 then
                                local lbl = bb2:FindFirstChildOfClass("TextLabel")
                                if lbl then lbl.Text = math.floor(hum.Health) .. " HP" end
                            end
                        end
                    end
                end
            end
        end)
    else
        clearESP()
        if connections.espAdded  then connections.espAdded:Disconnect() end
        if connections.espUpdate then connections.espUpdate:Disconnect() end
    end

    SendWebhook("👁️ ESP: **" .. tostring(espEnabled) .. "**")
    Notify("ARUSCRIPT V6", "ESP: " .. tostring(espEnabled))
    if _G.AruConsoleLog then
        _G.AruConsoleLog("ESP: " .. tostring(espEnabled),
            espEnabled and Color3.fromRGB(0,255,0) or Color3.fromRGB(255,0,0))
    end
end
_G.AruToggleESP = function(arg)
    if arg == "on"  and not espEnabled then toggleESP()
    elseif arg == "off" and espEnabled then toggleESP()
    else toggleESP() end
end

-- Смена цвета ESP
local function changeESPColor()
    colorIndex = (colorIndex % #colors) + 1
    espColor = colors[colorIndex]
    for _, objs in pairs(espObjects) do
        for _, obj in pairs(objs) do
            pcall(function()
                if obj:IsA("BoxHandleAdornment") then
                    obj.Color3 = espColor
                end
            end)
        end
    end
    Notify("ARUSCRIPT V6", "ESP Color changed!")
end

