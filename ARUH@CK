-- Функция создания хакерской кнопки
local function createHackerButton(name, text, layoutOrder)
    local buttonContainer = Instance.new("Frame")
    buttonContainer.Name = name .. "Container"
    buttonContainer.Size = UDim2.new(1, 0, 0, 50)
    buttonContainer.BackgroundTransparency = 1
    buttonContainer.LayoutOrder = layoutOrder
    buttonContainer.Parent = contentFrame
    
    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Text = "> " .. text .. " <"
    button.TextScaled = true
    button.TextColor3 = Color3.fromRGB(0, 255, 0)
    button.Font = Enum.Font.Code
    button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    button.BackgroundTransparency = 0.5
    button.BorderSizePixel = 0
    button.AutoButtonColor = false
    button.Parent = buttonContainer
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = button
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(0, 255, 0)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.3
    stroke.Parent = button
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 15)
    padding.PaddingRight = UDim.new(0, 15)
    padding.Parent = button
    
    -- Hex паттерн на фоне кнопки
    local hexPattern = Instance.new("TextLabel")
    hexPattern.Size = UDim2.new(1, 0, 1, 0)
    hexPattern.Position = UDim2.new(0, 0, 0, 0)
    hexPattern.Text = "0x1A2B3C"
    hexPattern.TextSize = 10
    hexPattern.TextColor3 = Color3.fromRGB(0, 100, 0)
    hexPattern.Font = Enum.Font.Code
    hexPattern.BackgroundTransparency = 1
    hexPattern.TextTransparency = 0.8
    hexPattern.ZIndex = 1
    hexPattern.Parent = button
    
    -- Эффект глитча на hover
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(0, 50, 0)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.1), {Transparency = 0, Thickness = 2}):Play()
        
        -- Глитч эффект
        for i = 1, 3 do
            button.Position = UDim2.new(0, math.random(-2, 2), 0, 0)
            wait(0.05)
        end
        button.Position = UDim2.new(0, 0, 0, 0)
    end)
    
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 0, 0)}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.3, Thickness = 1.5}):Play()
    end)
    
    return button
end

-- Функция создания хакерского текстового поля
local function createHackerTextBox(name, placeholderText, layoutOrder)
