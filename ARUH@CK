local function createHackerButton(name, text, layoutOrder)
    local buttonContainer = Instance.new("Frame")
    buttonContainer.Name = name .. "Container"
    buttonContainer.Size = UDim2.new(1, 0, 0, 45)
    buttonContainer.BackgroundTransparency = 1
    buttonContainer.LayoutOrder = layoutOrder
    buttonContainer.Parent = contentFrame
    
    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Text = "⟨ " .. text .. " ⟩"
    button.TextScaled = true
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.Code
    button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    button.BackgroundTransparency = 0.4
    button.BorderSizePixel = 0
    button.AutoButtonColor = false
    button.Parent = buttonContainer
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = button
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 0, 0)
    stroke.Thickness = 2
    stroke.Transparency = 0.2
    stroke.Parent = button
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 15)
    padding.PaddingRight = UDim.new(0, 15)
    padding.Parent = button
    
    local hexPattern = Instance.new("TextLabel")
    hexPattern.Size = UDim2.new(1, 0, 1, 0)
    hexPattern.Position = UDim2.new(0, 0, 0, 0)
    hexPattern.Text = "0x" .. string.format("%X", math.random(1000000, 9999999))
    hexPattern.TextSize = 10
    hexPattern.TextColor3 = Color3.fromRGB(100, 100, 100)
    hexPattern.Font = Enum.Font.Code
    hexPattern.BackgroundTransparency = 1
    hexPattern.TextTransparency = 0.8
    hexPattern.ZIndex = 1
    hexPattern.Parent = button
    
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {BackgroundTransparency = 0.2}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.1), {Transparency = 0, Thickness = 3}):Play()
        
        for i = 1, 3 do
            button.Position = UDim2.new(0, math.random(-2, 2), 0, 0)
            wait(0.05)
        end
        button.Position = UDim2.new(0, 0, 0, 0)
    end)
    
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundTransparency = 0.4}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.2, Thickness = 2}):Play()
    end)
    
    return button
end

