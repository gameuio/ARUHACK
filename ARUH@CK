-- Функция радужного цвета
local function getRainbowColor()
    hue = hue + rainbowSpeed / 100
    if hue >= 1 then hue = 0 end
    return Color3.fromHSV(hue, 1, 1)
end

-- Save Config
local function SaveConfig()
    if writefile then
        pcall(function()
            writefile("AruScriptV5_Config.json", HttpService:JSONEncode(Config))
            print("✅ Config Saved!")
        end)
    end
end

-- Load Config
local function LoadConfig()
    if isfile and readfile and isfile("AruScriptV5_Config.json") then
        pcall(function()
            Config = HttpService:JSONDecode(readfile("AruScriptV5_Config.json"))
            print("✅ Config Loaded!")
        end)
    end
end

-- Discord Webhook
local function SendWebhook(message)
    if Config.DiscordWebhook ~= "" and request then
        pcall(function()
            request({
                Url = Config.DiscordWebhook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    content = "",
                    embeds = {{
                        title = "🎮 ARUSCRIPT V5",
                        description = message,
                        color = 65280,
                        footer = {text = Players.LocalPlayer.Name .. " | " .. os.date("%X")}
                    }}
                })
            })
        end)
    end
end

