    if walkSpeedEnabled  then local h=getHumanoid(); if h then h.WalkSpeed=customWalkSpeed end end
    if jumpPowerEnabled  then local h=getHumanoid(); if h then h.JumpPower=customJumpPower end end
    if gravityEnabled    then Workspace.Gravity = customGravity end
    if speedhackEnabled  then local h=getHumanoid(); if h then h.WalkSpeed=speedhackSpeed end end
    if espEnabled        then
        clearESP()
        for _, p in pairs(Players:GetPlayers()) do
            createESPForPlayer(p)
        end
    end
    if _G.AruConsoleLog then
        _G.AruConsoleLog("Character respawned — features restored", Color3.fromRGB(0,255,100))
    end
end

