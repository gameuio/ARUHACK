-- 1. ESP
local function TgESP()
    S.esp = not S.esp
    Upd("ESP", S.esp)
    if S.esp then
        for _, p in pairs(Serv.Plr:GetPlayers()) do
            if p ~= LP and p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r and not r:FindFirstChild("ESPBox") then
                    local box = Instance.new("BoxHandleAdornment")
                    box.Name = "ESPBox"
                    box.Size = Vector3.new(4, 7, 1)
                    box.Adornee = r
                    box.Color3 = Color3.fromRGB(0, 255, 0)
                    box.AlwaysOnTop = true
                    box.Transparency = 0.5
                    box.Parent = r
                end
            end
        end
    else
        for _, p in pairs(Serv.Plr:GetPlayers()) do
            if p.Character then
                for _, v in pairs(p.Character:GetDescendants()) do
                    if v:IsA("BoxHandleAdornment") and v.Name == "ESPBox" then v:Destroy() end
                end
            end
        end
    end
    U.Notify("ESP", tostring(S.esp))
end

-- 2. FLY (ПОЛНОСТЬЮ РАБОЧИЙ)
local function TgFly()
    S.fly = not S.fly
    Upd("Fly", S.fly)
    if S.fly then
        local r = U.Root()
        if r then
            D.bv = Instance.new("BodyVelocity")
            D.bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            D.bv.Velocity = Vector3.new(0, 0, 0)
            D.bv.Parent = r
            D.bg = Instance.new("BodyGyro")
            D.bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            D.bg.CFrame = r.CFrame
            D.bg.Parent = r
            D.con.fly = Serv.Run.Heartbeat:Connect(function()
                if not S.fly then return end
                local md = Vector3.new(0, 0, 0)
                if Serv.UIS:IsKeyDown(Enum.KeyCode.W) then md = md + Cam.CFrame.LookVector end
                if Serv.UIS:IsKeyDown(Enum.KeyCode.S) then md = md - Cam.CFrame.LookVector end
                if Serv.UIS:IsKeyDown(Enum.KeyCode.A) then md = md - Cam.CFrame.RightVector end
                if Serv.UIS:IsKeyDown(Enum.KeyCode.D) then md = md + Cam.CFrame.RightVector end
                if Serv.UIS:IsKeyDown(Enum.KeyCode.Space) then md = md + Vector3.new(0, 1, 0) end
                if Serv.UIS:IsKeyDown(Enum.KeyCode.LeftControl) then md = md - Vector3.new(0, 1, 0) end
                if D.bv then D.bv.Velocity = md * S.flyS end
                if D.bg then D.bg.CFrame = Cam.CFrame end
            end)
        end
    else
        if D.con.fly then D.con.fly:Disconnect() end
        if D.bv then D.bv:Destroy() D.bv = nil end
        if D.bg then D.bg:Destroy() D.bg = nil end
    end
    U.Notify("FLY", tostring(S.fly))
end

