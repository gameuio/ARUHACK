    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {BackgroundTransparency = 0.35}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.15), {Thickness = 2, Transparency = 0.2}):Play()
    end)

    return btn, stroke
end

