    textBox.PlaceholderText = "// " .. placeholderText .. " //"
    textBox.Text = ""
    textBox.TextScaled = true
    textBox.TextColor3 = Color3.fromRGB(0, 255, 0)
    textBox.PlaceholderColor3 = Color3.fromRGB(0, 150, 0)
    textBox.Font = Enum.Font.Code
    textBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    textBox.BackgroundTransparency = 0.5
    textBox.BorderSizePixel = 0
    textBox.ClearTextOnFocus = false
    textBox.Parent = textBoxContainer
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = textBox
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(0, 255, 0)
    stroke.Thickness = 1.5
    stroke.Transparency = 0.5
    stroke.Parent = textBox
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 15)
    padding.PaddingRight = UDim.new(0, 15)
    padding.Parent = textBox
    
    -- Мигающий курсор эффект
    local cursor = Instance.new("Frame")
    cursor.Name = "Cursor"
    cursor.Size = UDim2.new(0, 2, 0.6, 0)
    cursor.Position = UDim2.new(0, 15, 0.2, 0)
    cursor.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    cursor.BorderSizePixel = 0
    cursor.Visible = false
    cursor.Parent = textBox
    
    textBox.Focused:Connect(function()
        cursor.Visible = true
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0, Thickness = 2}):Play()
        
        -- Мигающий курсор
        spawn(function()
            while textBox:IsFocused() do
                cursor.Visible = not cursor.Visible
                wait(0.5)
            end
        end)
    end)
    
    textBox.FocusLost:Connect(function()
        cursor.Visible = false
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.5, Thickness = 1.5}):Play()
    end)
    
    return textBox
end

