local Utils = {}

function Utils.Rainbow()
    Data.hue = Data.hue + State.rainbowSpeed / 100
    if Data.hue >= 1 then Data.hue = 0 end
    return Color3.fromHSV(Data.hue, 1, 1)
end

function Utils.SaveConfig()
    if writefile then
        pcall(function()
            writefile("AruScriptV5.json", Services.HttpService:JSONEncode({
                Settings = State,
                Waypoints = Data.waypoints
            }))
        end)
    end
end

function Utils.LoadConfig()
    if isfile and readfile and isfile("AruScriptV5.json") then
        pcall(function()
            local loaded = Services.HttpService:JSONDecode(readfile("AruScriptV5.json"))
            for k, v in pairs(loaded.Settings or {}) do State[k] = v end
            Data.waypoints = loaded.Waypoints or {}
        end)
    end
end

function Utils.Webhook(msg)
    if Settings.Webhook ~= "" then
        pcall(function()
            local req = syn and syn.request or request
            if req then
                req({
                    Url = Settings.Webhook,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = Services.HttpService:JSONEncode({
                        embeds = {{
                            title = "🎮 ARUSCRIPT V5",
                            description = msg,
                            color = 65280,
                            footer = {text = Services.Players.LocalPlayer.Name .. " | " .. os.date("%X")}
                        }}
                    })
                })
            end
        end)
    end
end

function Utils.Notify(title, text, dur)
    pcall(function()
        Services.StarterGui:SetCore("SendNotification", {
            Title = title or "ARUSCRIPT V5",
            Text = text or "",
            Duration = dur or 3
        })
    end)
    print("🔔 " .. title .. " | " .. text)
end

function Utils.CopyClipboard(text)
    if setclipboard then
        setclipboard(text)
        return true
    end
    return false
end

