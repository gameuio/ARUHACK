local function GetRainbowColor()
    States.rainbowHue = States.rainbowHue + 0.005
    if States.rainbowHue >= 1 then 
        States.rainbowHue = 0 
    end
    return Color3.fromHSV(States.rainbowHue, 1, 1)
end

local function GetCharacter()
    return LocalPlayer.Character
end

local function GetHumanoid()
    local character = GetCharacter()
    if character then
        return character:FindFirstChildOfClass("Humanoid")
    end
    return nil
end

local function GetRootPart()
    local character = GetCharacter()
    if character then
        return character:FindFirstChild("HumanoidRootPart")
    end
    return nil
end

local function SendNotification(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title or "ARUSCRIPT V5",
            Text = text or "",
            Duration = duration or 3
        })
    end)
    print("🔔 " .. title .. ": " .. text)
end

local function SendWebhook(message)
    if Settings.Webhook ~= "" then
        pcall(function()
            local request = syn and syn.request or request or http_request or http.request
            if request then
                request({
                    Url = Settings.Webhook,
                    Method = "POST",
                    Headers = {
                        ["Content-Type"] = "application/json"
                    },
                    Body = HttpService:JSONEncode({
                        embeds = {{
                            title = "🎮 ARUSCRIPT V5",
                            description = message,
                            color = 65280,
                            timestamp = os.date("!%Y-%m-%dT%H:%M:%S"),
                            footer = {
                                text = LocalPlayer.Name
                            }
                        }}
                    })
                })
            end
        end)
    end
end

