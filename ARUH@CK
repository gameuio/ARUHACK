local function buildRadar()
    radarFrame = Instance.new("Frame")
    radarFrame.Name = "AruRadar"
    radarFrame.Size = UDim2.new(0, 230, 0, 230)
    radarFrame.Position = UDim2.new(1, -250, 0, 20)
    radarFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    radarFrame.BackgroundTransparency = 0.25
    radarFrame.BorderSizePixel = 0
    radarFrame.Visible = false
    radarFrame.Parent = screenGui

    Instance.new("UICorner", radarFrame).CornerRadius = UDim.new(1, 0)

    local rs = Instance.new("UIStroke", radarFrame)
    rs.Color = Color3.fromRGB(255, 0, 0)
    rs.Thickness = 3

    -- Крестик посередине
    for _, axis in pairs({"H", "V"}) do
        local line = Instance.new("Frame", radarFrame)
        line.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
        line.BackgroundTransparency = 0.5
        line.BorderSizePixel = 0
        if axis == "H" then
            line.Size = UDim2.new(1, 0, 0, 1)
            line.Position = UDim2.new(0, 0, 0.5, 0)
        else
            line.Size = UDim2.new(0, 1, 1, 0)
            line.Position = UDim2.new(0.5, 0, 0, 0)
        end
    end

    -- Точка игрока
    local center = Instance.new("Frame", radarFrame)
    center.Size = UDim2.new(0, 8, 0, 8)
    center.Position = UDim2.new(0.5, -4, 0.5, -4)
    center.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
    center.BorderSizePixel = 0
    Instance.new("UICorner", center).CornerRadius = UDim.new(1, 0)

    local lbl = Instance.new("TextLabel", radarFrame)
    lbl.Size = UDim2.new(1, 0, 0, 22)
    lbl.Position = UDim2.new(0, 0, 0, -28)
    lbl.Text = "⟨ RADAR ⟩"
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    lbl.Font = Enum.Font.Code
    lbl.TextSize = 15
    lbl.BackgroundTransparency = 1

    spawn(function()
        while radarFrame and radarFrame.Parent do
            rs.Color = getRainbowColor()
            wait(0.01)
        end
    end)
end

local function toggleRadar()
    radarEnabled = not radarEnabled

    if not radarFrame then buildRadar() end
    radarFrame.Visible = radarEnabled

    if radarEnabled then
        connections.radar = RunService.RenderStepped:Connect(function()
            for _, dot in pairs(radarDots) do
                pcall(function() dot:Destroy() end)
            end
            radarDots = {}

            local hrp = getHRP()
            if not hrp then return end

            for _, p in pairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character then
                    local tHRP = p.Character:FindFirstChild("HumanoidRootPart")
                    if tHRP then
                        local diff = hrp.Position - tHRP.Position
                        local scale = 110

                        if diff.Magnitude <= 500 then
                            local dot = Instance.new("Frame", radarFrame)
                            dot.Size = UDim2.new(0, 7, 0, 7)
                            dot.Position = UDim2.new(
                                0.5, diff.X / scale - 3,
                                0.5, diff.Z / scale - 3
                            )
                            dot.BackgroundColor3 = Color3.fromRGB(255, 50, 50)
                            dot.BorderSizePixel = 0
                            Instance.new("UICorner", dot).CornerRadius = UDim.new(1, 0)
                            table.insert(radarDots, dot)
                        end
                    end
                end
            end
        end)
    else
        if connections.radar then connections.radar:Disconnect() end
        for _, dot in pairs(radarDots) do
            pcall(function() dot:Destroy() end)
        end
        radarDots = {}
    end

    Notify("ARUSCRIPT V6", "Radar: " .. tostring(radarEnabled))
end
_G.AruToggleRadar = function(arg)
    if arg == "on"  and not radarEnabled then toggleRadar()
    elseif arg == "off" and radarEnabled then toggleRadar()
    else toggleRadar() end
end

