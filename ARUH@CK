-- 2. FLY (ПОЛНАЯ РЕАЛИЗАЦИЯ)
local function ToggleFly()
    State.fly = not State.fly
    UpdateButton("Fly", State.fly)
    
    if State.fly then
        print("✅ Fly включен - создание BodyVelocity и BodyGyro...")
        
        local root = GetRoot()
        if root then
            -- Создаем BodyVelocity
            Data.flyBV = Instance.new("BodyVelocity")
            Data.flyBV.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            Data.flyBV.Velocity = Vector3.new(0, 0, 0)
            Data.flyBV.Parent = root
            
            -- Создаем BodyGyro
            Data.flyBG = Instance.new("BodyGyro")
            Data.flyBG.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            Data.flyBG.CFrame = root.CFrame
            Data.flyBG.Parent = root
            
            -- Основной цикл полета
            Data.connections.fly = Run.Heartbeat:Connect(function()
                if not State.fly then return end
                
                local moveDirection = Vector3.new(0, 0, 0)
                
                -- WASD движение
                if UIS:IsKeyDown(Enum.KeyCode.W) then
                    moveDirection = moveDirection + Cam.CFrame.LookVector
                end
                if UIS:IsKeyDown(Enum.KeyCode.S) then
                    moveDirection = moveDirection - Cam.CFrame.LookVector
                end
                if UIS:IsKeyDown(Enum.KeyCode.A) then
                    moveDirection = moveDirection - Cam.CFrame.RightVector
                end
                if UIS:IsKeyDown(Enum.KeyCode.D) then
                    moveDirection = moveDirection + Cam.CFrame.RightVector
                end
                
                -- Вверх/Вниз
                if UIS:IsKeyDown(Enum.KeyCode.Space) then
                    moveDirection = moveDirection + Vector3.new(0, 1, 0)
                end
                if UIS:IsKeyDown(Enum.KeyCode.LeftControl) then
                    moveDirection = moveDirection - Vector3.new(0, 1, 0)
                end
                
                -- Применяем движение
                if Data.flyBV then
                    Data.flyBV.Velocity = moveDirection * State.flySpeed
                end
                
                if Data.flyBG then
                    Data.flyBG.CFrame = Cam.CFrame
                end
            end)
            
            Notify("FLY", "✅ Включен! Управление: WASD + Space/Ctrl | Скорость: " .. State.flySpeed)
            SendDiscord("✈️ FLY", "Включен (скорость: " .. State.flySpeed .. ")", 65280)
        else
            print("❌ Не удалось найти HumanoidRootPart!")
            State.fly = false
            UpdateButton("Fly", false)
        end
    else
        print("❌ Fly выключен - удаление объектов полета...")
        
        ClearConnection("fly")
        
        if Data.flyBV then
            Data.flyBV:Destroy()
            Data.flyBV = nil
        end
        
        if Data.flyBG then
            Data.flyBG:Destroy()
            Data.flyBG = nil
        end
        
        Notify("FLY", "❌ Выключен")
        SendDiscord("✈️ FLY", "Выключен", 16711680)
    end
end

