-- ============== FLY ==============

local function toggleFly()
    flying = not flying

    if flying then
        local char = getCharacter()
        if not char then flying = false return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then flying = false return end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = true end

        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = hrp

        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bodyGyro.CFrame = hrp.CFrame
        bodyGyro.Parent = hrp

        connections.fly = RunService.Heartbeat:Connect(function()
            local moveDir = Vector3.new(0, 0, 0)
            local spd = UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and speed * 2 or speed

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDir = moveDir + Camera.CFrame.LookVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDir = moveDir - Camera.CFrame.LookVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDir = moveDir - Camera.CFrame.RightVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDir = moveDir + Camera.CFrame.RightVector * spd
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDir = moveDir + Vector3.new(0, spd, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                moveDir = moveDir - Vector3.new(0, spd, 0)
            end

            bodyVelocity.Velocity = moveDir
            bodyGyro.CFrame = Camera.CFrame
        end)
    else
        if connections.fly then connections.fly:Disconnect() end
        if bodyVelocity then bodyVelocity:Destroy(); bodyVelocity = nil end
        if bodyGyro     then bodyGyro:Destroy();     bodyGyro     = nil end
        local hum = getHumanoid()
        if hum then hum.PlatformStand = false end
    end

    SendWebhook("✈️ Fly: **" .. tostring(flying) .. "**")
    Notify("ARUSCRIPT V6", "Fly: " .. tostring(flying))
end
_G.AruToggleFly = function(arg)
    if arg == "on"  and not flying then toggleFly()
    elseif arg == "off" and flying then toggleFly()
    else toggleFly() end
end

