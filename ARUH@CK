local Utils = {}

function Utils.Rainbow()
    Data.hue = Data.hue + 0.005
    if Data.hue >= 1 then Data.hue = 0 end
    return Color3.fromHSV(Data.hue, 1, 1)
end

function Utils.GetChar()
    return Services.Players.LocalPlayer.Character
end

function Utils.GetHumanoid()
    local char = Utils.GetChar()
    return char and char:FindFirstChildOfClass("Humanoid")
end

function Utils.GetRoot()
    local char = Utils.GetChar()
    return char and char:FindFirstChild("HumanoidRootPart")
end

function Utils.Webhook(msg)
    if Settings.Webhook ~= "" then
        pcall(function()
            local req = syn and syn.request or request or http_request or http.request
            if req then
                req({
                    Url = Settings.Webhook,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = Services.HttpService:JSONEncode({
                        embeds = {{
                            title = "🎮 ARUSCRIPT V5",
                            description = msg,
                            color = 65280,
                            timestamp = os.date("!%Y-%m-%dT%H:%M:%S"),
                            footer = {text = Services.Players.LocalPlayer.Name}
                        }}
                    })
                })
            end
        end)
    end
end

function Utils.Notify(title, text, dur)
    pcall(function()
        Services.StarterGui:SetCore("SendNotification", {
            Title = title or "ARUSCRIPT V5",
            Text = text or "",
            Duration = dur or 3
        })
    end)
    print("🔔 " .. title .. " | " .. text)
end

