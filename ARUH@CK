-- Функция создания хакерской кнопки
local function createHackerButton(name, text, layoutOrder)
    local buttonContainer = Instance.new("Frame")
    buttonContainer.Name = name .. "Container"
    buttonContainer.Size = UDim2.new(1, 0, 0, 45)
    buttonContainer.BackgroundTransparency = 1
    buttonContainer.LayoutOrder = layoutOrder
    buttonContainer.Parent = contentFrame
    
    local button = Instance.new("TextButton")
    button.Name = name
    button.Size = UDim2.new(1, 0, 1, 0)
    button.Text = "⟨ " .. text .. " ⟩"
    button.TextScaled = true
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Font = Enum.Font.Code
    button.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    button.BackgroundTransparency = 0.4
    button.BorderSizePixel = 0
    button.AutoButtonColor = false
    button.Parent = buttonContainer
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = button
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 0, 0)
    stroke.Thickness = 2
    stroke.Transparency = 0.2
    stroke.Parent = button
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 15)
    padding.PaddingRight = UDim.new(0, 15)
    padding.Parent = button
    
    -- Hex паттерн на фоне кнопки
    local hexPattern = Instance.new("TextLabel")
    hexPattern.Size = UDim2.new(1, 0, 1, 0)
    hexPattern.Position = UDim2.new(0, 0, 0, 0)
    hexPattern.Text = "0x" .. string.format("%X", math.random(1000000, 9999999))
    hexPattern.TextSize = 10
    hexPattern.TextColor3 = Color3.fromRGB(100, 100, 100)
    hexPattern.Font = Enum.Font.Code
    hexPattern.BackgroundTransparency = 1
    hexPattern.TextTransparency = 0.8
    hexPattern.ZIndex = 1
    hexPattern.Parent = button
    
    -- Эффект глитча на hover
    button.MouseEnter:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.1), {BackgroundTransparency = 0.2}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.1), {Transparency = 0, Thickness = 3}):Play()
        
        -- Глитч эффект
        for i = 1, 3 do
            button.Position = UDim2.new(0, math.random(-2, 2), 0, 0)
            wait(0.05)
        end
        button.Position = UDim2.new(0, 0, 0, 0)
    end)
    
    button.MouseLeave:Connect(function()
        TweenService:Create(button, TweenInfo.new(0.2), {BackgroundTransparency = 0.4}):Play()
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.2, Thickness = 2}):Play()
    end)
    
    return button
end

-- Функция создания хакерского текстового поля
local function createHackerTextBox(name, placeholderText, layoutOrder)
    local textBoxContainer = Instance.new("Frame")
    textBoxContainer.Name = name .. "Container"
    textBoxContainer.Size = UDim2.new(1, 0, 0, 45)
    textBoxContainer.BackgroundTransparency = 1
    textBoxContainer.LayoutOrder = layoutOrder
    textBoxContainer.Parent = contentFrame
    
    local textBox = Instance.new("TextBox")
    textBox.Name = name
    textBox.Size = UDim2.new(1, 0, 1, 0)
    textBox.PlaceholderText = "⟨ " .. placeholderText .. " ⟩"
    textBox.Text = ""
    textBox.TextScaled = true
    textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    textBox.PlaceholderColor3 = Color3.fromRGB(150, 150, 150)
    textBox.Font = Enum.Font.Code
    textBox.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    textBox.BackgroundTransparency = 0.4
    textBox.BorderSizePixel = 0
    textBox.ClearTextOnFocus = false
    textBox.Parent = textBoxContainer
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = textBox
    
    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(255, 0, 0)
    stroke.Thickness = 2
    stroke.Transparency = 0.4
    stroke.Parent = textBox
    
    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 15)
    padding.PaddingRight = UDim.new(0, 15)
    padding.Parent = textBox
    
    -- Мигающий курсор эффект
    local cursor = Instance.new("Frame")
    cursor.Name = "Cursor"
    cursor.Size = UDim2.new(0, 2, 0.6, 0)
    cursor.Position = UDim2.new(0, 15, 0.2, 0)
    cursor.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    cursor.BorderSizePixel = 0
    cursor.Visible = false
    cursor.Parent = textBox
    
    textBox.Focused:Connect(function()
        cursor.Visible = true
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0, Thickness = 3}):Play()
        
        -- Мигающий курсор
        spawn(function()
            while textBox:IsFocused() do
                cursor.Visible = not cursor.Visible
                wait(0.5)
            end
        end)
    end)
    
    textBox.FocusLost:Connect(function()
        cursor.Visible = false
        TweenService:Create(stroke, TweenInfo.new(0.2), {Transparency = 0.4, Thickness = 2}):Play()
    end)
    
    return textBox
end

