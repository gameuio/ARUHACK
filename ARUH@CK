    playerTitle.Position = UDim2.new(0, 10, 0, 0)
    playerTitle.Text = "🎵 MUSIC PLAYER"
    playerTitle.TextColor3 = Color3.fromRGB(0, 255, 255)
    playerTitle.TextSize = 18
    playerTitle.Font = Enum.Font.GothamBlack
    playerTitle.TextXAlignment = Enum.TextXAlignment.Left
    playerTitle.BackgroundTransparency = 1
    
    local trackName = Instance.new("TextLabel", player)
    trackName.Name = "TrackName"
    trackName.Size = UDim2.new(1, -20, 0, 30)
    trackName.Position = UDim2.new(0, 10, 0, 50)
    trackName.Text = "No track playing"
    trackName.TextColor3 = Color3.fromRGB(255, 255, 255)
    trackName.TextSize = 16
    trackName.Font = Enum.Font.GothamBold
    trackName.TextXAlignment = Enum.TextXAlignment.Center
    trackName.BackgroundTransparency = 1
    
    local btnContainer = Instance.new("Frame", player)
    btnContainer.Size = UDim2.new(1, 0, 0, 50)
    btnContainer.Position = UDim2.new(0, 0, 0, 90)
    btnContainer.BackgroundTransparency = 1
    
    local btnList = Instance.new("UIListLayout", btnContainer)
    btnList.FillDirection = Enum.FillDirection.Horizontal
    btnList.HorizontalAlignment = Enum.HorizontalAlignment.Center
    btnList.Padding = UDim.new(0, 15)
    
    local function createMusicBtn(text, callback)
        local btn = Instance.new("TextButton", btnContainer)
        btn.Size = UDim2.new(0, 50, 0, 50)
        btn.Text = text
        btn.TextSize = 24
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Font = Enum.Font.GothamBlack
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
        btn.BorderSizePixel = 0
        
        local btnCorner = Instance.new("UICorner", btn)
        btnCorner.CornerRadius = UDim.new(1, 0)
        
        btn.MouseEnter:Connect(function()
            TS:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 200, 255)}):Play()
        end)
        
        btn.MouseLeave:Connect(function()
            TS:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(40, 40, 55)}):Play()
        end)
        
        btn.MouseButton1Click:Connect(callback)
        return btn
    end
    
    createMusicBtn("⏮", function()
        State.currentMusicIndex = State.currentMusicIndex - 1
        if State.currentMusicIndex < 1 then State.currentMusicIndex = #MusicPlaylist end
        if State.music then
            local track = MusicPlaylist[State.currentMusicIndex]
            Data.musicSound.SoundId = "rbxassetid://" .. track.id
            Data.musicSound:Play()
            trackName.Text = "🎵 " .. track.name
            Notify("MUSIC", "▶️ " .. track.name)
        end
    end)
    
    local playPauseBtn = createMusicBtn("⏸", function()
        if Data.musicSound then
            if Data.musicSound.IsPlaying then
                Data.musicSound:Pause()
                playPauseBtn.Text = "▶️"
                Notify("MUSIC", "⏸ Пауза")
            else
                Data.musicSound:Resume()
                playPauseBtn.Text = "⏸"
                Notify("MUSIC", "▶️ Воспроизведение")
            end
        end
    end)
    
    createMusicBtn("⏭", function()
        State.currentMusicIndex = State.currentMusicIndex + 1
        if State.currentMusicIndex > #MusicPlaylist then State.currentMusicIndex = 1 end
        if State.music then
            local track = MusicPlaylist[State.currentMusicIndex]
            Data.musicSound.SoundId = "rbxassetid://" .. track.id
            Data.musicSound:Play()
            trackName.Text = "🎵 " .. track.name
            Notify("MUSIC", "▶️ " .. track.name)
        end
    end)
    
    createMusicBtn("🔀", function()
        State.currentMusicIndex = math.random(1, #MusicPlaylist)
        if State.music then
            local track = MusicPlaylist[State.currentMusicIndex]
            Data.musicSound.SoundId = "rbxassetid://" .. track.id
            Data.musicSound:Play()
            trackName.Text = "🎵 " .. track.name
            Notify("MUSIC", "🔀 " .. track.name)
        end
    end)
    
    local volLabel = Instance.new("TextLabel", player)
    volLabel.Size = UDim2.new(0, 100, 0, 20)
    volLabel.Position = UDim2.new(0, 10, 0, 150)
    volLabel.Text = "🔊 Volume:"
    volLabel.TextColor3 = Color3.fromRGB(200, 200, 220)
    volLabel.TextSize = 14
    volLabel.Font = Enum.Font.GothamBold
    volLabel.TextXAlignment = Enum.TextXAlignment.Left
    volLabel.BackgroundTransparency = 1
    
    local volSlider = Instance.new("Frame", player)
    volSlider.Size = UDim2.new(1, -120, 0, 8)
    volSlider.Position = UDim2.new(0, 110, 0, 156)
    volSlider.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    volSlider.BorderSizePixel = 0
    local volSliderCorner = Instance.new("UICorner", volSlider)
    volSliderCorner.CornerRadius = UDim.new(1, 0)
    
    local volFill = Instance.new("Frame", volSlider)
    volFill.Size = UDim2.new(State.musicVolume, 0, 1, 0)
    volFill.BackgroundColor3 = Color3.fromRGB(0, 255, 255)
    volFill.BorderSizePixel = 0
    local volFillCorner = Instance.new("UICorner", volFill)
    volFillCorner.CornerRadius = UDim.new(1, 0)
    
    local volDragging = false
    
    local function updateVolume(input)
        local pos = math.clamp((input.Position.X - volSlider.AbsolutePosition.X) / volSlider.AbsoluteSize.X, 0, 1)
        State.musicVolume = pos
        volFill.Size = UDim2.new(pos, 0, 1, 0)
        if Data.musicSound then Data.musicSound.Volume = pos end
        volLabel.Text = string.format("🔊 Volume: %d%%", math.floor(pos * 100))
    end
    
    volSlider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            volDragging = true
            updateVolume(input)
        end
    end)
    
    volSlider.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            volDragging = false
        end
    end)
    
    UIS.InputChanged:Connect(function(input)
        if volDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            updateVolume(input)
        end
    end)
    
    GUI.MusicPlayer = player
end

local function ToggleMusic()
    State.music = not State.music
    UpdateButton("Music", State.music)
    
    if State.music then
        if not Data.musicSound then
            Data.musicSound = Instance.new("Sound")
            Data.musicSound.Parent = GUI.Screen
            Data.musicSound.Looped = false
            Data.musicSound.Volume = State.musicVolume
            
            Data.musicSound.Ended:Connect(function()
                if State.music then
                    State.currentMusicIndex = State.currentMusicIndex + 1
                    if State.currentMusicIndex > #MusicPlaylist then State.currentMusicIndex = 1 end
                    local track = MusicPlaylist[State.currentMusicIndex]
                    Data.musicSound.SoundId = "rbxassetid://" .. track.id
                    Data.musicSound:Play()
                    if GUI.MusicPlayer then
                        GUI.MusicPlayer:FindFirstChild("TrackName").Text = "🎵 " .. track.name
                    end
                    Notify("MUSIC", "▶️ " .. track.name)
                end
            end)
        end
        
        CreateMusicPlayer()
        
        local track = MusicPlaylist[State.currentMusicIndex]
        Data.musicSound.SoundId = "rbxassetid://" .. track.id
        Data.musicSound:Play()
        
        GUI.MusicPlayer:FindFirstChild("TrackName").Text = "🎵 " .. track.name
        GUI.MusicPlayer.Visible = true
        
        Notify("MUSIC PLAYER", "▶️ " .. track.name)
        SendDiscord("🎵 MUSIC", "Включена музыка: " .. track.name, 65280)
    else
        if Data.musicSound then
            Data.musicSound:Stop()
        end
        if GUI.MusicPlayer then
            GUI.MusicPlayer.Visible = false
        end
        Notify("MUSIC PLAYER", "⏸ Выключена")
        SendDiscord("🎵 MUSIC", "Музыка выключена", 16711680)
    end
end

