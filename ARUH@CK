Services.UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    if input.KeyCode == Enum.KeyCode.RightShift then
        if State.menuVisible then
            State.menuVisible = false
            Services.TweenService:Create(GUI.Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Size = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(0.5, 0, 0.5, 0)
            }):Play()
            wait(0.5)
            GUI.Main.Visible = false
            GUI.Toggle.Visible = true
        else
            State.menuVisible = true
            GUI.Toggle.Visible = false
            GUI.Main.Visible = true
            GUI.Main.Size = UDim2.new(0, 0, 0, 0)
            GUI.Main.Position = UDim2.new(0.5, 0, 0.5, 0)
            Services.TweenService:Create(GUI.Main, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 700, 0, 500),
                Position = UDim2.new(0.5, -350, 0.5, -250)
            }):Play()
        end
    elseif input.KeyCode == Enum.KeyCode.F then
        ToggleFly()
    elseif input.KeyCode == Enum.KeyCode.N then
        ToggleNoclip()
    elseif input.KeyCode == Enum.KeyCode.E then
        ToggleESP()
    end
end)

