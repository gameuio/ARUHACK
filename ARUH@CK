        TS:Create(iconLabel, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 0, 0)}):Play()
        TS:Create(textLabel, TweenInfo.new(0.2), {TextColor3 = Color3.fromRGB(0, 0, 0)}):Play()
        
        GUI.CurrentCat = name
        
        for _, v in pairs(GUI.Content:GetChildren()) do
            if v:IsA("Frame") and v.Name ~= "UIListLayout" and v.Name ~= "UIPadding" then
                v.Visible = (v.Name == name)
            end
        end
    end)
    
    local container = Instance.new("Frame", GUI.Content)
    container.Name = name
    container.Size = UDim2.new(1, 0, 0, 0)
