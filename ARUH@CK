-- ============== МУЗЫКА ==============

local function playMusic()
    if not currentSong or not currentSong.Parent then
        currentSong = Instance.new("Sound")
        currentSong.Name = "AruMusic"
        currentSong.Looped = true
        currentSong.Volume = 0
        currentSong.Parent = SoundService
    end
    currentSong.SoundId = musicTrackId
    currentSong:Play()
end

local function toggleMusic()
    musicEnabled = not musicEnabled

    if musicEnabled then
        playMusic()
        if fadeConnection then fadeConnection:Disconnect() end
        local t0 = tick()
        fadeConnection = RunService.Heartbeat:Connect(function()
            local p = math.min((tick()-t0)/2, 1)
            currentSong.Volume = musicVolume * p
            if p >= 1 then fadeConnection:Disconnect() end
        end)
    else
        if fadeConnection then fadeConnection:Disconnect() end
        if currentSong then
            local startVol = currentSong.Volume
            local t0 = tick()
            fadeConnection = RunService.Heartbeat:Connect(function()
                local p = math.min((tick()-t0)/3, 1)
                currentSong.Volume = startVol * (1 - p)
                if p >= 1 then
                    currentSong:Stop()
                    fadeConnection:Disconnect()
                end
            end)
        end
    end

    Notify("ARUSCRIPT V6", "Music: " .. tostring(musicEnabled))
end
_G.AruToggleMusic = function(arg)
    if arg == "on"  and not musicEnabled then toggleMusic()
    elseif arg == "off" and musicEnabled then toggleMusic()
    else toggleMusic() end
end

