-- ============== KEYBINDS ==============

UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end

    local k = input.KeyCode

    if k == Enum.KeyCode.RightShift then
        toggleButton:GetPropertyChangedSignal("Text"):Fire()
        toggleButton.MouseButton1Click:Fire()

    elseif k == Enum.KeyCode.F then
        F.toggleFly()
        setActive(flyBtn, flying)

    elseif k == Enum.KeyCode.N then
        F.toggleNoclip()
        setActive(noclipBtn, noclipEnabled)

    elseif k == Enum.KeyCode.E then
        F.toggleESP()
        setActive(espBtn, espEnabled)

    elseif k == Enum.KeyCode.G then
        F.toggleGodMode()
        setActive(godModeBtn, godModeEnabled)

    elseif k == Enum.KeyCode.BackQuote then
        -- ~ открывает консоль
        if consoleFrame.Visible then
            TweenService:Create(consoleFrame,
                TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In),
                {Position = UDim2.new(0.5,-350,-0.6,0)}):Play()
            wait(0.35)
            consoleFrame.Visible = false
        else
            consoleFrame.Visible = true
            consoleFrame.Position = UDim2.new(0.5,-350,-0.6,0)
            TweenService:Create(consoleFrame,
                TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
                {Position = UDim2.new(0.5,-350,0.5,-230)}):Play()
            consoleInput:CaptureFocus()
        end

    elseif k == Enum.KeyCode.M then
        F.toggleMusic()
        setActive(musicBtn, musicEnabled)

    elseif k == Enum.KeyCode.X then
        F.toggleAimbot()
        setActive(aimbotBtn, aimbotEnabled)

    elseif k == Enum.KeyCode.V then
        F.toggleSpeedhack()
        setActive(speedhackBtn, speedhackEnabled)

    elseif k == Enum.KeyCode.J then
        F.toggleInfJump()
        setActive(infJumpBtn, infJumpEnabled)
    end
end)

