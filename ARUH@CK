-- ESP
local function ToggleESP()
    States.espEnabled = not States.espEnabled
    UpdateButtonStatus("ESP", States.espEnabled)
    
    if States.espEnabled then
        print("🔍 ESP включен")
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local rootPart = player.Character:FindFirstChild("HumanoidRootPart")
                if rootPart and not rootPart:FindFirstChild("ESPBox") then
                    local espBox = Instance.new("BoxHandleAdornment")
                    espBox.Name = "ESPBox"
                    espBox.Size = Vector3.new(4, 7, 1)
                    espBox.Adornee = rootPart
                    espBox.Color3 = Color3.fromRGB(0, 255, 0)
                    espBox.AlwaysOnTop = true
                    espBox.Transparency = 0.5
                    espBox.Parent = rootPart
                end
            end
        end
    else
        print("🔍 ESP выключен")
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character then
                for _, obj in pairs(player.Character:GetDescendants()) do
                    if obj:IsA("BoxHandleAdornment") and obj.Name == "ESPBox" then
                        obj:Destroy()
                    end
                end
            end
        end
    end
    
    SendNotification("ESP", States.espEnabled and "Включен" or "Выключен")
end

-- FLY
local function ToggleFly()
    States.flyEnabled = not States.flyEnabled
    UpdateButtonStatus("Fly", States.flyEnabled)
    
    if States.flyEnabled then
        print("✈️ Fly включен")
        local rootPart = GetRootPart()
        if rootPart then
            Data.bodyVelocity = Instance.new("BodyVelocity")
            Data.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            Data.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
            Data.bodyVelocity.Parent = rootPart
            
            Data.bodyGyro = Instance.new("BodyGyro")
            Data.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
            Data.bodyGyro.CFrame = rootPart.CFrame
            Data.bodyGyro.Parent = rootPart
            
            Data.connections.fly = RunService.Heartbeat:Connect(function()
                if not States.flyEnabled then return end
                
                local moveDirection = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveDirection = moveDirection + Camera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveDirection = moveDirection - Camera.CFrame.LookVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    moveDirection = moveDirection - Camera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    moveDirection = moveDirection + Camera.CFrame.RightVector
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveDirection = moveDirection + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                    moveDirection = moveDirection - Vector3.new(0, 1, 0)
                end
                
                if Data.bodyVelocity then
                    Data.bodyVelocity.Velocity = moveDirection * States.flySpeed
                end
                if Data.bodyGyro then
                    Data.bodyGyro.CFrame = Camera.CFrame
                end
            end)
        end
    else
        print("✈️ Fly выключен")
        if Data.connections.fly then
            Data.connections.fly:Disconnect()
        end
        if Data.bodyVelocity then
            Data.bodyVelocity:Destroy()
            Data.bodyVelocity = nil
        end
        if Data.bodyGyro then
            Data.bodyGyro:Destroy()
            Data.bodyGyro = nil
        end
    end
    
    SendNotification("FLY", States.flyEnabled and "Включен" or "Выключен")
end

