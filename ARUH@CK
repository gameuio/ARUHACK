local function Rainbow()
    State.hue = State.hue + 0.005
    if State.hue >= 1 then State.hue = 0 end
    return Color3.fromHSV(State.hue, 1, 1)
end

local function Notify(title, text)
    pcall(function()
        SG:SetCore("SendNotification", {
            Title = title or "ARUSCRIPT V5",
            Text = text or "",
            Duration = 3
        })
    end)
    print("🔔 " .. title .. ": " .. text)
end

