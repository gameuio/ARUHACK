local function getRainbowColor()
    hue = hue + rainbowSpeed / 100
    if hue >= 1 then hue = 0 end
    return Color3.fromHSV(hue, 1, 1)
end

local function Notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title    = title    or "ARUSCRIPT V6",
            Text     = text     or "",
            Duration = duration or 3,
        })
    end)
end

local function SaveConfig()
    if writefile then
        pcall(function()
            writefile("AruScriptV6_Config.json", HttpService:JSONEncode(Config))
        end)
    end
end

local function LoadConfig()
    if isfile and readfile and isfile("AruScriptV6_Config.json") then
        pcall(function()
            local loaded = HttpService:JSONDecode(readfile("AruScriptV6_Config.json"))
            for k,v in pairs(loaded) do Config[k] = v end
        end)
    end
end

local function SendWebhook(message)
    if Config.DiscordWebhook ~= "" and request then
        pcall(function()
            request({
                Url    = Config.DiscordWebhook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode({
                    embeds = {{
                        title       = "🎮 ARUSCRIPT V6",
                        description = message,
                        color       = 65280,
                        footer      = {text = LocalPlayer.Name .. " | " .. os.date("%X")},
                    }}
                }),
            })
        end)
    end
end

local function getCharacter()
    return LocalPlayer.Character
end

local function getHumanoid()
    local c = getCharacter()
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function getHRP()
    local c = getCharacter()
    return c and c:FindFirstChild("HumanoidRootPart")
end

