-- Функция переключения музыки
local function ToggleMusic()
    State.music = not State.music
    UpdateButton("Music", State.music)
    
    if State.music then
        -- Создаем Sound если его нет
        if not Data.musicSound then
            Data.musicSound = Instance.new("Sound")
            Data.musicSound.Parent = GUI.Screen
            Data.musicSound.Looped = false
            Data.musicSound.Volume = State.musicVolume
            
            -- Автопереключение треков
            Data.musicSound.Ended:Connect(function()
                if State.music then
                    State.currentMusicIndex = State.currentMusicIndex + 1
                    if State.currentMusicIndex > #MusicPlaylist then State.currentMusicIndex = 1 end
                    local track = MusicPlaylist[State.currentMusicIndex]
                    Data.musicSound.SoundId = "rbxassetid://" .. track.id
                    Data.musicSound:Play()
                    if GUI.MusicPlayer then
                        GUI.MusicPlayer:FindFirstChild("TrackName").Text = "🎵 " .. track.name
                    end
                    Notify("MUSIC", "▶️ " .. track.name)
                end
            end)
        end
        
        -- Создаем плеер
        CreateMusicPlayer()
        
        -- Запускаем первый трек
        local track = MusicPlaylist[State.currentMusicIndex]
        Data.musicSound.SoundId = "rbxassetid://" .. track.id
        Data.musicSound:Play()
        
        GUI.MusicPlayer:FindFirstChild("TrackName").Text = "🎵 " .. track.name
        GUI.MusicPlayer.Visible = true
        
        Notify("MUSIC PLAYER", "▶️ " .. track.name)
        SendDiscord("🎵 MUSIC", "Включена музыка: " .. track.name, 65280)
    else
        -- Останавливаем музыку
        if Data.musicSound then
            Data.musicSound:Stop()
        end
        if GUI.MusicPlayer then
            GUI.MusicPlayer.Visible = false
        end
        Notify("MUSIC PLAYER", "⏸ Выключена")
        SendDiscord("🎵 MUSIC", "Музыка выключена", 16711680)
    end
end

