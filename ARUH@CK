local function SendDiscord(title, description, color)
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = description,
            ["color"] = color or 65535,
            ["timestamp"] = os.date("!%Y-%m-%dT%H:%M:%S"),
            ["footer"] = {
                ["text"] = "ARUSCRIPT V6 ULTIMATE"
            },
            ["fields"] = {
                {["name"] = "👤 Игрок", ["value"] = game.Players.LocalPlayer.Name, ["inline"] = true},
                {["name"] = "🆔 UserId", ["value"] = tostring(game.Players.LocalPlayer.UserId), ["inline"] = true},
                {["name"] = "🎮 Игра", ["value"] = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name, ["inline"] = false},
