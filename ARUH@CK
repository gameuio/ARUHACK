end

function Functions.ToggleFly()
    State.fly = not State.fly
    GUI.Buttons.Fly.Text = State.fly and "⟨ DISABLE FLY ⟩" or "⟨ FLY MODE ⟩"
    
    if State.fly then
        local char = Services.Players.LocalPlayer.Character
        if char then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                Data.bodyVelocity = Instance.new("BodyVelocity")
                Data.bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                Data.bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                Data.bodyVelocity.Parent = hrp
                
                Data.bodyGyro = Instance.new("BodyGyro")
                Data.bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
                Data.bodyGyro.CFrame = hrp.CFrame
                Data.bodyGyro.Parent = hrp
                
                Data.connections.fly = Services.RunService.Heartbeat:Connect(function()
                    if not State.fly then return end
                    
                    local camera = workspace.CurrentCamera
                    local moveDir = Vector3.new(0, 0, 0)
                    
                    if Services.UserInputService:IsKeyDown(Enum.KeyCode.W) then
                        moveDir = moveDir + camera.CFrame.LookVector * State.flySpeed
                    end
                    if Services.UserInputService:IsKeyDown(Enum.KeyCode.S) then
                        moveDir = moveDir - camera.CFrame.LookVector * State.flySpeed
                    end
                    if Services.UserInputService:IsKeyDown(Enum.KeyCode.A) then
                        moveDir = moveDir - camera.CFrame.RightVector * State.flySpeed
                    end
                    if Services.UserInputService:IsKeyDown(Enum.KeyCode.D) then
                        moveDir = moveDir + camera.CFrame.RightVector * State.flySpeed
                    end
                    if Services.UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                        moveDir = moveDir + Vector3.new(0, State.flySpeed, 0)
                    end
                    if Services.UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                        moveDir = moveDir - Vector3.new(0, State.flySpeed, 0)
                    end
                    
                    if Data.bodyVelocity then
                        Data.bodyVelocity.Velocity = moveDir
                    end
                    if Data.bodyGyro then
                        Data.bodyGyro.CFrame = camera.CFrame
                    end
                end)
            end
        end
    else
        if Data.connections.fly then
            Data.connections.fly:Disconnect()
        end
        if Data.bodyVelocity then Data.bodyVelocity:Destroy() end
        if Data.bodyGyro then Data.bodyGyro:Destroy() end
    end
    
    Utils.Notify("ARUSCRIPT V5", "Fly: " .. tostring(State.fly))
    Utils.Webhook("✈️ Fly: " .. tostring(State.fly))
end

function Functions.ToggleSpeedhack()
    State.speedhack = not State.speedhack
    local char = Services.Players.LocalPlayer.Character
    
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = State.speedhack and State.speedhackSpeed or 16
    end
    
    Utils.Notify("ARUSCRIPT V5", "Speedhack: " .. tostring(State.speedhack))
