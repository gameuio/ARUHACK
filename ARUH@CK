-- ESP WALLHACK
local function toggleESP()
    espEnabled = not espEnabled
    espBtn.Text = espEnabled and "⟨ DISABLE WALLHACK ⟩" or "⟨ ESP WALLHACK ⟩"
    
    if espEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp and not hrp:FindFirstChild("ESPBox") then
                    local espBox = Instance.new("BoxHandleAdornment")
                    espBox.Name = "ESPBox"
                    espBox.Size = Vector3.new(4, 7, 1)
                    espBox.Adornee = hrp
                    espBox.Color3 = espColor
                    espBox.AlwaysOnTop = true
                    espBox.ZIndex = 10
                    espBox.Transparency = 0.5
                    espBox.Parent = hrp
                end
            end
        end
        consoleLog("👁️ ESP: ENABLED", Color3.fromRGB(0, 255, 0))
    else
        for _, player in pairs(Players:GetPlayers()) do
            if player.Character then
                for _, part in pairs(player.Character:GetDescendants()) do
                    if part:IsA("BoxHandleAdornment") and part.Name == "ESPBox" then
                        part:Destroy()
                    end
                end
            end
        end
        consoleLog("👁️ ESP: DISABLED", Color3.fromRGB(255, 0, 0))
    end
    
    SendWebhook("👁️ ESP: " .. tostring(espEnabled))
    Notify("ARUSCRIPT V5", "ESP: " .. tostring(espEnabled))
end

