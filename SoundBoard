local function tw(o, pr, ti)
    t:Create(o, TweenInfo.new(ti or 0.3), pr):Play()
end

local function mk(cl, pr)
    local o = Instance.new(cl)
    for k, v in pairs(pr) do
        if k ~= "Parent" then o[k] = v end
    end
    o.Parent = pr.Parent
    return o
end

local function co(o, ra)
    mk("UICorner", {CornerRadius = UDim.new(0, ra or 12), Parent = o})
end

local function gr(o)
    mk("UIGradient", {Color = ColorSequence.new{ColorSequenceKeypoint.new(0, c.p), ColorSequenceKeypoint.new(1, c.s)}, Rotation = 90, Parent = o})
end

local function no(ti, te)
    s:SetCore("SendNotification", {Title = ti, Text = te, Duration = 2})
end

