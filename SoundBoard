local function PerformOSINT(player)
    if not player or not player.Parent then
        OSINTText.Text = "❌ Player not found!"
        return
    end
    
    local data = {}
    
    -- Collect data
    data.Name = player.Name
    data.DisplayName = player.DisplayName
    data.UserId = player.UserId
    data.AccountAge = player.AccountAge
    data.IsPremium = player.MembershipType == Enum.MembershipType.Premium
    data.HasVerifiedBadge = player.HasVerifiedBadge
    
    pcall(function() data.IsFriend = player:IsFriendsWith(LocalPlayer.UserId) end)
    
    if player.Team then
        data.TeamName = player.Team.Name
        data.TeamPlayers = #player.Team:GetPlayers()
    end
    
    data.LocaleId = player.LocaleId or "Unknown"
    
    -- Character data
    if player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            data.Health = math.floor(humanoid.Health)
            data.MaxHealth = math.floor(humanoid.MaxHealth)
            data.WalkSpeed = humanoid.WalkSpeed
        end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local dist = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            data.Distance = math.floor(dist)
        end
    end
    
    -- Leaderstats
    data.Stats = {}
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        for _, stat in ipairs(leaderstats:GetChildren()) do
            data.Stats[stat.Name] = tostring(stat.Value)
        end
    end
    
    -- Generate report
    local report = string.format([[
╔═══════════════════════════════════════════════════════════════╗
                    🔍 OSINT INTELLIGENCE REPORT
╚═══════════════════════════════════════════════════════════════╝

👤 PLAYER PROFILE
────────────────────────────────────────────────────────────────
  Name: %s
  Display: %s
  UserID: %d
  Profile: https://www.roblox.com/users/%d/profile
  
  Account Age: %d days (%.1f years)
  Premium: %s
  Verified: %s
  Friend: %s
  Locale: %s

👥 TEAM INFORMATION
────────────────────────────────────────────────────────────────
  Team: %s
  Players: %s

🎮 CHARACTER STATUS
────────────────────────────────────────────────────────────────
  Health: %s/%s
  Speed: %s
  Distance: %s studs

📊 LEADERSTATS
────────────────────────────────────────────────────────────────
%s

🔗 QUICK LINKS
────────────────────────────────────────────────────────────────
  Friends: https://www.roblox.com/users/%d/friends
  Games: https://www.roblox.com/users/%d/games
  Inventory: https://www.roblox.com/users/%d/inventory

────────────────────────────────────────────────────────────────
Report generated: %s
    ]],
        data.Name, data.DisplayName, data.UserId, data.UserId,
        data.AccountAge, data.AccountAge / 365,
        data.IsPremium and "✅ Yes" or "❌ No",
        data.HasVerifiedBadge and "✅ Yes" or "❌ No",
        data.IsFriend and "✅ Yes" or "❌ No",
        data.LocaleId,
        data.TeamName or "No Team",
        data.TeamPlayers and tostring(data.TeamPlayers) or "N/A",
        data.Health or "N/A", data.MaxHealth or "N/A",
        data.WalkSpeed or "N/A",
        data.Distance and (data.Distance .. " studs") or "N/A",
        next(data.Stats) and 
            (function()
                local t = ""
                for k, v in pairs(data.Stats) do
                    t = t .. string.format("  %s: %s\n", k, v)
                end
                return t
            end)() or "  No stats available",
        data.UserId, data.UserId, data.UserId,
        os.date("%H:%M:%S %d/%m/%Y")
    )
    
    OSINTText.Text = report
    OSINTResults.CanvasSize = UDim2.new(0, 0, 0, OSINTText.TextBounds.Y + 20)
end

