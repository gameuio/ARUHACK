-- Scan БЕЗ ОЖИДАНИЙ
local function scan()
    d.rem = {}
    local function sc(o, de)
        if de > 10 then return end
        for _, v in pairs(o:GetChildren()) do
            if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
                table.insert(d.rem, {t = v.ClassName, o = v})
            end
            sc(v, de + 1)
        end
    end
    sc(game:GetService("ReplicatedStorage"), 0)
    sc(w, 0)
    no("✅ Scan Done", #d.rem.." remotes")
end

-- Play - БЕЗ ПРОВЕРОК
local function play(id)
    if #d.rem > 0 then
        for _, re in pairs(d.rem) do
            re.o:FireServer("rbxassetid://"..id)
            re.o:FireServer(tonumber(id))
        end
    else
        if d.snd then d.snd:Destroy() end
        local sn = Instance.new("Sound")
        sn.SoundId = "rbxassetid://"..id
        sn.Volume = 0.5
        sn.Parent = w
        sn:Play()
        d.snd = sn
    end
end

-- Stop
local function stop()
    if d.snd then d.snd:Destroy() end
    for _, o in pairs(w:GetDescendants()) do
        if o:IsA("Sound") then
            o:Stop()
            o:Destroy()
        end
    end
    no("⏹ Stopped", "All stopped")
end

-- OSINT
local function osint(pla)
    local da = {n = pla.Name, d = pla.DisplayName, i = pla.UserId, a = pla.AccountAge}
    local ch = pla.Character
    if ch then
        local hm = ch:FindFirstChild("Humanoid")
        if hm then
            da.hp = math.floor(hm.Health)
            da.mh = math.floor(hm.MaxHealth)
            da.sp = hm.WalkSpeed
        end
    end
    
    g.rt.Text = string.format([[
🔍 OSINT
%s (@%s)
ID: %d | Age: %d days
HP: %s/%s | Speed: %s
roblox.com/users/%d
    ]], da.n, da.d, da.i, da.a, da.hp or "N/A", da.mh or "N/A", da.sp or "N/A", da.i)
    
    g.rs.CanvasSize = UDim2.new(0,0,0,g.rt.TextBounds.Y+20)
end

