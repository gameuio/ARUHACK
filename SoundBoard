local function applyStats()
    pcall(function()
        char = plr.Character or plr.CharacterAdded:Wait()
        hum = char:WaitForChild("Humanoid")
        
        hum.WalkSpeed = data.weapons.speed
        if hum.UseJumpPower then
            hum.JumpPower = data.weapons.jump
        else
            hum.JumpHeight = data.weapons.jump / 4
        end
        workspace.Gravity = data.weapons.gravity
        
        notif("✅ Stats Applied", string.format("Speed:%d Jump:%d Grav:%.1f", data.weapons.speed, data.weapons.jump, data.weapons.gravity))
        data.stats.weapons = data.stats.weapons + 1
    end)
end

local function toggleFly()
    flyEnabled = not flyEnabled
    g.flyBtn.BackgroundColor3 = flyEnabled and theme.ok or theme.bg
    g.flyBtn.Text = flyEnabled and "🚀 FLY: ON" or "🚀 FLY: OFF"
    
    if flyEnabled then
        local flying = true
        local ctrl = {f = 0, b = 0, l = 0, r = 0}
        local lastctrl = {f = 0, b = 0, l = 0, r = 0}
        local maxspeed = 50
        local speed = 0
        
        spawn(function()
            while flyEnabled and char and hum do
                local bg = char.HumanoidRootPart:FindFirstChild("FlyBodyGyro") or Instance.new("BodyGyro")
                local bv = char.HumanoidRootPart:FindFirstChild("FlyBodyVelocity") or Instance.new("BodyVelocity")
                bg.Name = "FlyBodyGyro"
                bv.Name = "FlyBodyVelocity"
                bg.P = 9e4
                bg.maxTorque = Vector3.new(9e9, 9e9, 9e9)
                bg.cframe = char.HumanoidRootPart.CFrame
                bv.velocity = Vector3.new(0, 0, 0)
                bv.maxForce = Vector3.new(9e9, 9e9, 9e9)
                bg.Parent = char.HumanoidRootPart
                bv.Parent = char.HumanoidRootPart
                
                wait()
            end
            
            if char and char:FindFirstChild("HumanoidRootPart") then
                local bg = char.HumanoidRootPart:FindFirstChild("FlyBodyGyro")
                local bv = char.HumanoidRootPart:FindFirstChild("FlyBodyVelocity")
                if bg then bg:Destroy() end
                if bv then bv:Destroy() end
            end
        end)
        
        notif("🚀 Fly Enabled", "WASD to fly, Q/E up/down")
    else
        notif("🚀 Fly Disabled", "")
    end
end

local function toggleNoclip()
    noclipEnabled = not noclipEnabled
    g.noclipBtn.BackgroundColor3 = noclipEnabled and theme.ok or theme.bg
    g.noclipBtn.Text = noclipEnabled and "👻 NOCLIP: ON" or "👻 NOCLIP: OFF"
    
    if noclipEnabled then
        spawn(function()
            while noclipEnabled do
                pcall(function()
                    for _, v in pairs(char:GetDescendants()) do
                        if v:IsA("BasePart") then
                            v.CanCollide = false
                        end
                    end
                end)
                wait(0.1)
            end
            pcall(function()
                for _, v in pairs(char:GetDescendants()) do
                    if v:IsA("BasePart") then
                        v.CanCollide = true
                    end
                end
            end)
        end)
        notif("👻 Noclip ON", "Walk through walls!")
    else
        notif("👻 Noclip OFF", "")
    end
end

local function toggleESP()
    espEnabled = not espEnabled
    g.espBtn.BackgroundColor3 = espEnabled and theme.ok or theme.bg
    g.espBtn.Text = espEnabled and "👁️ ESP: ON" or "👁️ ESP: OFF"
    
    if espEnabled then
        for _, p in pairs(plrs:GetPlayers()) do
            if p ~= plr and p.Character then
                spawn(function()
                    local c = p.Character
                    local h = Instance.new("Highlight")
                    h.Name = "ESP_Highlight"
                    h.FillColor = Color3.fromRGB(255, 0, 0)
                    h.OutlineColor = Color3.fromRGB(255, 255, 255)
                    h.FillTransparency = 0.5
                    h.OutlineTransparency = 0
                    h.Parent = c
                end)
            end
        end
        notif("👁️ ESP ON", "See all players!")
    else
        for _, p in pairs(plrs:GetPlayers()) do
            if p.Character then
                local h = p.Character:FindFirstChild("ESP_Highlight")
                if h then h:Destroy() end
            end
        end
        notif("👁️ ESP OFF", "")
    end
end

