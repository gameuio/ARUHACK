local function tw(obj, props, time)
    tws:Create(obj, TweenInfo.new(time or 0.3, Enum.EasingStyle.Quad), props):Play()
end

local function mk(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then obj[k] = v end
    end
    obj.Parent = props.Parent
    return obj
end

local function corner(obj, r)
    return mk("UICorner", {CornerRadius = UDim.new(0, r or 10), Parent = obj})
end

local function grad(obj)
    return mk("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, theme.p),
            ColorSequenceKeypoint.new(1, theme.s)
        },
        Rotation = 90,
        Parent = obj
    })
end

local function notif(title, text)
    pcall(function()
        sg:SetCore("SendNotification", {Title = title, Text = text, Duration = 3})
    end)
end

