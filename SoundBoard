-- События OSINT
SearchButton.MouseButton1Click:Connect(function()
    local input = SearchInput.Text
    if input and input ~= "" then
        local player = GetPlayerByNameOrId(input)
        if player then
            PerformOSINT(player)
        else
            OSINTText.Text = string.format("❌ Игрок '%s' не найден на сервере!", input)
        end
    end
end)

