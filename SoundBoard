local Functions = {}

-- Remote Scanner
function Functions.ScanRemotes()
    if AppData.ScanInProgress then
        Utils.Notify("⚠️  Warning", "Scan already in progress!", 2)
        return
    end
    
    AppData.ScanInProgress = true
    RemoteStatusText.Text = "⏳ Scanning all services...\n📊 Please wait..."
    RemoteStatusText.TextColor3 = Theme.Info
    
    if GUI.StatusText then
        GUI.StatusText.Text = "SCANNING..."
        GUI.StatusText.TextColor3 = Theme.Warning
    end
    
    AppData.Remotes = {}
    AppData.RemoteEvents = 0
    AppData.RemoteFunctions = 0
    AppData.UnreliableRemotes = 0
    
    local scanStart = tick()
    
    local function DeepScan(container, depth, maxDepth)
        if depth >= (maxDepth or Config.MaxRemoteDepth) then return end
        
        for _, obj in pairs(container:GetChildren()) do
            Utils.Try(function()
                if obj:IsA("RemoteEvent") then
                    table.insert(AppData.Remotes, {Type = "Event", Object = obj, Path = obj:GetFullName()})
                    AppData.RemoteEvents = AppData.RemoteEvents + 1
                elseif obj:IsA("UnreliableRemoteEvent") then
                    table.insert(AppData.Remotes, {Type = "UnreliableEvent", Object = obj, Path = obj:GetFullName()})
                    AppData.UnreliableRemotes = AppData.UnreliableRemotes + 1
                elseif obj:IsA("RemoteFunction") then
                    table.insert(AppData.Remotes, {Type = "Function", Object = obj, Path = obj:GetFullName()})
                    AppData.RemoteFunctions = AppData.RemoteFunctions + 1
                end
                
                if #obj:GetChildren() > 0 then
                    DeepScan(obj, depth + 1, maxDepth)
                end
            end)
        end
    end
    
    print("[SCAN] Starting deep scan...")
    
    Utils.Try(function() DeepScan(Services.ReplicatedStorage, 0, 25) end)
    Utils.Try(function() DeepScan(Services.Workspace, 0, 20) end)
    
    for _, player in pairs(Services.Players:GetPlayers()) do
        Utils.Try(function()
            if player.Character then
                DeepScan(player.Character, 0, 15)
            end
            DeepScan(player, 0, 15)
        end)
    end
    
    Utils.Try(function() DeepScan(game:GetService("StarterGui"), 0, 15) end)
    Utils.Try(function() DeepScan(game:GetService("StarterPlayer"), 0, 15) end)
    Utils.Try(function() DeepScan(game:GetService("StarterPack"), 0, 10) end)
    
    local scanTime = tick() - scanStart
    local total = #AppData.Remotes
    
    EventsValue.Text = tostring(AppData.RemoteEvents + AppData.UnreliableRemotes)
    FuncsValue.Text = tostring(AppData.RemoteFunctions)
    
    AppData.LastScanTime = tick()
    AppData.Stats.TotalScans = AppData.Stats.TotalScans + 1
    AppData.Stats.RemotesFound = total
    
    if total > 0 then
        RemoteStatusText.Text = string.format(
            "✅ Scan Complete in %.2fs\n📊 Events: %d | Functions: %d | Total: %d\n⚡ Ready for exploitation!",
            scanTime, AppData.RemoteEvents + AppData.UnreliableRemotes, AppData.RemoteFunctions, total
        )
        RemoteStatusText.TextColor3 = Theme.Success
        
        if GUI.StatusText then
            GUI.StatusText.Text = string.format("FOUND %d REMOTES", total)
            GUI.StatusText.TextColor3 = Theme.Success
        end
        
        Utils.Notify("✅ Scan Complete", string.format("Found %d exploitable remotes!", total), 3, "🔍")
        print(string.format("[SCAN] Found %d remotes in %.2fs", total, scanTime))
    else
        RemoteStatusText.Text = "❌ No remotes found\n💡 Try another game or rescan\n⚠️  Some games don't use remotes"
        RemoteStatusText.TextColor3 = Theme.Danger
        
        if GUI.StatusText then
            GUI.StatusText.Text = "NO REMOTES"
            GUI.StatusText.TextColor3 = Theme.Danger
        end
        
        Utils.Notify("❌ Scan Failed", "No remotes found in this game", 3, "⚠️")
    end
    
    AppData.ScanInProgress = false
end

-- Play Sound
function Functions.PlaySound(audioId, songName)
    if not audioId or audioId == "" then
        Utils.Notify("⚠️  Error", "Invalid Audio ID", 2)
        return
    end
    
    local id = tostring(audioId)
    
    if #AppData.Remotes > 0 then
        local sent = 0
        for _, remote in pairs(AppData.Remotes) do
            Utils.Try(function()
                if remote.Type == "Event" or remote.Type == "UnreliableEvent" then
                    remote.Object:FireServer("rbxassetid://" .. id)
                    remote.Object:FireServer(tonumber(id))
                    remote.Object:FireServer({SoundId = "rbxassetid://" .. id, Sound = id, ID = id})
                    remote.Object:FireServer({Action = "PlaySound", Id = id})
                    sent = sent + 1
                end
            end)
        end
        
        Utils.Notify("▶️  Playing", string.format("Sent to %d remotes", sent), 2, "🔊")
        print(string.format("[SOUND] Sent %s to %d remotes", songName or id, sent))
    else
        if AppData.CurrentSound then
            Utils.Try(function()
                AppData.CurrentSound:Stop()
                AppData.CurrentSound:Destroy()
            end)
        end
        
        local sound = Instance.new("Sound")
        sound.SoundId = "rbxassetid://" .. id
        sound.Volume = AppData.Volume
        sound.Parent = Services.Workspace
        sound:Play()
        
        AppData.CurrentSound = sound
        
        Utils.Notify("▶️  Playing", "Local mode (only you hear)", 2, "🎵")
        print(string.format("[SOUND] Playing locally: %s", songName or id))
    end
    
    table.insert(AppData.SoundHistory, {
        ID = id,
        Name = songName or "Custom",
        Time = tick()
    })
    
    AppData.Stats.TotalSoundsPlayed = AppData.Stats.TotalSoundsPlayed + 1
end

-- Stop All
function Functions.StopAll()
    if AppData.CurrentSound then
        Utils.Try(function()
            AppData.CurrentSound:Stop()
            AppData.CurrentSound:Destroy()
        end)
        AppData.CurrentSound = nil
    end
    
    for _, obj in pairs(Services.Workspace:GetDescendants()) do
        if obj:IsA("Sound") then
            Utils.Try(function()
                obj:Stop()
                obj:Destroy()
            end)
        end
    end
    
    Utils.Notify("⏹️  Stopped", "All sounds stopped", 2, "🔇")
    print("[SOUND] All sounds stopped")
end

-- OSINT
function Functions.PerformOSINT(player)
    if not player or not player.Parent then
        ResultText.Text = "❌ Player not found or left"
        return
    end
    
    AppData.SelectedPlayer = player
    AppData.Stats.TotalOSINTQueries = AppData.Stats.TotalOSINTQueries + 1
    AppData.Stats.PlayersScanned = AppData.Stats.PlayersScanned + 1
    
    local data = {
        Name = player.Name,
        Display = player.DisplayName,
        ID = player.UserId,
        Age = player.AccountAge,
        Premium = player.MembershipType == Enum.MembershipType.Premium,
        Verified = player.HasVerifiedBadge,
        Locale = player.LocaleId or "Unknown",
    }
    
    Utils.Try(function() data.Friend = player:IsFriendsWith(Player.UserId) end)
    
    if player.Team then
        data.Team = player.Team.Name
        data.TeamColor = tostring(player.Team.TeamColor)
        data.TeamPlayers = #player.Team:GetPlayers()
    end
    
    if player.Character then
        local hum = player.Character:FindFirstChild("Humanoid")
        if hum then
            data.Health = math.floor(hum.Health)
            data.MaxHealth = math.floor(hum.MaxHealth)
            data.Speed = hum.WalkSpeed
            data.State = tostring(hum:GetState()):gsub("Enum.HumanoidStateType.", "")
        end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
            local dist = Utils.GetDistance(hrp.Position, Player.Character.HumanoidRootPart.Position)
            data.Distance = math.floor(dist)
        end
    end
    
    local stats = ""
    local ls = player:FindFirstChild("leaderstats")
    if ls then
        for _, s in pairs(ls:GetChildren()) do
            stats = stats .. string.format("  %s: %s\n", s.Name, tostring(s.Value))
        end
    end
    
    local report = string.format([[
