local function UpdateStatus(text, color)
    StatusText.Text = text
    CreateTween(StatusText, {TextColor3 = color})
    CreateTween(StatusDot, {BackgroundColor3 = color})
end

local function ScanForRemotes()
    UpdateStatus("SCANNING...", Config.WarningColor)
    foundRemotes = {}
    local remoteEvents = 0
    local remoteFunctions = 0
    
    wait(0.1)
    
    local function DeepScan(container, maxDepth, currentDepth)
        currentDepth = currentDepth or 0
        if currentDepth >= (maxDepth or 15) then return end
        
        local success, result = pcall(function()
            for _, obj in ipairs(container:GetChildren()) do
                pcall(function()
                    if obj:IsA("RemoteEvent") or obj:IsA("UnreliableRemoteEvent") then
                        table.insert(foundRemotes, {Type = "Event", Object = obj})
                        remoteEvents = remoteEvents + 1
                        print("[FOUND] RemoteEvent:", obj:GetFullName())
                    elseif obj:IsA("RemoteFunction") then
                        table.insert(foundRemotes, {Type = "Function", Object = obj})
                        remoteFunctions = remoteFunctions + 1
                        print("[FOUND] RemoteFunction:", obj:GetFullName())
                    end
                    
                    if #obj:GetChildren() > 0 then
                        DeepScan(obj, maxDepth, currentDepth + 1)
                    end
                end)
            end
        end)
    end
    
    -- Сканируем все возможные контейнеры
    print("=== Starting Deep Scan ===")
    
    pcall(function() DeepScan(ReplicatedStorage, 20) end)
    pcall(function() DeepScan(workspace, 15) end)
    
    for _, player in ipairs(Players:GetPlayers()) do
        pcall(function() 
            if player.Character then
                DeepScan(player.Character, 10)
            end
            DeepScan(player, 10)
        end)
    end
    
    pcall(function() DeepScan(game:GetService("StarterGui"), 10) end)
    pcall(function() DeepScan(game:GetService("StarterPlayer"), 10) end)
    pcall(function() DeepScan(game:GetService("StarterPack"), 10) end)
    
    -- Обновляем UI
    RemoteEventsValue.Text = tostring(remoteEvents)
    RemoteFunctionsValue.Text = tostring(remoteFunctions)
    
    local total = #foundRemotes
    print(string.format("=== Scan Complete: %d total ===", total))
    
    if total > 0 then
        UpdateStatus("READY - " .. total .. " REMOTES", Config.AccentColor)
        Notify("✅ Scan Complete", string.format("Found %d Remote Events!", total), 3)
    else
        UpdateStatus("NO REMOTES FOUND", Config.DangerColor)
        Notify("❌ Scan Failed", "No exploitable remotes found", 3)
    end
    
    scanComplete = true
end

local function PlaySoundViaRemote(audioId)
    if #foundRemotes == 0 then
        Notify("⚠️  Warning", "Scan for remotes first!", 2)
        return
    end
    
    local attempts = 0
    for _, remote in ipairs(foundRemotes) do
        pcall(function()
            if remote.Type == "Event" then
                remote.Object:FireServer("rbxassetid://" .. audioId)
                remote.Object:FireServer(tonumber(audioId))
                remote.Object:FireServer({Sound = audioId, SoundId = "rbxassetid://" .. audioId})
                attempts = attempts + 1
            end
        end)
    end
    
    UpdateStatus("PLAYING - " .. attempts .. " ATTEMPTS", Config.AccentColor)
end

local function PlaySoundLocal(audioId)
    if currentSound then
        pcall(function() currentSound:Stop() currentSound:Destroy() end)
    end
    
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://" .. audioId
    sound.Volume = 0.5
    sound.Parent = workspace
    sound:Play()
    
    currentSound = sound
    UpdateStatus("PLAYING LOCALLY", Config.WarningColor)
end

local function StopAllSounds()
    if currentSound then
        pcall(function() currentSound:Stop() currentSound:Destroy() end)
    end
    
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("Sound") then
            pcall(function() obj:Stop() obj:Destroy() end)
        end
    end
    
    UpdateStatus("STOPPED", Config.DangerColor)
    Notify("⏹️  Stopped", "All sounds stopped", 2)
end

