local function scanRemotes()
    data.remotes = {}
    data.revents = 0
    data.rfuncs = 0
    g.stxt.Text = "⏳ Scanning..."
    g.stxt.TextColor3 = theme.warn
    
    local function scan(obj, depth)
        if depth > 15 then return end
        pcall(function()
            for _, v in pairs(obj:GetChildren()) do
                if v:IsA("RemoteEvent") then
                    table.insert(data.remotes, {t="Event", o=v})
                    data.revents = data.revents + 1
                elseif v:IsA("RemoteFunction") then
                    table.insert(data.remotes, {t="Function", o=v})
                    data.rfuncs = data.rfuncs + 1
                end
                scan(v, depth + 1)
            end
        end)
    end
    
    scan(game:GetService("ReplicatedStorage"), 0)
    scan(workspace, 0)
    for _, p in pairs(plrs:GetPlayers()) do
        if p.Character then scan(p.Character, 0) end
    end
    
    local tot = #data.remotes
    g.eval.Text = tostring(data.revents)
    g.fval.Text = tostring(data.rfuncs)
    
    if tot > 0 then
        g.stxt.Text = string.format("✅ %d remotes!", tot)
        g.stxt.TextColor3 = theme.ok
        notif("✅ Scan Done", string.format("%d remotes!", tot))
    else
        g.stxt.Text = "❌ No remotes"
        g.stxt.TextColor3 = theme.no
        notif("❌ Failed", "No remotes")
    end
    data.stats.scans = data.stats.scans + 1
end

local function playSound(id, name)
    if not id or id == "" then return end
    if #data.remotes > 0 then
        local sent = 0
        for _, r in pairs(data.remotes) do
            pcall(function()
                if r.t == "Event" then
                    r.o:FireServer("rbxassetid://" .. id)
                    r.o:FireServer(tonumber(id))
                    r.o:FireServer({SoundId="rbxassetid://"..id, Sound=id, ID=id})
                    sent = sent + 1
                end
            end)
        end
        notif("▶️  Playing", string.format("%d remotes", sent))
    else
        if data.sound then pcall(function() data.sound:Destroy() end) end
        local s = Instance.new("Sound")
        s.SoundId = "rbxassetid://" .. id
        s.Volume = data.vol
        s.Parent = workspace
        s:Play()
        data.sound = s
        notif("▶️  Playing", "Local")
    end
    data.stats.played = data.stats.played + 1
end

local function stopAll()
    if data.sound then pcall(function() data.sound:Destroy() end) end
    for _, o in pairs(workspace:GetDescendants()) do
        if o:IsA("Sound") then pcall(function() o:Stop() o:Destroy() end) end
    end
    notif("⏹️  Stopped", "All stopped")
end

local function extremeOSINT(p)
    if not p or not p.Parent then
        g.rtxt.Text = "❌ Player not found"
        return
    end
    
    data.selplr = p
    data.stats.osint = data.stats.osint + 1
    
    local d = {}
    
    local function hash(str)
        local h = 0
        for i = 1, #str do
            h = (h * 31 + string.byte(str, i)) % 2147483647
        end
        return string.format("%X", h)
    end
    
    d.name = p.Name
    d.display = p.DisplayName
    d.id = p.UserId
    d.age = p.AccountAge
    d.created = os.date("%d/%m/%Y", tick() - (d.age * 86400))
    d.premium = p.MembershipType == Enum.MembershipType.Premium
    d.verified = p.HasVerifiedBadge or false
    d.locale = p.LocaleId or "Unknown"
    pcall(function() d.friend = p:IsFriendsWith(plr.UserId) end)
    
    local c = p.Character
    if c then
        local h = c:FindFirstChild("Humanoid")
        if h then
            d.health = math.floor(h.Health)
            d.maxhp = math.floor(h.MaxHealth)
            d.speed = h.WalkSpeed
            d.jump = h.JumpPower or h.JumpHeight
            d.state = tostring(h:GetState()):gsub("Enum.HumanoidStateType.", "")
            d.sitting = h.Sit
            d.dead = h.Health <= 0
        end
        
        local hrp = c:FindFirstChild("HumanoidRootPart")
        if hrp then
            if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local dist = (plr.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                d.distance = math.floor(dist)
            end
            d.velocity = math.floor(hrp.AssemblyLinearVelocity.Magnitude)
            d.position = string.format("X:%.0f Y:%.0f Z:%.0f", hrp.Position.X, hrp.Position.Y, hrp.Position.Z)
        end
        d.accessories = #c:GetChildren() - 5
