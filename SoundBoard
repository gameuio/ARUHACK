local function teleportToPlayer(name)
    local target = nil
    for _, p in pairs(plrs:GetPlayers()) do
        if p.Name:lower():find(name:lower()) or p.DisplayName:lower():find(name:lower()) then
            target = p
            break
        end
    end
    
    if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        pcall(function()
            char.HumanoidRootPart.CFrame = target.Character.HumanoidRootPart.CFrame
            notif("🚀 Teleported", string.format("To %s", target.Name))
            data.stats.teleports = data.stats.teleports + 1
        end)
    else
        notif("❌ Error", "Player not found")
    end
end

local function teleportToSpawn()
    pcall(function()
        local spawnLocation = workspace:FindFirstChild("SpawnLocation") or workspace:FindFirstChildOfClass("SpawnLocation")
        if spawnLocation then
            char.HumanoidRootPart.CFrame = spawnLocation.CFrame + Vector3.new(0, 5, 0)
            notif("🏠 Teleported", "To spawn")
        else
            char.HumanoidRootPart.CFrame = CFrame.new(0, 50, 0)
            notif("🏠 Teleported", "To default spawn")
        end
    end)
end

