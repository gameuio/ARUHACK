local Utils = {}

-- Animation Tween
function Utils.Tween(object, properties, duration, style, direction, callback)
    local tweenInfo = TweenInfo.new(
        duration or Config.AnimationSpeed,
        style or Enum.EasingStyle.Quad,
        direction or Enum.EasingDirection.Out
    )
    local tween = Services.TweenService:Create(object, tweenInfo, properties)
    
    if callback then
        tween.Completed:Connect(callback)
    end
    
    tween:Play()
    return tween
end

-- Corner Radius
function Utils.Corner(object, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or Config.CornerRadius)
    corner.Parent = object
    return corner
end

-- Stroke/Border
function Utils.Stroke(object, color, thickness, transparency)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Theme.Primary
    stroke.Thickness = thickness or 1
    stroke.Transparency = transparency or 0
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    stroke.Parent = object
    return stroke
end

-- Gradient
function Utils.Gradient(object, colors, rotation, offset)
    local gradient = Instance.new("UIGradient")
    
    if colors then
        gradient.Color = colors
    else
        gradient.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Theme.Primary),
            ColorSequenceKeypoint.new(1, Theme.Secondary)
        }
    end
    
    gradient.Rotation = rotation or 90
    gradient.Offset = offset or Vector2.new(0, 0)
    gradient.Parent = object
    return gradient
end

-- Padding
function Utils.Padding(object, all, top, bottom, left, right)
    local padding = Instance.new("UIPadding")
    
    if all then
        padding.PaddingTop = UDim.new(0, all)
        padding.PaddingBottom = UDim.new(0, all)
        padding.PaddingLeft = UDim.new(0, all)
        padding.PaddingRight = UDim.new(0, all)
    else
        padding.PaddingTop = UDim.new(0, top or 0)
        padding.PaddingBottom = UDim.new(0, bottom or 0)
        padding.PaddingLeft = UDim.new(0, left or 0)
        padding.PaddingRight = UDim.new(0, right or 0)
    end
    
    padding.Parent = object
    return padding
end

-- Notification
function Utils.Notify(title, text, duration, icon, color)
    if not AppData.Settings.ShowNotifications then return end
    
    local notifTitle = icon and (icon .. " " .. title) or title
    
    pcall(function()
        Services.StarterGui:SetCore("SendNotification", {
            Title = notifTitle,
            Text = text,
            Duration = duration or 3,
            Button1 = "OK",
            Icon = icon or ""
        })
    end)
    
    print(string.format("[NOTIF] %s: %s", title, text))
end

-- Format Numbers
function Utils.FormatNumber(num)
    if num >= 1000000000 then
        return string.format("%.2fB", num / 1000000000)
    elseif num >= 1000000 then
        return string.format("%.2fM", num / 1000000)
    elseif num >= 1000 then
        return string.format("%.1fK", num / 1000)
    else
        return tostring(math.floor(num))
    end
end

-- Format Time
function Utils.FormatTime(seconds)
    local hours = math.floor(seconds / 3600)
    local minutes = math.floor((seconds % 3600) / 60)
    local secs = math.floor(seconds % 60)
    
    if hours > 0 then
        return string.format("%02d:%02d:%02d", hours, minutes, secs)
    else
        return string.format("%02d:%02d", minutes, secs)
    end
end

-- Format Duration
function Utils.FormatDuration(str)
    return str
end

-- Deep Copy
function Utils.DeepCopy(original)
    local copy = {}
    for k, v in pairs(original) do
        if type(v) == "table" then
            copy[k] = Utils.DeepCopy(v)
        else
            copy[k] = v
        end
    end
    return copy
end

-- Safe Call
function Utils.Try(func, ...)
    local success, result = pcall(func, ...)
    if not success then
        warn("[ERROR]", result)
        return nil, result
    end
    return result
end

-- Random ID
function Utils.RandomID(length)
    local chars = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789"
    local id = ""
    for i = 1, length or 8 do
        local rand = math.random(1, #chars)
        id = id .. string.sub(chars, rand, rand)
    end
    return id
end

-- Get Distance
function Utils.GetDistance(pos1, pos2)
    return (pos1 - pos2).Magnitude
end

-- Lerp Color
function Utils.LerpColor(color1, color2, alpha)
    return Color3.new(
        color1.R + (color2.R - color1.R) * alpha,
        color1.G + (color2.G - color1.G) * alpha,
        color1.B + (color2.B - color1.B) * alpha
    )
end

