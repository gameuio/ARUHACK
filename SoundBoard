-- ИСПРАВЛЕННАЯ функция сканирования
local function ScanForRemotes()
    foundRemotes = {}
    local remoteEvents = 0
    local remoteFunctions = 0
    
    InfoText.Text = "🔍 Сканирование...\n⏳ Ищем Remote Events..."
    wait(0.1)
    
    -- Функция рекурсивного сканирования
    local function deepScan(parent, depth)
        if depth > 10 then return end -- Защита от бесконечной рекурсии
        
        pcall(function()
            for _, obj in pairs(parent:GetChildren()) do
                pcall(function()
                    -- Проверяем тип объекта
                    if obj:IsA("RemoteEvent") then
                        table.insert(foundRemotes, {Type = "RemoteEvent", Object = obj, Path = obj:GetFullName()})
                        remoteEvents = remoteEvents + 1
                        print("[FOUND RemoteEvent]", obj:GetFullName())
                    elseif obj:IsA("RemoteFunction") then
                        table.insert(foundRemotes, {Type = "RemoteFunction", Object = obj, Path = obj:GetFullName()})
                        remoteFunctions = remoteFunctions + 1
                        print("[FOUND RemoteFunction]", obj:GetFullName())
                    elseif obj:IsA("UnreliableRemoteEvent") then
                        table.insert(foundRemotes, {Type = "UnreliableRemoteEvent", Object = obj, Path = obj:GetFullName()})
                        remoteEvents = remoteEvents + 1
                        print("[FOUND UnreliableRemoteEvent]", obj:GetFullName())
                    end
                    
                    -- Рекурсивно сканируем детей
                    if #obj:GetChildren() > 0 then
                        deepScan(obj, depth + 1)
                    end
                end)
            end
        end)
    end
    
    -- Сканируем ReplicatedStorage
    print("Scanning ReplicatedStorage...")
    deepScan(ReplicatedStorage, 0)
    
    -- Сканируем Workspace
    print("Scanning Workspace...")
    deepScan(workspace, 0)
    
    -- Сканируем игроков
    print("Scanning Players...")
    for _, player in pairs(Players:GetPlayers()) do
        if player.Character then
            deepScan(player.Character, 0)
        end
        deepScan(player, 0)
    end
    
    -- Сканируем StarterGui, StarterPlayer и другие сервисы
    pcall(function() deepScan(game:GetService("StarterGui"), 0) end)
    pcall(function() deepScan(game:GetService("StarterPlayer"), 0) end)
    pcall(function() deepScan(game:GetService("StarterPack"), 0) end)
    
    -- Обновляем информацию
    local totalFound = #foundRemotes
    InfoText.Text = string.format(
        "✅ Сканирование завершено!\n🔍 RemoteEvents: %d\n🔍 RemoteFunctions: %d\n📊 Всего: %d\n🎵 Готов к воспроизведению!",
        remoteEvents, remoteFunctions, totalFound
    )
    
    print(string.format("[SCAN COMPLETE] Found %d Remotes", totalFound))
    
    if totalFound == 0 then
        InfoText.Text = "❌ Remote Events не найдены!\n💡 Игра не использует Remotes\n🎵 Используйте локальный режим"
    end
end

-- Функция воспроизведения через Remote
local function PlaySoundViaRemote(audioId)
    if #foundRemotes == 0 then
        InfoText.Text = "❌ Сначала просканируйте!\n🔍 Нажмите кнопку сканирования"
        return
    end
    
    local attempts = 0
    
    for _, remote in pairs(foundRemotes) do
        pcall(function()
            local obj = remote.Object
            
            if remote.Type == "RemoteEvent" then
                -- Пробуем разные варианты
                obj:FireServer("rbxassetid://" .. audioId)
                obj:FireServer(audioId)
                obj:FireServer({Sound = audioId})
                obj:FireServer({SoundId = "rbxassetid://" .. audioId})
                obj:FireServer({Id = audioId})
                obj:FireServer("Play", audioId)
                obj:FireServer("PlaySound", audioId)
                obj:FireServer("Music", audioId)
                obj:FireServer({Action = "Play", Id = audioId})
                attempts = attempts + 1
            elseif remote.Type == "RemoteFunction" then
                obj:InvokeServer("rbxassetid://" .. audioId)
                obj:InvokeServer(audioId)
                attempts = attempts + 1
            end
        end)
    end
    
    InfoText.Text = string.format(
        "✅ Отправлено %d запросов!\n🎵 Audio ID: %s\n📡 Remotes: %d\n⚠️  Проверьте результат",
        attempts, audioId, #foundRemotes
    )
end

-- Функция локального воспроизведения
local function PlaySoundLocal(audioId)
    if currentSound then
        pcall(function() currentSound:Stop() currentSound:Destroy() end)
    end
    
    local sound = Instance.new("Sound")
    sound.SoundId = "rbxassetid://" .. audioId
    sound.Volume = 0.5
    sound.Parent = workspace
    sound:Play()
    
    currentSound = sound
    
    InfoText.Text = string.format(
        "🎵 Локальное воспроизведение\n🔊 Audio ID: %s\n⚠️  Слышите только ВЫ!",
        audioId
    )
end

-- Функция остановки
local function StopAllSounds()
    if currentSound then
        pcall(function() currentSound:Stop() currentSound:Destroy() end)
        currentSound = nil
    end
    
    for _, remote in pairs(foundRemotes) do
        pcall(function()
            if remote.Type == "RemoteEvent" then
                remote.Object:FireServer("Stop")
                remote.Object:FireServer({Action = "Stop"})
            end
        end)
    end
    
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Sound") then
            pcall(function() obj:Stop() obj:Destroy() end)
        end
    end
    
    InfoText.Text = "⏹️  Все звуки остановлены!"
end

