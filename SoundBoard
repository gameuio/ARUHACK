local function GetPlayerByNameOrId(input)
    input = tostring(input)
    
    -- Проверяем UserID
    local userId = tonumber(input)
    if userId then
        for _, player in pairs(Players:GetPlayers()) do
            if player.UserId == userId then
                return player
            end
        end
    end
    
    -- Проверяем имя (частичное совпадение)
    input = input:lower()
    for _, player in pairs(Players:GetPlayers()) do
        if player.Name:lower():find(input) or player.DisplayName:lower():find(input) then
            return player
        end
    end
    
    return nil
end

local function PerformOSINT(player)
    if not player or not player.Parent then
        OSINTText.Text = "❌ Игрок не найден!"
        return
    end
    
    -- Собираем МАКСИМУМ информации
    local data = {}
    
    -- Базовая информация
    data.Name = player.Name
    data.DisplayName = player.DisplayName
    data.UserId = player.UserId
    data.AccountAge = player.AccountAge
    data.AccountAgeYears = string.format("%.2f", player.AccountAge / 365)
    data.AccountCreated = os.date("%d.%m.%Y", os.time() - (player.AccountAge * 86400))
    
    -- Premium и Verified
    data.IsPremium = player.MembershipType == Enum.MembershipType.Premium
    data.MembershipType = tostring(player.MembershipType):gsub("Enum.MembershipType.", "")
    data.HasVerifiedBadge = player.HasVerifiedBadge
    
    -- Друг или нет
    data.IsFriend = false
    pcall(function() data.IsFriend = player:IsFriendsWith(LocalPlayer.UserId) end)
    
    -- Команда
    if player.Team then
        data.TeamName = player.Team.Name
        data.TeamColor = tostring(player.Team.TeamColor)
        data.TeamPlayers = #player.Team:GetPlayers()
    else
        data.TeamName = "No Team"
        data.TeamColor = "N/A"
        data.TeamPlayers = 0
    end
    
    -- Locale
    data.LocaleId = player.LocaleId or "Unknown"
    
    -- Персонаж
    data.HasCharacter = player.Character ~= nil
    if player.Character then
        local humanoid = player.Character:FindFirstChild("Humanoid")
        if humanoid then
            data.Health = math.floor(humanoid.Health)
            data.MaxHealth = math.floor(humanoid.MaxHealth)
            data.WalkSpeed = humanoid.WalkSpeed
            data.JumpPower = humanoid.JumpPower or humanoid.JumpHeight
            data.RigType = humanoid.RigType.Name
        end
        
        local hrp = player.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local pos = hrp.Position
            data.Position = string.format("X:%.1f Y:%.1f Z:%.1f", pos.X, pos.Y, pos.Z)
            
            if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local distance = (hrp.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                data.Distance = math.floor(distance)
            end
        end
        
        -- Аксессуары
        data.Accessories = {}
        for _, item in pairs(player.Character:GetChildren()) do
            if item:IsA("Accessory") then
                table.insert(data.Accessories, item.Name)
            end
        end
    end
    
    -- Leaderstats
    data.Leaderstats = {}
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        for _, stat in pairs(leaderstats:GetChildren()) do
            data.Leaderstats[stat.Name] = tostring(stat.Value)
        end
    end
    
    -- Backpack
    data.BackpackTools = {}
    local backpack = player:FindFirstChild("Backpack")
    if backpack then
        for _, tool in pairs(backpack:GetChildren()) do
            if tool:IsA("Tool") then
                table.insert(data.BackpackTools, tool.Name)
            end
        end
    end
    
