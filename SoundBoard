local function getHWID()
    local hwid = {}
    local function hash(str)
        local h = 0
        for i = 1, #str do
            h = (h * 31 + string.byte(str, i)) % 2147483647
        end
        return string.format("%X", h)
    end
    hwid.userId = plr.UserId
    hwid.userName = plr.Name
    hwid.accountAge = plr.AccountAge
    local baseString = string.format("%d_%s_%d_%d", hwid.userId, hwid.userName, hwid.accountAge, tick())
    hwid.hardwareId = hash(baseString)
    hwid.sessionId = hash(tostring(tick()) .. tostring(math.random(1000000, 9999999)))
    hwid.executor = identifyexecutor and identifyexecutor() or "Unknown"
    hwid.exploiting = true
    hwid.gameId = game.PlaceId
    hwid.jobId = game.JobId
    hwid.clientId = game:GetService("RbxAnalyticsService"):GetClientId() or "Unknown"
    return hwid
end

local function getIPInfo()
    local ip = {}
    ip.type = "IPv4"
    ip.status = "Private/Hidden by Roblox"
    ip.note = "Real IP hidden by Roblox security"
    ip.serverRegion = plr.LocaleId or "Unknown"
    local ping = stats.PerformanceStats.Ping:GetValue() or 0
    ip.ping = math.floor(ping)
    ip.quality = ping < 50 and "Excellent" or (ping < 100 and "Good" or (ping < 200 and "Fair" or "Poor"))
    return ip
end

local function getDeviceInfo()
    local device = {}
    device.platform = uis.TouchEnabled and not uis.KeyboardEnabled and "Mobile" or (uis.KeyboardEnabled and "PC" or "Console")
    device.touchEnabled = uis.TouchEnabled
    device.keyboardEnabled = uis.KeyboardEnabled
    device.mouseEnabled = uis.MouseEnabled
    device.gamepadEnabled = uis.GamepadEnabled
    device.vrEnabled = uis.VREnabled
    device.accelerometerEnabled = uis.AccelerometerEnabled
    device.gyroscopeEnabled = uis.GyroscopeEnabled
    local viewport = workspace.CurrentCamera.ViewportSize
    device.screenWidth = math.floor(viewport.X)
    device.screenHeight = math.floor(viewport.Y)
    device.aspectRatio = string.format("%.2f:1", viewport.X / viewport.Y)
    device.screenSize = string.format("%dx%d", device.screenWidth, device.screenHeight)
    device.graphicsQuality = settings().Rendering.QualityLevel.Value
    device.graphicsMode = settings().Rendering.MeshPartDetailLevel.Name
    return device
end

