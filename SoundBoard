local Utils = {}

-- Tween Function
function Utils.Tween(object, properties, duration)
    pcall(function()
        TweenService:Create(
            object,
            TweenInfo.new(duration or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            properties
        ):Play()
    end)
end

-- Create Instance
function Utils.Create(className, properties)
    local object = Instance.new(className)
    for property, value in pairs(properties) do
        if property ~= "Parent" then
            pcall(function()
                object[property] = value
            end)
        end
    end
    object.Parent = properties.Parent
    return object
end

-- Add Corner
function Utils.AddCorner(object, radius)
    Utils.Create("UICorner", {
        CornerRadius = UDim.new(0, radius or 12),
        Parent = object
    })
end

-- Add Gradient
function Utils.AddGradient(object, rotation)
    Utils.Create("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Colors.Primary),
            ColorSequenceKeypoint.new(1, Colors.Secondary)
        },
        Rotation = rotation or 90,
        Parent = object
    })
end

-- Add Padding
function Utils.AddPadding(object, padding)
    Utils.Create("UIPadding", {
        PaddingTop = UDim.new(0, padding),
        PaddingBottom = UDim.new(0, padding),
        PaddingLeft = UDim.new(0, padding),
        PaddingRight = UDim.new(0, padding),
        Parent = object
    })
end

-- Notification
function Utils.Notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 3
        })
    end)
end

