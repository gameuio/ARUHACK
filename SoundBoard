-- Scan Remotes
local function scanRemotes()
    data.remotes = {}
    data.revents = 0
    data.rfuncs = 0
    
    g.stxt.Text = "⏳ Scanning..."
    g.stxt.TextColor3 = theme.warn
    
    local function scan(obj, depth)
        if depth > 15 then return end
        pcall(function()
            for _, v in pairs(obj:GetChildren()) do
                if v:IsA("RemoteEvent") then
                    table.insert(data.remotes, {t="Event", o=v})
                    data.revents = data.revents + 1
                elseif v:IsA("RemoteFunction") then
                    table.insert(data.remotes, {t="Function", o=v})
                    data.rfuncs = data.rfuncs + 1
                end
                scan(v, depth + 1)
            end
        end)
    end
    
    scan(game:GetService("ReplicatedStorage"), 0)
    scan(workspace, 0)
    
    for _, p in pairs(plrs:GetPlayers()) do
        if p.Character then scan(p.Character, 0) end
    end
    
    local tot = #data.remotes
    
    g.eval.Text = tostring(data.revents)
    g.fval.Text = tostring(data.rfuncs)
    
    if tot > 0 then
        g.stxt.Text = string.format("✅ Found %d remotes! (%d events, %d funcs)", tot, data.revents, data.rfuncs)
        g.stxt.TextColor3 = theme.ok
        notif("✅ Scan Complete", string.format("Found %d remotes!", tot))
    else
        g.stxt.Text = "❌ No remotes found"
        g.stxt.TextColor3 = theme.no
        notif("❌ Failed", "No remotes found")
    end
    
    data.stats.scans = data.stats.scans + 1
end

-- Play Sound
local function playSound(id, name)
    if not id or id == "" then return end
    
    if #data.remotes > 0 then
        local sent = 0
        for _, r in pairs(data.remotes) do
            pcall(function()
                if r.t == "Event" then
                    r.o:FireServer("rbxassetid://" .. id)
                    r.o:FireServer(tonumber(id))
                    r.o:FireServer({SoundId="rbxassetid://"..id, Sound=id, ID=id})
                    sent = sent + 1
                end
            end)
        end
        notif("▶️  Playing", string.format("Sent to %d remotes", sent))
    else
        if data.sound then
            pcall(function() data.sound:Destroy() end)
        end
        
        local s = Instance.new("Sound")
        s.SoundId = "rbxassetid://" .. id
        s.Volume = data.vol
        s.Parent = workspace
        s:Play()
        
        data.sound = s
        notif("▶️  Playing", "Local mode")
    end
    
    data.stats.played = data.stats.played + 1
end

-- Stop All
local function stopAll()
    if data.sound then
        pcall(function() data.sound:Destroy() end)
    end
    
    for _, o in pairs(workspace:GetDescendants()) do
        if o:IsA("Sound") then
            pcall(function() o:Stop() o:Destroy() end)
        end
    end
    
    notif("⏹️  Stopped", "All sounds stopped")
end

-- OSINT
local function osint(p)
    if not p or not p.Parent then
        g.rtxt.Text = "❌ Player not found"
        return
    end
    
    data.selplr = p
    data.stats.osint = data.stats.osint + 1
    
    local d = {
        n = p.Name,
        dn = p.DisplayName,
        id = p.UserId,
        age = p.AccountAge,
        prem = p.MembershipType == Enum.MembershipType.Premium,
    }
    
    local c = p.Character
    if c then
        local h = c:FindFirstChild("Humanoid")
        if h then
            d.hp = math.floor(h.Health)
            d.mhp = math.floor(h.MaxHealth)
            d.spd = h.WalkSpeed
        end
        
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and c:FindFirstChild("HumanoidRootPart") then
            local dist = (plr.Character.HumanoidRootPart.Position - c.HumanoidRootPart.Position).Magnitude
            d.dist = math.floor(dist)
        end
    end
    
    local rep = string.format([[
