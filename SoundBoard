--                                    UTILITY FUNCTIONS
-- ═══════════════════════════════════════════════════════════════════════════════════════════════

local Utils = {}

function Utils.Tween(obj, props, time)
    TweenService:Create(obj, TweenInfo.new(time or 0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

function Utils.Create(class, props)
    local obj = Instance.new(class)
    for k, v in pairs(props) do
        if k ~= "Parent" then obj[k] = v end
    end
    obj.Parent = props.Parent
    return obj
end

function Utils.Corner(obj, radius)
    return Utils.Create("UICorner", {CornerRadius = UDim.new(0, radius or 12), Parent = obj})
end

function Utils.Gradient(obj, rotation)
    return Utils.Create("UIGradient", {
        Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Theme.Primary),
            ColorSequenceKeypoint.new(1, Theme.Secondary)
        },
        Rotation = rotation or 90,
        Parent = obj
    })
end

function Utils.Stroke(obj, color, thickness)
    return Utils.Create("UIStroke", {
        Color = color or Theme.Primary,
        Thickness = thickness or 2,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
        Parent = obj
    })
end

function Utils.Padding(obj, padding)
    return Utils.Create("UIPadding", {
        PaddingTop = UDim.new(0, padding),
        PaddingBottom = UDim.new(0, padding),
        PaddingLeft = UDim.new(0, padding),
        PaddingRight = UDim.new(0, padding),
        Parent = obj
    })
end

function Utils.Notify(title, text, duration)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = duration or 3
        })
    end)
end

