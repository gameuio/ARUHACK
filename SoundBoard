-- Show OSINT
function Functions.ShowOSINT(player)
    pcall(function()
        local data = {
            Name = player.Name,
            DisplayName = player.DisplayName,
            UserID = player.UserId,
            AccountAge = player.AccountAge,
        }
        
        local character = player.Character
        if character then
            local humanoid = character:FindFirstChild("Humanoid")
            if humanoid then
                data.Health = math.floor(humanoid.Health)
                data.MaxHealth = math.floor(humanoid.MaxHealth)
                data.WalkSpeed = humanoid.WalkSpeed
                data.JumpPower = humanoid.UseJumpPower and humanoid.JumpPower or humanoid.JumpHeight * 4
            end
            
            local rootPart = character:FindFirstChild("HumanoidRootPart")
            if rootPart then
                local position = rootPart.Position
                data.Position = string.format("%.1f, %.1f, %.1f", position.X, position.Y, position.Z)
            end
