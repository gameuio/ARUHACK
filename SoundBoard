local UtilityFunctions = {}

-- Performance Monitor
local FPS = 0
local LastFrame = tick()
local FrameCounter = 0

RunService.RenderStepped:Connect(function()
    FrameCounter = FrameCounter + 1
    local currentTime = tick()
    
    if currentTime - LastFrame >= 1 then
        FPS = FrameCounter
        FrameCounter = 0
        LastFrame = currentTime
    end
end)

-- Update Performance Stats
function UtilityFunctions.UpdatePerformance()
    pcall(function()
        -- FPS
        GUI.FPSLabel.Text = string.format("FPS: %d", FPS)
        GUI.FPSLabel.TextColor3 = FPS >= 50 and Theme.Success or (FPS >= 30 and Theme.Warning or Theme.Danger)
        
        -- Ping
        local ping = Stats.PerformanceStats.Ping:GetValue()
        GUI.PingLabel.Text = string.format("PING: %dms", math.floor(ping))
        GUI.PingLabel.TextColor3 = ping < 100 and Theme.Success or (ping < 200 and Theme.Warning or Theme.Danger)
        
        -- Memory
        local memory = Stats:GetTotalMemoryUsageMb()
        GUI.MemoryLabel.Text = string.format("MEMORY: %dMB", math.floor(memory))
        GUI.MemoryLabel.TextColor3 = memory < 1000 and Theme.Success or (memory < 2000 and Theme.Warning or Theme.Danger)
        
        -- Players
        local playerCount = #Players:GetPlayers()
        GUI.PlayersLabel.Text = string.format("PLAYERS: %d/%d", playerCount, Players.MaxPlayers)
        
        -- Session Time
        local sessionTime = tick() - Data.Stats.SessionStart
        local hours = math.floor(sessionTime / 3600)
        local minutes = math.floor((sessionTime % 3600) / 60)
        local seconds = math.floor(sessionTime % 60)
        GUI.SessionLabel.Text = string.format("⏱️ SESSION: %02d:%02d:%02d", hours, minutes, seconds)
    end)
end

-- Update every second
spawn(function()
    while wait(1) do
        UtilityFunctions.UpdatePerformance()
    end
end)

