local Functions = {}

-- Scan for Remotes
function Functions.ScanRemotes()
    Data.Remotes = {}
    
    local function scanObject(object, depth)
        if depth > 10 then return end
        
        pcall(function()
            for _, child in pairs(object:GetChildren()) do
                if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") then
                    table.insert(Data.Remotes, {
                        Type = child.ClassName,
                        Object = child,
                        Path = child:GetFullName()
                    })
                end
                scanObject(child, depth + 1)
            end
        end)
    end
    
    scanObject(ReplicatedStorage, 0)
    scanObject(Workspace, 0)
    
    Utils.Notify("✅ Scan Complete", "Found " .. #Data.Remotes .. " remotes!")
    print("[SCAN] Found " .. #Data.Remotes .. " remotes")
end

-- Play Sound
function Functions.PlaySound(soundId)
    pcall(function()
        if #Data.Remotes > 0 then
            -- Try to fire remotes
            for _, remote in pairs(Data.Remotes) do
                pcall(function()
                    remote.Object:FireServer("rbxassetid://" .. soundId)
                    remote.Object:FireServer(tonumber(soundId))
                end)
            end
            Utils.Notify("🔊 Playing", "Attempting to play via remotes...")
        else
            -- Play locally
            if Data.CurrentSound then
                Data.CurrentSound:Destroy()
            end
            
            local sound = Instance.new("Sound")
            sound.SoundId = "rbxassetid://" .. soundId
            sound.Volume = 0.5
            sound.Parent = Workspace
            sound:Play()
            
            Data.CurrentSound = sound
            Utils.Notify("🔊 Playing", "Playing locally...")
        end
    end)
end

-- Stop All Sounds
function Functions.StopAllSounds()
    pcall(function()
        if Data.CurrentSound then
            Data.CurrentSound:Destroy()
        end
        
        for _, sound in pairs(Workspace:GetDescendants()) do
            if sound:IsA("Sound") then
                sound:Stop()
                sound:Destroy()
            end
        end
    end)
    
    Utils.Notify("⏹ Stopped", "All sounds stopped")
end

