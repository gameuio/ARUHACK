    b.Position = UDim2.new((y % 2 == 0) and 0.07 or 0.52,0,0,420 + math.floor(y/2)*35)
    b.BackgroundColor3 = Color3.fromRGB(80,0,0)
    b.TextColor3 = Color3.new(1,1,1)
    b.Text = text .. ": OFF"
    return b
end

local ex = {
    SuperJump = addExtraButton("SuperJump", 0),
    Sit = addExtraButton("Sit", 1),
    Reset = addExtraButton("Reset", 2),
    TPUp = addExtraButton("TP Up", 3),
    AirWalk = addExtraButton("AirWalk", 4),
    Spin = addExtraButton("Spin", 5),
    Bright = addExtraButton("Bright", 6),
    Invis = addExtraButton("Invisible", 7),
    ClickTP = addExtraButton("ClickTP", 8),
    FPS = addExtraButton("FPSBoost", 9)
}

local function toggleBtn(btn, name, state)
    btn.Text = name .. ": " .. (state and "ON" or "OFF")
    btn.BackgroundColor3 = state and Color3.fromRGB(0,120,0) or Color3.fromRGB(80,0,0)
end

ex.SuperJump.MouseButton1Click:Connect(function()
    states.superJump = not states.superJump
    toggleBtn(ex.SuperJump, "SuperJump", states.superJump)
end)

ex.Sit.MouseButton1Click:Connect(function()
    if Humanoid then
        Humanoid.Sit = true
    end
end)

ex.Reset.MouseButton1Click:Connect(function()
    if Character then
        Character:BreakJoints()
    end
end)

ex.TPUp.MouseButton1Click:Connect(function()
    if HRP then
        HRP.CFrame = HRP.CFrame + Vector3.new(0,50,0)
    end
end)

ex.AirWalk.MouseButton1Click:Connect(function()
    states.airWalk = not states.airWalk
    toggleBtn(ex.AirWalk, "AirWalk", states.airWalk)
end)

ex.Spin.MouseButton1Click:Connect(function()
    states.spin = not states.spin
    toggleBtn(ex.Spin, "Spin", states.spin)
end)

ex.Bright.MouseButton1Click:Connect(function()
    states.fullbright = not states.fullbright
    toggleBtn(ex.Bright, "Bright", states.fullbright)
    if states.fullbright then
        game.Lighting.Brightness = 5
        game.Lighting.ClockTime = 14
        game.Lighting.FogEnd = 100000
    end
end)

ex.Invis.MouseButton1Click:Connect(function()
    states.invisible = not states.invisible
    toggleBtn(ex.Invis, "Invisible", states.invisible)
end)

ex.ClickTP.MouseButton1Click:Connect(function()
    states.clicktp = not states.clicktp
    toggleBtn(ex.ClickTP, "ClickTP", states.clicktp)
end)

ex.FPS.MouseButton1Click:Connect(function()
    states.fpsboost = not states.fpsboost
    toggleBtn(ex.FPS, "FPSBoost", states.fpsboost)

    if states.fpsboost then
        settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
        for _, v in ipairs(game:GetDescendants()) do
            if v:IsA("BasePart") then
                v.Material = Enum.Material.Plastic
                v.Reflectance = 0
            end
        end
    end
end)

UIS.InputBegan:Connect(function(input, gp)
    if gp then return end

    if states.clicktp and input.UserInputType == Enum.UserInputType.MouseButton1 then
        local mouse = LocalPlayer:GetMouse()
        if mouse.Hit and HRP then
            HRP.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0,3,0))
        end
    end
end)

RunService.RenderStepped:Connect(function()
    if not Character or not HRP then return end

    if states.spin then
        HRP.CFrame = HRP.CFrame * CFrame.Angles(0, math.rad(5), 0)
    end

    if states.invisible then
        for _, v in ipairs(Character:GetDescendants()) do
            if v:IsA("BasePart") then
                v.Transparency = 0.65
            end
        end
    end

    if states.airWalk then
        local p = Instance.new("Part")
        p.Size = Vector3.new(6,1,6)
        p.Anchored = true
        p.Transparency = 1
        p.CanCollide = true
        p.Position = HRP.Position - Vector3.new(0,3,0)
        p.Parent = workspace
        game.Debris:AddItem(p, 0.15)
    end
end)

UIS.JumpRequest:Connect(function()
    if states.superJump and HRP then
        HRP.Velocity = Vector3.new(HRP.Velocity.X, 120, HRP.Velocity.Z)
    end
end)
