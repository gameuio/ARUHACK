-- states
local flying, speedOn, noclipOn, infJumpOn = false, false, false, false
local espOn, aimOn, followOn = false, false, false
local selectedPlayer = nil
local flySpeed, normalSpeed, fastSpeed = 90, 16, 75
local bv, bg
local espObjects = {}

pcall(function() game.CoreGui.UnifiedHub:Destroy() end)

-- anti-afk
LocalPlayer.Idled:Connect(function()
    VirtualUser:CaptureController()
